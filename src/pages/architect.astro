                startViewerSafely();
              },
              { rootMargin: '280px' },
            )
          : null;

      if (shouldReplayWithoutPreloader) {
        returnBlankTimer = window.setTimeout(() => {
          returnBlankTimer = 0;
          startFrameId = window.requestAnimationFrame(() => {
            startFrameId = 0;
            startViewerSafely();
          });
        }, ARCHITECT_RETURN_BLANK_HOLD_MS);
      } else if (observer) {
        observer.observe(viewer);
        setPreloaderTimer(startViewerSafely, 0);
      } else {
        setPreloaderTimer(startViewerSafely, 0);
      }

      const dispose = () => {
        if (hasDisposed) return;
        hasDisposed = true;
        document.removeEventListener('astro:before-swap', dispose);
        window.removeEventListener('pagehide', dispose);
        if (startFrameId) {
          window.cancelAnimationFrame(startFrameId);
          startFrameId = 0;
        }
        if (returnBlankTimer) {
          window.clearTimeout(returnBlankTimer);
          returnBlankTimer = 0;
        }
        document.documentElement.classList.remove(architectReturnBlankClass);
        observer?.disconnect();
        preloaderTimers.forEach((timer) => window.clearTimeout(timer));
        preloaderTimers.clear();
        delete viewer.dataset.viewerBooted;
        document.documentElement.classList.remove(rockControlsLockedClass);
        viewer.classList.remove('is-ready', 'is-return-reveal', 'is-return-reveal-visible', 'is-rock-visible');
        viewer.style.removeProperty('--architect-rock-fade-ms');
        viewer.style.removeProperty('--architect-return-rock-fade-ms');
        if (shell instanceof HTMLElement) {
          shell.style.removeProperty('--architect-viewport-height');
        }
        window.removeEventListener('resize', syncArchitectViewportHeight);
        window.removeEventListener('orientationchange', forceSyncArchitectViewportHeight);
        window.visualViewport?.removeEventListener('resize', syncArchitectViewportHeight);
        if (stage instanceof HTMLElement) {
          stage.classList.remove(
            'is-reveal-sequence',
            'is-projects-visible',
            'is-portfolios-visible'
          );
          stage.style.removeProperty('--architect-link-fade-ms');
        }
        cleanupSpatialLinks();
        cleanupSharedPreloaderComplete();
        unlockPageBehindPreloader();
        clearPendingArchitectPreloader();
        unlockRockControlsAfterPreloader();
        clearNavigationPreloaderClassIfIdle();
        cleanup();
        if (state.dispose === dispose) state.dispose = null;
      };

      state.dispose = dispose;
      document.addEventListener('astro:before-swap', dispose);
      window.addEventListener('pagehide', dispose);
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:after-swap', initArchitectViewer);
      document.addEventListener('astro:page-load', initArchitectViewer);
      window.addEventListener('pageshow', initArchitectViewer);
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArchitectViewer, { once: true });
    } else {
      initArchitectViewer();
    }
  })();
</script>

