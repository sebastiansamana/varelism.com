---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Architect | Sebastian Samana" description="Built work and spatial research.">
  <section class="section fade-up">
    <p class="eyebrow">Architect</p>
    <h1 class="page-title">Buildings, interiors, and spatial studies.</h1>
    <p class="page-intro">
      Architecture is treated as long-duration research. Each project records a method for working with context,
      light, and material memory.
    </p>
  </section>

  <section class="section architect-list">
    {projects.map((project, index) => (
      <article class="entry fade-up stagger" style={`--delay:${index * 0.06}s`}>
        <a href={`/projects/${project.slug}/`}>
          <p class="meta">{project.data.year} · {project.data.location} · {project.data.category}</p>
          <h2>{project.data.title}</h2>
          <p>{project.data.excerpt}</p>
        </a>
      </article>
    ))}
  </section>

  <a class="btn-link" href="/projects/">Open Full Project Archive</a>
</BaseLayout>

<style>
  .architect-list {
    border-top: 1px solid var(--line);
    margin-bottom: 1.6rem;
  }

  .entry {
    border-bottom: 1px solid var(--line);
    padding: 1.35rem 0 1.45rem;
  }

  .meta {
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.73rem;
    letter-spacing: 0.04em;
    margin: 0 0 0.35rem;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(1.36rem, 2vw, 1.9rem);
    font-weight: 400;
    margin: 0;
  }

  .entry p:last-child {
    color: var(--muted);
    margin: 0.34rem 0 0;
    max-width: 68ch;
  }

  .entry a {
    display: block;
    transition: opacity 0.25s var(--ease);
  }

  .entry a:hover {
    opacity: 0.66;
  }
</style>
