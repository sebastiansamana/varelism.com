---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const modelUrl = `${basePath}/models/Processed_Rock_Model_optimized.glb`;
---

<BaseLayout title="Architect | Varelism" description="Interactive architectural object.">
  <div class="architect-viewer" data-architect-viewer data-model-url={modelUrl}></div>
  <section class="architect-stage" data-architect-stage aria-label="Architect">
    <nav class="architect-spatial-nav" aria-label="Architect sections">
      <a
        class="architect-spatial-link architect-spatial-link--projects"
        href="/architect/projects"
        data-architect-spatial-link
      >
        Projects
      </a>
      <a
        class="architect-spatial-link architect-spatial-link--portfolios"
        href="/architect/portfolios"
        data-architect-spatial-link
      >
        Portfolios
      </a>
    </nav>
  </section>
</BaseLayout>

<script>
  (() => {
    const stateKey = '__varelismArchitectViewer';
    const state = (window[stateKey] ||= {
      dispose: null,
      listenersAttached: false,
    });
    const navigationPreloaderClass = 'home-preloader-navigation-active';
    const rockControlsLockedClass = 'architect-rock-controls-locked';
    const architectReturnReplayKey = 'varelism-architect-return-replay';
    const architectReturnBlankClass = 'architect-return-blank-active';
    const routeEnteringClass = 'varelism-route-entering';
    const ARCHITECT_RETURN_BLANK_HOLD_MS = 360;
    const ARCHITECT_ROCK_FADE_MS = 620;
    const ARCHITECT_LINK_FADE_MS = 450;
    const ARCHITECT_PROJECTS_REVEAL_DELAY_MS = ARCHITECT_ROCK_FADE_MS + 240;
    const ARCHITECT_PORTFOLIOS_REVEAL_DELAY_MS = ARCHITECT_PROJECTS_REVEAL_DELAY_MS + 750;
    const ARCHITECT_INTRO_ORBIT_RAMP_MS =
      ARCHITECT_PORTFOLIOS_REVEAL_DELAY_MS - ARCHITECT_PROJECTS_REVEAL_DELAY_MS + ARCHITECT_LINK_FADE_MS;
    const ARCHITECT_SCENE_READY_EVENT = 'varelism:architect-scene-ready';
    const ARCHITECT_SCENE_READY_FLAG = '__varelismReady_varelism_architect_scene_ready';

    const clearNavigationPreloaderClassIfIdle = () => {
      if (
        document.querySelector(
          '[data-home-preloader-handoff], [data-home-preloader][data-navigation-preloader="true"]'
        )
      ) {
        return;
      }

      document.documentElement.classList.remove(navigationPreloaderClass);
      window.__varelismUnlockNavigationPreloaderScroll?.();
    };

    const disposeCurrentViewer = () => {
      if (typeof state.dispose === 'function') {
        state.dispose();
        state.dispose = null;
      }
    };

    const isSamePath = (pathA, pathB) =>
      pathA === pathB ||
      `${pathA.replace(/\/$/, '')}/` === `${pathB.replace(/\/$/, '')}/`;

    const markArchitectReturnReplay = () => {
      try {
        sessionStorage.setItem(architectReturnReplayKey, 'true');
      } catch {
        // Storage can be unavailable in strict privacy contexts.
      }
    };

    const consumeArchitectReturnReplay = () => {
      try {
        if (sessionStorage.getItem(architectReturnReplayKey) !== 'true') return false;
        sessionStorage.removeItem(architectReturnReplayKey);
        return true;
      } catch {
        return false;
      }
    };

    const getPendingHandoffState = () => {
      const visibleHandoff = document.querySelector('[data-home-preloader-handoff]');
      const visibleHandoffPath = visibleHandoff instanceof HTMLElement ? visibleHandoff.dataset.handoffPath : '';
      const activeHandoff = window.__varelismActivePreloaderHandoff;
      const pendingNavigation = window.__varelismPendingPreloaderNavigation;
      const shouldHonorVisibleHandoff = Boolean(
        activeHandoff?.startedAt || pendingNavigation?.suppressRoutePreloaderVideo
      );

      if (
        visibleHandoff instanceof HTMLElement &&
        shouldHonorVisibleHandoff &&
        isSamePath(visibleHandoffPath || window.location.pathname, window.location.pathname)
      ) {
        return {
          cycleComplete: visibleHandoff.dataset.handoffReleased === 'true',
          pathname: visibleHandoffPath || window.location.pathname,
        };
      }

      if (visibleHandoff instanceof HTMLElement && !shouldHonorVisibleHandoff) {
        visibleHandoff.remove();
        document.documentElement.classList.remove('home-preloader-handoff-active');
        clearNavigationPreloaderClassIfIdle();
      }

      if (
        activeHandoff?.startedAt &&
        activeHandoff.pathname &&
        isSamePath(activeHandoff.pathname, window.location.pathname)
      ) {
        return {
          cycleComplete: Boolean(activeHandoff.cycleComplete),
          pathname: activeHandoff.pathname,
        };
      }

      if (
        !pendingNavigation?.suppressRoutePreloaderVideo ||
        !pendingNavigation.pathname ||
        !isSamePath(pendingNavigation.pathname, window.location.pathname)
      ) {
        return null;
      }

      return {
        cycleComplete: Boolean(pendingNavigation.handoffCycleComplete),
        pathname: pendingNavigation.pathname,
      };
    };

    const initArchitectViewer = () => {
      const viewer = document.querySelector('[data-architect-viewer]');

      if (!(viewer instanceof HTMLElement)) {
        return;
      }

      const shouldReplayWithoutPreloader = consumeArchitectReturnReplay();

      if (viewer.dataset.viewerBooted === 'true') {
        if (!shouldReplayWithoutPreloader) return;

        disposeCurrentViewer();
      }

      const stage = document.querySelector('[data-architect-stage]');
      const controlsElement = stage instanceof HTMLElement ? stage : viewer;
      const shell = viewer.closest('.site-shell');
      let stableViewportWidth = 0;
      let stableViewportOrientation = '';
      const getViewportOrientation = () =>
        window.innerWidth > window.innerHeight ? 'landscape' : 'portrait';
      const isSmallLandscapeViewport = () =>
        window.matchMedia('(orientation: landscape) and (max-width: 1180px)').matches;
      const syncArchitectViewportHeight = ({ force = false } = {}) => {
        if (!(shell instanceof HTMLElement)) return;

        const nextWidth = window.innerWidth || document.documentElement.clientWidth || 0;
        const nextOrientation = getViewportOrientation();

        if (
          !force &&
          isSmallLandscapeViewport() &&
          nextWidth === stableViewportWidth &&
          nextOrientation === stableViewportOrientation
        ) {
          return;
        }

        stableViewportWidth = nextWidth;
        stableViewportOrientation = nextOrientation;
        shell.style.setProperty(
          '--architect-viewport-height',
          `${window.innerHeight || document.documentElement.clientHeight || 1}px`,
        );
      };

      syncArchitectViewportHeight({ force: true });
      const forceSyncArchitectViewportHeight = () => syncArchitectViewportHeight({ force: true });
      window.addEventListener('resize', syncArchitectViewportHeight);
      window.addEventListener('orientationchange', forceSyncArchitectViewportHeight);
      window.visualViewport?.addEventListener('resize', syncArchitectViewportHeight);

      if (shouldReplayWithoutPreloader) {
        document.documentElement.classList.add(architectReturnBlankClass);
        viewer.style.setProperty('--architect-return-rock-fade-ms', `${ARCHITECT_ROCK_FADE_MS}ms`);
        viewer.classList.add('is-return-reveal');
        document.querySelectorAll('[data-home-preloader-handoff]').forEach((overlay) => overlay.remove());
        document.documentElement.classList.remove(
          'home-preloader-active',
          'home-preloader-booting',
          'home-preloader-handoff-active',
        );
        document.documentElement.classList.remove(navigationPreloaderClass);
        window.__varelismUnlockNavigationPreloaderScroll?.();
        clearNavigationPreloaderClassIfIdle();

        if (window.scrollX || window.scrollY) {
          window.scrollTo({ left: 0, top: 0, behavior: 'auto' });
        }
      }

      disposeCurrentViewer();
      viewer.dataset.viewerBooted = 'true';

      let didStart = false;
      let hasDisposed = false;
      let cleanup = () => {};
      let observer = null;
      let startFrameId = 0;
      let returnBlankTimer = 0;
      let isModelReady = false;
      let isPreloaderHiding = false;
      let cleanupSpatialLinks = () => {};
      let cleanupSharedPreloaderComplete = () => {};
      let enableRockControls = () => {};
      let startIntroOrbitRamp = () => {};
      let cancelIntroOrbitRamp = () => {};
      let isRockInteractionLocked = !shouldReplayWithoutPreloader;
      let isPointCoveredByModel = () => true;
      let isRockHitTestReady = false;
      let hasStartedRevealSequence = false;
      const preloaderTimers = new Set();
      const hasActivePreloaderSurface = () =>
        Boolean(document.querySelector('[data-home-preloader].is-visible, [data-home-preloader-handoff]'));
      const isRouteEntering = () => document.documentElement.classList.contains(routeEnteringClass);
      const spatialLinks = Array.from(controlsElement.querySelectorAll('[data-architect-spatial-link]')).filter(
        (link) => link instanceof HTMLAnchorElement,
      );
      const getSpatialLinks = () => spatialLinks;

      const setPreloaderTimer = (callback, delay) => {
        const timer = window.setTimeout(() => {
          preloaderTimers.delete(timer);
          if (!hasDisposed) callback();
        }, delay);
        preloaderTimers.add(timer);
        return timer;
      };

      const lockRockControlsBehindPreloader = () => {
        isRockInteractionLocked = true;
        document.documentElement.classList.add(rockControlsLockedClass);
      };

      const unlockRockControlsAfterPreloader = () => {
        isRockInteractionLocked = false;
        document.documentElement.classList.remove(rockControlsLockedClass);
        enableRockControls();
      };

      if (isRockInteractionLocked) {
        lockRockControlsBehindPreloader();
      }

      const unlockPageBehindPreloader = () => {
      };

      viewer.style.setProperty('--architect-rock-fade-ms', `${ARCHITECT_ROCK_FADE_MS}ms`);
      if (stage instanceof HTMLElement) {
        stage.style.setProperty('--architect-link-fade-ms', `${ARCHITECT_LINK_FADE_MS}ms`);
        stage.classList.add('is-reveal-sequence');
      }

      const startArchitectRevealSequence = ({ returnReveal = false } = {}) => {
        if (hasDisposed || hasStartedRevealSequence) return;
        hasStartedRevealSequence = true;

        viewer.classList.add(returnReveal ? 'is-return-reveal-visible' : 'is-rock-visible');

        if (!(stage instanceof HTMLElement)) return;

        setPreloaderTimer(() => {
          stage.classList.add('is-projects-visible');
          startIntroOrbitRamp();
        }, ARCHITECT_PROJECTS_REVEAL_DELAY_MS);

        setPreloaderTimer(() => {
          stage.classList.add('is-portfolios-visible');
        }, ARCHITECT_PORTFOLIOS_REVEAL_DELAY_MS);
      };

      const clearPendingArchitectPreloader = () => {
        const pendingNavigation = window.__varelismPendingPreloaderNavigation;

        if (pendingNavigation?.pathname && isSamePath(pendingNavigation.pathname, window.location.pathname)) {
          window.__varelismPendingPreloaderNavigation = null;
        }
      };

      const signalArchitectSceneReady = () => {
        if (window[ARCHITECT_SCENE_READY_FLAG]) return;

        window.__varelismArchitectSceneReady = true;
        window[ARCHITECT_SCENE_READY_FLAG] = true;
        window.dispatchEvent(new CustomEvent(ARCHITECT_SCENE_READY_EVENT));
      };

      const removePreloader = () => {
        clearPendingArchitectPreloader();
        if (isModelReady) {
          if (isRouteEntering()) {
            setPreloaderTimer(removePreloader, 30);
          } else {
            startArchitectRevealSequence();
          }
        }
        unlockRockControlsAfterPreloader();
        clearNavigationPreloaderClassIfIdle();
      };

      const hidePreloaderWhenReady = () => {
        if (
          hasDisposed ||
          isPreloaderHiding ||
          !isModelReady
        ) {
          return;
        }

        isPreloaderHiding = true;
        signalArchitectSceneReady();
        if (!hasActivePreloaderSurface()) {
          removePreloader();
        }
      };

      if (!shouldReplayWithoutPreloader) {
        const onSharedPreloaderComplete = () => {
          if (!isSamePath(window.location.pathname, '/architect/')) return;

          cleanupSharedPreloaderComplete();
          removePreloader();
        };

        window.addEventListener('varelism:preloader-complete', onSharedPreloaderComplete);
        cleanupSharedPreloaderComplete = () => {
          window.removeEventListener('varelism:preloader-complete', onSharedPreloaderComplete);
          cleanupSharedPreloaderComplete = () => {};
        };
      }

      const installSpatialLinkGuards = () => {
        const spatialLinks = getSpatialLinks();
        const dragThreshold = 10;
        let activePointer = null;
        let hoveredLink = null;
        let suppressedClickLink = null;

        const getEventPoint = (event) => {
          if (typeof event.clientX === 'number' && typeof event.clientY === 'number') {
            return { x: event.clientX, y: event.clientY };
          }

          const touch = event.changedTouches?.[0] || event.touches?.[0];
          if (!touch) return null;
          return { x: touch.clientX, y: touch.clientY };
        };

        const isVisibleLinkHit = (event) => {
          const point = getEventPoint(event);
          return Boolean(point && !isPointCoveredByModel(point.x, point.y));
        };

        const setHoveredLink = (link) => {
          if (hoveredLink === link) return;
          hoveredLink?.classList.remove('is-visible-hit');
          hoveredLink = link;
          hoveredLink?.classList.add('is-visible-hit');
        };

        const onPointerDown = (event) => {
          if (!isVisibleLinkHit(event)) {
            suppressedClickLink = event.currentTarget;
            setHoveredLink(null);
            return;
          }

          event.stopPropagation();
          suppressedClickLink = null;
          setHoveredLink(event.currentTarget);
          activePointer = {
            id: event.pointerId,
            link: event.currentTarget,
            startX: event.clientX,
            startY: event.clientY,
            hasDragged: false,
            startedVisible: true,
          };
          event.currentTarget.setPointerCapture?.(event.pointerId);
        };

        const onPointerMove = (event) => {
          const isVisible = isVisibleLinkHit(event);

          if (isVisible) {
            setHoveredLink(event.currentTarget);
          } else if (hoveredLink === event.currentTarget) {
            setHoveredLink(null);
          }

          if (!activePointer || activePointer.id !== event.pointerId) return;
          if (activePointer.link !== event.currentTarget) return;

          if (!activePointer.startedVisible) {
            return;
          }

          event.stopPropagation();

          const deltaX = event.clientX - activePointer.startX;
          const deltaY = event.clientY - activePointer.startY;
          if (Math.hypot(deltaX, deltaY) > dragThreshold) {
            activePointer.hasDragged = true;
          }
        };

        const onPointerUp = (event) => {
          if (!activePointer || activePointer.id !== event.pointerId) return;
          if (activePointer.startedVisible) {
            event.stopPropagation();
          }

          if (activePointer.hasDragged) {
            const linkToSuppress = activePointer.link;
            suppressedClickLink = linkToSuppress;
            window.setTimeout(() => {
              if (suppressedClickLink === linkToSuppress) suppressedClickLink = null;
            }, 0);
          }

          activePointer = null;
        };

        const onPointerCancel = (event) => {
          if (activePointer?.startedVisible) {
            event.stopPropagation();
          }

          activePointer = null;
          suppressedClickLink = null;
          setHoveredLink(null);
        };

        const onPointerEnter = (event) => {
          if (isVisibleLinkHit(event)) {
            setHoveredLink(event.currentTarget);
          }
        };

        const onPointerLeave = (event) => {
          if (hoveredLink === event.currentTarget) {
            setHoveredLink(null);
          }
        };

        const onClick = (event) => {
          const isSuppressed = suppressedClickLink === event.currentTarget || !isVisibleLinkHit(event);
          if (!isSuppressed) {
            markArchitectReturnReplay();
            return;
          }

          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          suppressedClickLink = null;
          setHoveredLink(null);
        };

        const stopTouchPropagation = (event) => {
          if (isVisibleLinkHit(event)) {
            event.stopPropagation();
          }
        };

        spatialLinks.forEach((link) => {
          link.addEventListener('pointerenter', onPointerEnter);
          link.addEventListener('pointerleave', onPointerLeave);
          link.addEventListener('pointerdown', onPointerDown);
          link.addEventListener('pointermove', onPointerMove);
          link.addEventListener('pointerup', onPointerUp);
          link.addEventListener('pointercancel', onPointerCancel);
          link.addEventListener('click', onClick);
          link.addEventListener('touchstart', stopTouchPropagation);
          link.addEventListener('touchmove', stopTouchPropagation);
          link.addEventListener('touchend', stopTouchPropagation);
          link.addEventListener('touchcancel', stopTouchPropagation);
        });

        cleanupSpatialLinks = () => {
          setHoveredLink(null);
          spatialLinks.forEach((link) => {
            link.removeEventListener('pointerenter', onPointerEnter);
            link.removeEventListener('pointerleave', onPointerLeave);
            link.removeEventListener('pointerdown', onPointerDown);
            link.removeEventListener('pointermove', onPointerMove);
            link.removeEventListener('pointerup', onPointerUp);
            link.removeEventListener('pointercancel', onPointerCancel);
            link.removeEventListener('click', onClick);
            link.removeEventListener('touchstart', stopTouchPropagation);
            link.removeEventListener('touchmove', stopTouchPropagation);
            link.removeEventListener('touchend', stopTouchPropagation);
            link.removeEventListener('touchcancel', stopTouchPropagation);
          });
        };
      };

      installSpatialLinkGuards();

      const startViewer = async () => {
        if (didStart || hasDisposed) return;
        didStart = true;
        const modelUrl = viewer.dataset.modelUrl || '/models/Processed_Rock_Model_optimized.glb';
        const modelPath = modelUrl.slice(0, modelUrl.lastIndexOf('/') + 1);
        const modelFetchController = new AbortController();
        const modelBufferPromise = fetch(modelUrl, {
          signal: modelFetchController.signal,
        }).then((response) => {
          if (!response.ok) {
            throw new Error(`Architect model failed to load: ${response.status}`);
          }

          return response.arrayBuffer();
        });
        modelBufferPromise.catch(() => {
          // The promise is awaited below; this prevents an abort during page swap from surfacing as unhandled.
        });

        const [THREE, { GLTFLoader }, { TrackballControls }, { MeshoptDecoder }] = await Promise.all([
          import('three'),
          import('three/examples/jsm/loaders/GLTFLoader.js'),
          import('three/examples/jsm/controls/TrackballControls.js'),
          import('three/examples/jsm/libs/meshopt_decoder.module.js'),
        ]);
        if (hasDisposed) return;
        THREE.Cache.enabled = true;

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(37, 1, 0.01, 100);
        const renderer = new THREE.WebGLRenderer({
          alpha: true,
          antialias: true,
          powerPreference: 'high-performance',
        });
        const INITIAL_MODEL_ROTATION_DEGREES = { x: 0, y: 54, z: 0 };
        const INITIAL_CAMERA_DIRECTION = new THREE.Vector3(0.43, 0.41, -0.8).normalize();
        let resizeObserver = null;
        let frameId = 0;
        let resizeFrameId = 0;
        let isRenderLoopRunning = false;
        let requestRender = () => {};
        let onVisibilityChange = null;
        let controls = null;
        let introOrbitFrameId = 0;
        const preventTouchMove = (event) => {
          if (isRockInteractionLocked) return;
          if (orbitGesture.activePointerId === null) return;
          if (event.cancelable) event.preventDefault();
        };
        const hitTestRenderTarget = new THREE.WebGLRenderTarget(1, 1, {
          depthBuffer: true,
          stencilBuffer: false,
        });
        const hitTestMaterial = new THREE.MeshBasicMaterial({
          color: 0xffffff,
          side: THREE.DoubleSide,
        });
        const hitTestPixel = new Uint8Array(4);
        const hitTestAlphaThreshold = 96;
        const hitTestMaxDimension = 960;
        const hitTestSampleOffsets = [
          [0, 0],
          [1, 0],
          [-1, 0],
          [0, 1],
          [0, -1],
          [0.7, 0.7],
          [-0.7, 0.7],
          [0.7, -0.7],
          [-0.7, -0.7],
        ];
        const hitTestRect = { left: 0, top: 0, width: 0, height: 0 };
        let hitTestScaleX = 1;
        let hitTestScaleY = 1;
        let hitTestBufferWidth = 0;
        let hitTestBufferHeight = 0;
        let renderVersion = 0;
        let hitTestRenderVersion = -1;
        let lastHitTestKey = '';
        let lastHitTestResult = false;

        const updateHitTestMetrics = () => {
          const rect = renderer.domElement.getBoundingClientRect();
          hitTestRect.left = rect.left;
          hitTestRect.top = rect.top;
          hitTestRect.width = rect.width;
          hitTestRect.height = rect.height;
          const rendererContext = renderer.getContext();
          const drawingBufferWidth = rendererContext.drawingBufferWidth;
          const drawingBufferHeight = rendererContext.drawingBufferHeight;
          const hitTestScale = Math.min(
            1,
            hitTestMaxDimension / Math.max(drawingBufferWidth || 1, drawingBufferHeight || 1),
          );
          const nextHitTestBufferWidth = Math.max(1, Math.round(drawingBufferWidth * hitTestScale));
          const nextHitTestBufferHeight = Math.max(1, Math.round(drawingBufferHeight * hitTestScale));

          if (
            nextHitTestBufferWidth !== hitTestBufferWidth ||
            nextHitTestBufferHeight !== hitTestBufferHeight
          ) {
            hitTestBufferWidth = nextHitTestBufferWidth;
            hitTestBufferHeight = nextHitTestBufferHeight;
            hitTestRenderTarget.setSize(hitTestBufferWidth, hitTestBufferHeight);
            hitTestRenderVersion = -1;
            lastHitTestKey = '';
          }

          hitTestScaleX = hitTestRect.width > 0 ? hitTestBufferWidth / hitTestRect.width : 1;
          hitTestScaleY = hitTestRect.height > 0 ? hitTestBufferHeight / hitTestRect.height : 1;
        };

        const renderHitTestScene = () => {
          if (!hitTestBufferWidth || !hitTestBufferHeight) return;

          const previousRenderTarget = renderer.getRenderTarget();
          const previousOverrideMaterial = scene.overrideMaterial;

          try {
            scene.overrideMaterial = hitTestMaterial;
            renderer.setRenderTarget(hitTestRenderTarget);
            renderer.clear(true, true, true);
            renderer.render(scene, camera);
          } finally {
            scene.overrideMaterial = previousOverrideMaterial;
            renderer.setRenderTarget(previousRenderTarget);
          }

          hitTestRenderVersion = renderVersion;
        };

        const isRenderedPixelCovered = (clientX, clientY) => {
          updateHitTestMetrics();

          if (
            hitTestRect.width <= 0 ||
            hitTestRect.height <= 0 ||
            hitTestBufferWidth <= 0 ||
            hitTestBufferHeight <= 0 ||
            clientX < hitTestRect.left ||
            clientX > hitTestRect.left + hitTestRect.width ||
            clientY < hitTestRect.top ||
            clientY > hitTestRect.top + hitTestRect.height
          ) {
            return false;
          }

          const bufferX = Math.floor((clientX - hitTestRect.left) * hitTestScaleX);
          const bufferYFromTop = Math.floor((clientY - hitTestRect.top) * hitTestScaleY);
          const bufferY = hitTestBufferHeight - 1 - bufferYFromTop;

          if (bufferX < 0 || bufferX >= hitTestBufferWidth || bufferY < 0 || bufferY >= hitTestBufferHeight) {
            return false;
          }

          const hitTestKey = `${renderVersion}:${bufferX}:${bufferY}`;
          if (hitTestKey === lastHitTestKey) return lastHitTestResult;

          if (hitTestRenderVersion !== renderVersion) {
            renderHitTestScene();
          }

          const toleranceX = Math.max(1, Math.round(hitTestScaleX * 3));
          const toleranceY = Math.max(1, Math.round(hitTestScaleY * 3));
          let isCovered = false;

          try {
            for (const [offsetX, offsetY] of hitTestSampleOffsets) {
              const sampleX = bufferX + Math.round(offsetX * toleranceX);
              const sampleY = bufferY - Math.round(offsetY * toleranceY);

              if (
                sampleX < 0 ||
                sampleX >= hitTestBufferWidth ||
                sampleY < 0 ||
                sampleY >= hitTestBufferHeight
              ) {
                continue;
              }

              hitTestPixel.fill(0);
              renderer.readRenderTargetPixels(hitTestRenderTarget, sampleX, sampleY, 1, 1, hitTestPixel);

              if (hitTestPixel[3] >= hitTestAlphaThreshold) {
                isCovered = true;
                break;
              }
            }
          } catch {
            return false;
          }

          lastHitTestKey = hitTestKey;
          lastHitTestResult = isCovered;
          return lastHitTestResult;
        };

        const disposeObject = (object) => {
          object.traverse((child) => {
            if (!child.isMesh) return;
            child.geometry?.dispose();
            const materials = Array.isArray(child.material) ? child.material : [child.material];
            materials.forEach((material) => material?.dispose());
          });
        };

        const disposeScene = () => {
          disposeObject(scene);
        };

        cleanup = () => {
          window.cancelAnimationFrame(frameId);
          window.cancelAnimationFrame(resizeFrameId);
          window.cancelAnimationFrame(introOrbitFrameId);
          introOrbitFrameId = 0;
          isRenderLoopRunning = false;
          modelFetchController.abort();
          resizeObserver?.disconnect();
          if (onVisibilityChange) {
            document.removeEventListener('visibilitychange', onVisibilityChange);
          }
          controlsElement.removeEventListener('touchmove', preventTouchMove);
          controlsElement.removeEventListener('pointerdown', onOrbitPointerDown, { capture: true });
          window.removeEventListener('pointermove', onOrbitPointerMove);
          window.removeEventListener('pointerup', onOrbitPointerEnd);
