---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const modelUrl = `${basePath}/models/Processed_Rock_Model_optimized.glb`;
const preloaderVideoUrl = `${basePath}/videos/Logo_Animation_Preloader.mp4`;
---

<BaseLayout title="Architect | Varelism" description="Interactive architectural object.">
  <div class="architect-preloader" data-architect-preloader aria-hidden="true">
    <video
      class="architect-preloader__video"
      src={preloaderVideoUrl}
      autoplay
      muted
      playsinline
      loop
      preload="auto"
    ></video>
  </div>
  <section class="architect-stage" data-architect-stage aria-label="Architect">
    <nav class="architect-spatial-nav" aria-label="Architect sections">
      <a
        class="architect-spatial-link architect-spatial-link--projects"
        href="/projects/"
        data-architect-spatial-link
      >
        Projects
      </a>
      <a
        class="architect-spatial-link architect-spatial-link--product-designs"
        href="/productdesigns/"
        data-architect-spatial-link
      >
        Product Designs
      </a>
      <a
        class="architect-spatial-link architect-spatial-link--portfolios"
        href="/portfolios/"
        data-architect-spatial-link
      >
        Portfolios
      </a>
    </nav>
    <div class="architect-viewer" data-architect-viewer data-model-url={modelUrl}></div>
  </section>
</BaseLayout>

<script>
  (() => {
    const stateKey = '__varelismArchitectViewer';
    const state = (window[stateKey] ||= {
      dispose: null,
      listenersAttached: false,
    });

    const disposeCurrentViewer = () => {
      if (typeof state.dispose === 'function') {
        state.dispose();
        state.dispose = null;
      }
    };

    const initArchitectViewer = () => {
      const viewer = document.querySelector('[data-architect-viewer]');
      const preloader = document.querySelector('[data-architect-preloader]');

      if (!(viewer instanceof HTMLElement)) {
        document.documentElement.classList.remove('architect-preloader-active');
        return;
      }

      if (viewer.dataset.viewerBooted === 'true') return;

      const stage = viewer.closest('[data-architect-stage]');
      const controlsElement = stage instanceof HTMLElement ? stage : viewer;

      disposeCurrentViewer();
      viewer.dataset.viewerBooted = 'true';
      document.documentElement.classList.add('architect-preloader-active');
      const preloaderVideo = preloader?.querySelector('video');

      if (preloaderVideo instanceof HTMLVideoElement) {
        preloaderVideo.muted = true;
        preloaderVideo.play().catch(() => {
          // Muted autoplay can still be delayed by the browser; the white overlay remains the fallback holding state.
        });
      }

      let didStart = false;
      let hasDisposed = false;
      let cleanup = () => {};
      let observer = null;
      let hasMetMinimumDuration = false;
      let isModelReady = false;
      let isPreloaderHiding = false;
      let cleanupSpatialLinks = () => {};
      let isPointCoveredByModel = () => true;
      const preloaderTimers = new Set();

      const videoVisibleMs = 1000;
      const videoFadeMs = 300;
      const whiteHoldMs = 300;
      const overlayFadeMs = 300;

      const setPreloaderTimer = (callback, delay) => {
        const timer = window.setTimeout(() => {
          preloaderTimers.delete(timer);
          if (!hasDisposed) callback();
        }, delay);
        preloaderTimers.add(timer);
        return timer;
      };

      const unlockPageBehindPreloader = () => {
        document.documentElement.classList.remove('architect-preloader-active');
      };

      const removePreloader = () => {
        preloader?.remove();
      };

      const hidePreloaderWhenReady = () => {
        if (hasDisposed || isPreloaderHiding || !isModelReady || !hasMetMinimumDuration) return;

        isPreloaderHiding = true;
        preloader?.classList.add('is-video-fading');

        setPreloaderTimer(() => {
          unlockPageBehindPreloader();
          setPreloaderTimer(() => {
            preloader?.classList.add('is-overlay-fading');
            setPreloaderTimer(removePreloader, overlayFadeMs);
          }, whiteHoldMs);
        }, videoFadeMs);
      };

      setPreloaderTimer(() => {
        hasMetMinimumDuration = true;
        hidePreloaderWhenReady();
      }, videoVisibleMs);

      const installSpatialLinkGuards = () => {
        const spatialLinks = Array.from(
          controlsElement.querySelectorAll('[data-architect-spatial-link]'),
        ).filter((link) => link instanceof HTMLAnchorElement);
        const dragThreshold = 10;
        let activePointer = null;
        let hoveredLink = null;
        let suppressedClickLink = null;

        const getEventPoint = (event) => {
          if (typeof event.clientX === 'number' && typeof event.clientY === 'number') {
            return { x: event.clientX, y: event.clientY };
          }

          const touch = event.changedTouches?.[0] || event.touches?.[0];
          if (!touch) return null;
          return { x: touch.clientX, y: touch.clientY };
        };

        const isVisibleLinkHit = (event) => {
          const point = getEventPoint(event);
          return Boolean(point && !isPointCoveredByModel(point.x, point.y));
        };

        const setHoveredLink = (link) => {
          if (hoveredLink === link) return;
          hoveredLink?.classList.remove('is-visible-hit');
          hoveredLink = link;
          hoveredLink?.classList.add('is-visible-hit');
        };

        const onPointerDown = (event) => {
          if (!isVisibleLinkHit(event)) {
            suppressedClickLink = event.currentTarget;
            setHoveredLink(null);
            return;
          }

          event.stopPropagation();
          suppressedClickLink = null;
          setHoveredLink(event.currentTarget);
          activePointer = {
            id: event.pointerId,
            link: event.currentTarget,
            startX: event.clientX,
            startY: event.clientY,
            hasDragged: false,
            startedVisible: true,
          };
          event.currentTarget.setPointerCapture?.(event.pointerId);
        };

        const onPointerMove = (event) => {
          const isVisible = isVisibleLinkHit(event);

          if (isVisible) {
            setHoveredLink(event.currentTarget);
          } else if (hoveredLink === event.currentTarget) {
            setHoveredLink(null);
          }

          if (!activePointer || activePointer.id !== event.pointerId) return;
          if (activePointer.link !== event.currentTarget) return;

          if (!activePointer.startedVisible) {
            return;
          }

          event.stopPropagation();

          const deltaX = event.clientX - activePointer.startX;
          const deltaY = event.clientY - activePointer.startY;
          if (Math.hypot(deltaX, deltaY) > dragThreshold) {
            activePointer.hasDragged = true;
          }
        };

        const onPointerUp = (event) => {
          if (!activePointer || activePointer.id !== event.pointerId) return;
          if (activePointer.startedVisible) {
            event.stopPropagation();
          }

          if (activePointer.hasDragged) {
            const linkToSuppress = activePointer.link;
            suppressedClickLink = linkToSuppress;
            window.setTimeout(() => {
              if (suppressedClickLink === linkToSuppress) suppressedClickLink = null;
            }, 0);
          }

          activePointer = null;
        };

        const onPointerCancel = (event) => {
          if (activePointer?.startedVisible) {
            event.stopPropagation();
          }

          activePointer = null;
          suppressedClickLink = null;
          setHoveredLink(null);
        };

        const onPointerEnter = (event) => {
          if (isVisibleLinkHit(event)) {
            setHoveredLink(event.currentTarget);
          }
        };

        const onPointerLeave = (event) => {
          if (hoveredLink === event.currentTarget) {
            setHoveredLink(null);
          }
        };

        const onClick = (event) => {
          const isSuppressed = suppressedClickLink === event.currentTarget || !isVisibleLinkHit(event);
          if (!isSuppressed) return;

          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          suppressedClickLink = null;
          setHoveredLink(null);
        };

        const stopTouchPropagation = (event) => {
          if (isVisibleLinkHit(event)) {
            event.stopPropagation();
          }
        };

        spatialLinks.forEach((link) => {
          link.addEventListener('pointerenter', onPointerEnter);
          link.addEventListener('pointerleave', onPointerLeave);
          link.addEventListener('pointerdown', onPointerDown);
          link.addEventListener('pointermove', onPointerMove);
          link.addEventListener('pointerup', onPointerUp);
          link.addEventListener('pointercancel', onPointerCancel);
          link.addEventListener('click', onClick);
          link.addEventListener('touchstart', stopTouchPropagation);
          link.addEventListener('touchmove', stopTouchPropagation);
          link.addEventListener('touchend', stopTouchPropagation);
          link.addEventListener('touchcancel', stopTouchPropagation);
        });

        cleanupSpatialLinks = () => {
          setHoveredLink(null);
          spatialLinks.forEach((link) => {
            link.removeEventListener('pointerenter', onPointerEnter);
            link.removeEventListener('pointerleave', onPointerLeave);
            link.removeEventListener('pointerdown', onPointerDown);
            link.removeEventListener('pointermove', onPointerMove);
            link.removeEventListener('pointerup', onPointerUp);
            link.removeEventListener('pointercancel', onPointerCancel);
            link.removeEventListener('click', onClick);
            link.removeEventListener('touchstart', stopTouchPropagation);
            link.removeEventListener('touchmove', stopTouchPropagation);
            link.removeEventListener('touchend', stopTouchPropagation);
            link.removeEventListener('touchcancel', stopTouchPropagation);
          });
        };
      };

      installSpatialLinkGuards();

      const startViewer = async () => {
        if (didStart || hasDisposed) return;
        didStart = true;

        const [THREE, { GLTFLoader }, { TrackballControls }, { MeshoptDecoder }] = await Promise.all([
          import('three'),
          import('three/examples/jsm/loaders/GLTFLoader.js'),
          import('three/examples/jsm/controls/TrackballControls.js'),
          import('three/examples/jsm/libs/meshopt_decoder.module.js'),
        ]);
        if (hasDisposed) return;
        THREE.Cache.enabled = true;

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(37, 1, 0.01, 100);
        const renderer = new THREE.WebGLRenderer({
          alpha: true,
          antialias: true,
          powerPreference: 'high-performance',
        });
        const INITIAL_MODEL_ROTATION_DEGREES = { x: 0, y: 54, z: 0 };
        const INITIAL_CAMERA_DIRECTION = new THREE.Vector3(0.43, 0.41, -0.8).normalize();
        let resizeObserver = null;
        let frameId = 0;
        let controls = null;
        const preventTouchMove = (event) => event.preventDefault();
        const raycaster = new THREE.Raycaster();
        const rayPointer = new THREE.Vector2();

        const disposeObject = (object) => {
          object.traverse((child) => {
            if (!child.isMesh) return;
            child.geometry?.dispose();
            const materials = Array.isArray(child.material) ? child.material : [child.material];
            materials.forEach((material) => material?.dispose());
          });
        };

        const disposeScene = () => {
          disposeObject(scene);
        };

        cleanup = () => {
          window.cancelAnimationFrame(frameId);
          resizeObserver?.disconnect();
          controlsElement.removeEventListener('touchmove', preventTouchMove);
          controls?.dispose();
          disposeScene();
          renderer.dispose();
          renderer.domElement.remove();
        };

        renderer.outputColorSpace = THREE.SRGBColorSpace;
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFShadowMap;
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        renderer.toneMappingExposure = 1.04;
        renderer.setClearColor(0xffffff, 0);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
        viewer.appendChild(renderer.domElement);

        const hemisphere = new THREE.HemisphereLight(0xffffff, 0xe8e1d6, 1.45);
        const key = new THREE.DirectionalLight(0xffffff, 5.2);
        const fill = new THREE.DirectionalLight(0xf3efe8, 0.55);

        key.position.set(3.6, 5.2, 4.4);
        key.castShadow = true;
        key.shadow.mapSize.set(2048, 2048);
        key.shadow.bias = -0.00008;
        fill.position.set(-4.2, 1.8, -3.8);
        scene.add(hemisphere, key, fill);

        controls = new TrackballControls(camera, controlsElement);
        controls.noPan = true;
        controls.noZoom = true;
        controls.rotateSpeed = 0.55;
        controls.staticMoving = false;
        controls.dynamicDampingFactor = 0.055;
        controls.target.set(0, 0, 0);

        controlsElement.addEventListener('touchmove', preventTouchMove, { passive: false });

        const loader = new GLTFLoader();
        loader.setMeshoptDecoder(MeshoptDecoder);
        const gltf = await loader.loadAsync(viewer.dataset.modelUrl || '/models/Processed_Rock_Model_optimized.glb');
        if (hasDisposed) {
          disposeObject(gltf.scene);
          return;
        }
        const model = gltf.scene;
        const importedRig = [];

        model.traverse((child) => {
          if (child.isLight || child.isCamera) {
            importedRig.push(child);
            return;
          }

          if (!child.isMesh) return;

          child.castShadow = true;
          child.receiveShadow = true;

          if (child.geometry && !child.geometry.attributes.normal) {
            child.geometry.computeVertexNormals();
          }

          const materials = Array.isArray(child.material) ? child.material : [child.material];
          materials.forEach((material) => {
            if (!material) return;
            if ('roughness' in material) material.roughness = Math.max(material.roughness ?? 0.82, 0.78);
            if ('metalness' in material) material.metalness = Math.min(material.metalness ?? 0, 0.04);
            material.needsUpdate = true;
          });
        });

        importedRig.forEach((child) => child.parent?.remove(child));

        const sourceBox = new THREE.Box3().setFromObject(model);
        const sourceCenter = sourceBox.getCenter(new THREE.Vector3());
        const sourceSize = sourceBox.getSize(new THREE.Vector3());
        const maxDimension = Math.max(sourceSize.x, sourceSize.y, sourceSize.z) || 1;
        const normalizedScale = 2.85 / maxDimension;
        const sculpture = new THREE.Group();

        model.position.sub(sourceCenter);
        sculpture.rotation.set(
          THREE.MathUtils.degToRad(INITIAL_MODEL_ROTATION_DEGREES.x),
          THREE.MathUtils.degToRad(INITIAL_MODEL_ROTATION_DEGREES.y),
          THREE.MathUtils.degToRad(INITIAL_MODEL_ROTATION_DEGREES.z),
        );
        sculpture.scale.setScalar(normalizedScale);
        sculpture.add(model);
        scene.add(sculpture);

        isPointCoveredByModel = (clientX, clientY) => {
          const rect = renderer.domElement.getBoundingClientRect();
          if (
            rect.width <= 0 ||
            rect.height <= 0 ||
            clientX < rect.left ||
            clientX > rect.right ||
            clientY < rect.top ||
            clientY > rect.bottom
          ) {
            return false;
          }

          rayPointer.x = ((clientX - rect.left) / rect.width) * 2 - 1;
          rayPointer.y = -((clientY - rect.top) / rect.height) * 2 + 1;
          raycaster.setFromCamera(rayPointer, camera);
          return raycaster.intersectObject(sculpture, true).length > 0;
        };

        const displayBox = new THREE.Box3().setFromObject(sculpture);
        const displaySphere = displayBox.getBoundingSphere(new THREE.Sphere());
        const displayRadius = displaySphere.radius || 1.2;
        const target = displaySphere.center.clone();
        let hasAppliedInitialCameraBookmark = false;

        controls.target.copy(target);

        const fitCamera = () => {
          const width = Math.max(viewer.clientWidth, 1);
          const height = Math.max(viewer.clientHeight, 1);
          const aspect = width / height;
          const verticalFov = THREE.MathUtils.degToRad(camera.fov);
          const horizontalFov = 2 * Math.atan(Math.tan(verticalFov / 2) * aspect);
          const limitingFov = Math.min(verticalFov, horizontalFov);
          const cameraFill = aspect < 0.72 ? 0.62 : aspect < 1 ? 0.52 : 0.44;
          const distance = (displayRadius / Math.sin(limitingFov / 2)) * cameraFill;
          const direction = hasAppliedInitialCameraBookmark
            ? camera.position.clone().sub(target).normalize()
            : INITIAL_CAMERA_DIRECTION.clone();

          camera.aspect = aspect;
          camera.near = Math.max(displayRadius / 320, 0.01);
          camera.far = displayRadius * 90;
          camera.position.copy(target).add(direction.multiplyScalar(distance));
          camera.updateProjectionMatrix();
          hasAppliedInitialCameraBookmark = true;

          renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
          renderer.setSize(width, height, false);
          controls.handleResize();
          controls.update();
        };

        fitCamera();

        resizeObserver = new ResizeObserver(fitCamera);
        resizeObserver.observe(viewer);

        const renderScene = () => {
          controls.update();
          renderer.render(scene, camera);
        };
        const render = () => {
          frameId = window.requestAnimationFrame(render);
          renderScene();
        };
        const renderStableFirstFrame = () =>
          new Promise((resolve) => {
            window.requestAnimationFrame(() => {
              if (!hasDisposed) renderScene();
              window.requestAnimationFrame(resolve);
            });
          });

        await renderStableFirstFrame();
        if (hasDisposed) return;
        render();
        await new Promise((resolve) => {
          window.requestAnimationFrame(resolve);
        });
        if (hasDisposed) return;
        viewer.classList.add('is-ready');
        isModelReady = true;
        hidePreloaderWhenReady();
      };

      observer =
        'IntersectionObserver' in window
          ? new IntersectionObserver(
              (entries) => {
                if (!entries.some((entry) => entry.isIntersecting)) return;
                observer?.disconnect();
                startViewer().catch((error) => {
                  console.error('Architect viewer failed to load.', error);
                });
              },
              { rootMargin: '280px' },
            )
          : null;

      if (observer) {
        observer.observe(viewer);
      } else {
        window.setTimeout(() => {
          startViewer().catch((error) => {
            console.error('Architect viewer failed to load.', error);
          });
        }, 1);
      }

      const dispose = () => {
        if (hasDisposed) return;
        hasDisposed = true;
        document.removeEventListener('astro:before-swap', dispose);
        window.removeEventListener('pagehide', dispose);
        observer?.disconnect();
        preloaderTimers.forEach((timer) => window.clearTimeout(timer));
        preloaderTimers.clear();
        delete viewer.dataset.viewerBooted;
        viewer.classList.remove('is-ready');
        cleanupSpatialLinks();
        unlockPageBehindPreloader();
        removePreloader();
        cleanup();
        if (state.dispose === dispose) state.dispose = null;
      };

      state.dispose = dispose;
      document.addEventListener('astro:before-swap', dispose);
      window.addEventListener('pagehide', dispose);
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:after-swap', initArchitectViewer);
      document.addEventListener('astro:page-load', initArchitectViewer);
      window.addEventListener('pageshow', initArchitectViewer);
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArchitectViewer, { once: true });
    } else {
      initArchitectViewer();
    }
  })();
</script>

<style>
  .architect-preloader {
    align-items: center;
    background: #ffffff;
    display: flex;
    inset: 0;
    justify-content: center;
    opacity: 1;
    pointer-events: auto;
    position: fixed;
    transition: opacity 300ms ease, visibility 0ms linear 300ms;
    visibility: visible;
    z-index: 9999;
  }

  .architect-preloader.is-overlay-fading {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .architect-preloader__video {
    display: block;
    height: auto;
    max-height: min(34vh, 18rem);
    max-width: min(48vw, 22rem);
    object-fit: contain;
    opacity: 1;
    transition: opacity 300ms ease;
    width: min(48vw, 22rem);
  }

  .architect-preloader.is-video-fading .architect-preloader__video {
    opacity: 0;
  }

  :global(html.architect-preloader-active),
  :global(html.architect-preloader-active body) {
    overflow: hidden;
  }

  :global(body) {
    overflow-x: hidden;
  }

  :global(.site-shell) {
    --architect-footer-offset: 7.5rem;
    min-height: calc(100vh + var(--architect-footer-offset));
    min-height: calc(100svh + var(--architect-footer-offset));
    min-height: calc(100dvh + var(--architect-footer-offset));
  }

  :global(.site-shell > main) {
    display: grid !important;
    max-width: none !important;
    min-height: calc(100vh + var(--architect-footer-offset)) !important;
    min-height: calc(100svh + var(--architect-footer-offset)) !important;
    min-height: calc(100dvh + var(--architect-footer-offset)) !important;
    padding: 0 !important;
    place-items: center !important;
    width: 100% !important;
  }

  :global(.site-shell > .site-footer) {
    bottom: auto;
    left: 0;
    pointer-events: none;
    position: absolute;
    right: 0;
    top: 100vh;
    top: 100svh;
    top: 100dvh;
    width: 100%;
    z-index: 20;
  }

  .architect-stage {
    display: grid;
    cursor: grab;
    isolation: isolate;
    min-height: calc(100vh + var(--architect-footer-offset));
    min-height: calc(100svh + var(--architect-footer-offset));
    min-height: calc(100dvh + var(--architect-footer-offset));
    overflow: hidden;
    place-items: center;
    position: relative;
    touch-action: none;
    user-select: none;
    width: 100%;
  }

  .architect-stage:active {
    cursor: grabbing;
  }

  .architect-spatial-nav {
    height: 100vh;
    height: 100svh;
    height: 100dvh;
    inset: 0 0 auto;
    pointer-events: none;
    position: absolute;
    z-index: 1;
  }

  .architect-spatial-link {
    color: #691b17;
    cursor: default;
    display: block;
    font-family: 'SF Pro Display Ultralight', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
    pointer-events: auto;
    position: absolute;
    text-align: center;
    text-decoration: none;
    touch-action: none;
    transform: translate(-50%, -50%);
    transition: color 180ms ease;
    white-space: nowrap;
  }

  .architect-spatial-link.is-visible-hit {
    color: #000000;
    cursor: pointer;
  }

  .architect-spatial-link:focus-visible {
    color: #000000;
    outline: 1px solid #691b17;
    outline-offset: 0.45rem;
  }

  .architect-spatial-link--projects {
    left: 25%;
    top: 40%;
  }

  .architect-spatial-link--product-designs {
    left: 56.5%;
    top: 74%;
  }

  .architect-spatial-link--portfolios {
    left: 78.5%;
    top: 60%;
  }

  .architect-viewer {
    height: calc(100vh + var(--architect-footer-offset) + var(--architect-footer-offset));
    height: calc(100svh + var(--architect-footer-offset) + var(--architect-footer-offset));
    height: calc(100dvh + var(--architect-footer-offset) + var(--architect-footer-offset));
    left: 0;
    min-height: 0;
    overflow: hidden;
    pointer-events: none;
    position: absolute;
    right: 0;
    touch-action: none;
    top: calc(0px - var(--architect-footer-offset));
    user-select: none;
    width: 100%;
    z-index: 2;
  }

  .architect-viewer :global(canvas) {
    background: transparent;
    display: block;
    height: 100%;
    inset: 0;
    position: absolute;
    pointer-events: none;
    touch-action: none;
    opacity: 0;
    transition: none;
    visibility: hidden;
    width: 100%;
  }

  .architect-viewer.is-ready :global(canvas) {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 560px) {
    .architect-stage {
      min-height: calc(100vh + var(--architect-footer-offset));
      min-height: calc(100svh + var(--architect-footer-offset));
      min-height: calc(100dvh + var(--architect-footer-offset));
    }

    .architect-spatial-link {
      font-size: clamp(0.95rem, 3.8vw, 1.25rem);
    }

    .architect-spatial-link--projects {
      left: 22%;
      top: 48%;
    }

    .architect-spatial-link--product-designs {
      left: 52%;
      top: 57%;
    }

