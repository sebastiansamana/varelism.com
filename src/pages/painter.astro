---
import BaseLayout from '../layouts/BaseLayout.astro';

const paintings = [
  {
    title: 'Night Wall',
    medium: 'Oil on linen',
    year: '2025',
    image: 'https://images.unsplash.com/photo-1577083552431-6e5fd01988f1?auto=format&fit=crop&w=1600&q=80',
  },
  {
    title: 'Ground Plane, Rain',
    medium: 'Oil on board',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1579965342575-16428a7c8881?auto=format&fit=crop&w=1600&q=80',
  },
  {
    title: 'Soft Facade Study',
    medium: 'Acrylic on paper',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1545239351-1141bd82e8a6?auto=format&fit=crop&w=1600&q=80',
  },
];
---

<BaseLayout title="Painter | Sebastian Samana" description="Painting practice.">
  <section class="section fade-up">
    <p class="eyebrow">Painter</p>
    <h1 class="page-title">Paintings as parallel research.</h1>
    <p class="page-intro">The painting practice studies light, edge, and atmosphere outside project timelines.</p>
  </section>

  <section class="section painting-grid">
    {paintings.map((work, index) => (
      <article class="work fade-up stagger" style={`--delay:${index * 0.08}s`}>
        <div class="image-frame">
          <img src={work.image} alt={work.title} loading="lazy" />
        </div>
        <div class="work-meta">
          <h2>{work.title}</h2>
          <p>{work.medium} · {work.year}</p>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .painting-grid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .work {
    display: grid;
    gap: 0.5rem;
  }

  .work img {
    aspect-ratio: 4 / 5;
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin: 0;
  }

  .work-meta p {
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    margin: 0.2rem 0 0;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .painting-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .painting-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
