---
import { getCollection } from 'astro:content';
import ArtworkArchive from '../../components/ArtworkArchive.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublicArtworks } from '../../lib/artworks';

const artworks = getPublicArtworks(await getCollection('artworks'));
---

<BaseLayout title="Sebastian Varela: List of works | Varelism" description="Sebastian Varela: List of works.">
  <ArtworkArchive artworks={artworks} />
</BaseLayout>
