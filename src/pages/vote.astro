---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Vote" description="Campaign and manifesto page.">
  <section class="vote-page">
    <section class="pillars">
      <h1>Better Portfolios</h1>
      <h1>Stronger Networks</h1>
      <h1>More Internships</h1>
    </section>

    <section class="candidates">
      <article class="candidate">
        <div class="portrait" aria-hidden="true"></div>
        <h2>MSSA Chair</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vel sapien sed
          massa placerat luctus. Praesent in mi sed risus feugiat sodales in sed erat.
        </p>
      </article>

      <article class="candidate">
        <div class="portrait" aria-hidden="true"></div>
        <h2>MSSA Secretary</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus vulputate,
          nunc ac mattis interdum, justo nibh ultrices arcu, et dignissim neque nisl ac erat.
        </p>
      </article>
    </section>

    <section class="shared-manifesto">
      <p class="shared-label">Shared Manifesto</p>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras aliquet, velit ut
        tristique luctus, urna lectus pharetra arcu, nec posuere turpis nunc vel nibh.
        Suspendisse potenti. Curabitur finibus, erat id vulputate faucibus, lorem eros
        bibendum est, a imperdiet tellus sapien sit amet neque.
      </p>
    </section>
  </section>
</BaseLayout>

<style>
  .vote-page {
    display: grid;
    gap: 6rem;
    margin: 0 auto;
    max-width: 64rem;
    padding: 5rem 0;
    width: 100%;
  }

  .pillars {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    text-align: center;
  }

  .pillars h1 {
    color: var(--ink);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.55rem, 2.7vw, 2.25rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
  }

  .candidates {
    display: grid;
    gap: 3rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .candidate {
    align-items: center;
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    text-align: center;
  }

  .portrait {
    aspect-ratio: 1;
    background: rgba(27, 55, 67, 0.08);
    border: 1px solid rgba(27, 55, 67, 0.14);
    border-radius: 50%;
    width: clamp(10rem, 18vw, 12.5rem);
  }

  .candidate h2 {
    color: var(--ink);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0;
  }

  .candidate p,
  .shared-manifesto p {
    color: rgba(27, 55, 67, 0.78);
    font-size: clamp(1rem, 1.3vw, 1.08rem);
    font-weight: 300;
    line-height: 1.7;
    margin: 0;
    max-width: 34rem;
  }

  .shared-manifesto {
    border-top: 1px solid rgba(27, 55, 67, 0.12);
    display: grid;
    gap: 1rem;
    justify-items: center;
    padding-top: 2rem;
    text-align: center;
  }

  .shared-label {
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0;
  }

  @media (max-width: 900px) {
    .vote-page {
      gap: 4.5rem;
      padding: 4rem 0;
    }

    .pillars {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .candidates {
      gap: 3.5rem;
      grid-template-columns: 1fr;
    }
  }
</style>
