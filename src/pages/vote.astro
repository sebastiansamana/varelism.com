</BaseLayout>

<style>
  .vote-page {
    --manifesto-copy-size: clamp(13.125rem, 23.625vw, 16.40625rem);
    --divider-space: 5.15625rem;
    display: grid;
    gap: var(--divider-space);
    margin: 0 auto;
    max-width: 64rem;
    padding: 5rem 0;
    width: 100%;
  }

  .pillars {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    text-align: center;
  }

  .pillars h1 {
    align-items: baseline;
    color: var(--ink);
    display: flex;
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    gap: 0.22em;
    justify-content: center;
    letter-spacing: -0.015em;
    line-height: 1.05;
    margin: 0;
  }

  .lead-word {
    color: rgba(27, 55, 67, 0.78);
    font-size: calc(20pt - 5pt);
    font-weight: 400;
  }

  .main-word {
    font-size: 20pt;
    font-weight: 400;
  }

  .candidates {
    border-top: 1px solid rgba(27, 55, 67, 0.12);
    display: grid;
    gap: 3rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding-top: var(--divider-space);
  }

  .candidate {
    --profile-size: clamp(10rem, 18vw, 12.5rem);
    align-items: center;
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    text-align: center;
  }

  .candidate-heading {
    display: grid;
    gap: 0;
    justify-items: center;
  }

  .portrait {
    aspect-ratio: 1;
    background: rgba(27, 55, 67, 0.08);
    border: 1px solid rgba(27, 55, 67, 0.14);
    border-radius: 50%;
    overflow: hidden;
    width: var(--profile-size);
  }

  .portrait-image {
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    width: 100%;
  }

  .portrait-image--secretary {
    object-position: 42% 20%;
    transform: scale(1.58);
    transform-origin: 42% 20%;
  }

  .candidate h2 {
    color: var(--ink);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0;
  }

  .candidate-name {
    color: rgba(27, 55, 67, 0.78);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 15pt;
    font-weight: 400;
    line-height: 1;
    margin: 0;
  }

  .candidate-copy,
  .shared-copy {
    color: rgba(27, 55, 67, 0.78);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 11.25pt;
    font-weight: 400;
    line-height: 1.55;
    margin: 0;
    text-align: center;
    width: 100%;
  }

  .candidate-copy {
    width: var(--manifesto-copy-size);
  }

  .candidate-copy p {
    margin: 0;
  }

  .manifesto-copy {
    display: grid;
    gap: 0.9rem;
    text-align: left;
  }

  .manifesto-copy ul {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding-left: 1.15rem;
    text-align: left;
  }

  .manifesto-copy li {
    margin: 0;
  }

  .shared-copy {
    width: var(--manifesto-copy-size);
  }

  .shared-manifesto {
    border-top: 1px solid rgba(27, 55, 67, 0.12);
    display: grid;
    gap: 0.25rem;
    justify-items: center;
    padding-top: var(--divider-space);
    text-align: center;
  }

  .shared-label {
    color: var(--ink);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  @media (max-width: 900px) {
    .vote-page {
      gap: 4.5rem;
      padding: 4rem 0;
    }

    .pillars {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .candidates {
      gap: 3.5rem;
      grid-template-columns: 1fr;
    }
  }
</style>
