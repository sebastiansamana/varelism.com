---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Sebastian Samana" description="About the practice.">
  <section class="section fade-up about-wrap">
    <p class="eyebrow">About</p>
    <h1 class="page-title">A personal practice across writing, architecture, and painting.</h1>
    <p class="page-intro">
      I work between disciplines to keep each one honest. Writing tests ideas, architecture gives them material form,
      and painting returns them to light, color, and atmosphere.
    </p>
  </section>

  <section class="section fade-up stagger" style="--delay:.08s">
    <p>
      Based in Manchester, my work moves between commissioned projects, self-initiated research, and studio studies.
      This website is structured as an index rather than a showcase: a working record of methods, questions, and outcomes.
    </p>
  </section>
</BaseLayout>

<style>
  .about-wrap {
    max-width: 78ch;
  }

  p {
    color: var(--muted);
    font-size: 1.08rem;
    margin: 0;
    max-width: 76ch;
  }
</style>
