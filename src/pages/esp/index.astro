---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sections = [
  { title: 'Autor', href: '/esp/autor/' },
  { title: 'Arquitecto', href: '/esp/arquitecto/' },
  { title: 'Artista', href: '/esp/artista/' },
];
---

<BaseLayout title="Varelism" description="Autor, arquitecto y artista.">
  <section class="triptych" aria-label="Secciones de Varelism">
    {sections.map((section) => (
      <div class="triptych-item">
        <a class="triptych-link" href={section.href}>
          <h1>{section.title}</h1>
        </a>
        <span class="column-stack" aria-hidden="true">
          <img
            class="column column-base"
            src="/images/Home_Page_Column.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <img
            class="column column-hover"
            src="/images/Home_Page_Column_Cursor.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </span>
      </div>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const setupColumnFootprintHitboxes = () => {
      document.querySelectorAll('.triptych-item').forEach((item) => {
        const link = item.querySelector('.triptych-link');
        const stack = item.querySelector('.column-stack');
        const image = item.querySelector('.column-base');

        if (
          !(item instanceof HTMLElement) ||
          !(link instanceof HTMLAnchorElement) ||
          !(stack instanceof HTMLElement) ||
          !(image instanceof HTMLImageElement) ||
          stack.dataset.columnFootprintHitboxReady === 'true'
        ) {
          return;
        }

        stack.dataset.columnFootprintHitboxReady = 'true';

        const alphaThreshold = 16;
        const backgroundThreshold = 250;
        const clickMoveTolerance = 10;
        const coarsePointerQuery = '(hover: none), (pointer: coarse)';
        let context = null;
        let naturalWidth = 0;
        let naturalHeight = 0;
        let pendingColumnClick = null;
        let pointerStart = null;
        let clearGroupTimer = 0;

        const isCoarsePointer = () => Boolean(window.matchMedia?.(coarsePointerQuery)?.matches);

        const setGroupHitState = (isHit) => {
          window.clearTimeout(clearGroupTimer);
          clearGroupTimer = 0;
          item.classList.toggle('is-column-hit', isHit);
        };

        const setColumnHitState = (isHit) => {
          setGroupHitState(isHit);
          stack.style.cursor = isHit ? 'pointer' : '';
        };

        const clearColumnHitState = () => {
          setGroupHitState(false);
          stack.style.cursor = '';
        };

        const scheduleGroupClear = () => {
          window.clearTimeout(clearGroupTimer);
          clearGroupTimer = window.setTimeout(clearColumnHitState, 80);
        };

        const buildHitCanvas = () => {
          if (!image.naturalWidth || !image.naturalHeight || context) return;

          naturalWidth = image.naturalWidth;
          naturalHeight = image.naturalHeight;

          const canvas = document.createElement('canvas');
          canvas.width = naturalWidth;
          canvas.height = naturalHeight;

          const nextContext = canvas.getContext('2d', { willReadFrequently: true });
          if (!nextContext) return;

          nextContext.drawImage(image, 0, 0, naturalWidth, naturalHeight);
          context = nextContext;
          flushPendingColumnClick();
        };

        const isPointInsideImageRect = (point) => {
          const rect = image.getBoundingClientRect();

          return (
            rect.width > 0 &&
            rect.height > 0 &&
            point.clientX >= rect.left &&
            point.clientX <= rect.right &&
            point.clientY >= rect.top &&
            point.clientY <= rect.bottom
          );
        };

        const isColumnPixel = (event) => {
          if (!isCoarsePointer()) {
            buildHitCanvas();
          }

          if (!context || !naturalWidth || !naturalHeight) return false;

          const rect = image.getBoundingClientRect();

          if (
            rect.width <= 0 ||
            rect.height <= 0 ||
            event.clientX < rect.left ||
            event.clientX > rect.right ||
            event.clientY < rect.top ||
            event.clientY > rect.bottom
          ) {
            return false;
          }

          const x = Math.min(
            naturalWidth - 1,
            Math.max(0, Math.floor(((event.clientX - rect.left) / rect.width) * naturalWidth)),
          );
          const y = Math.min(
            naturalHeight - 1,
            Math.max(0, Math.floor(((event.clientY - rect.top) / rect.height) * naturalHeight)),
          );
          const [red, green, blue, alpha] = context.getImageData(x, y, 1, 1).data;

          return (
            alpha > alphaThreshold &&
            !(red > backgroundThreshold && green > backgroundThreshold && blue > backgroundThreshold)
          );
        };

        const getPointerDistance = (event) => {
          if (!pointerStart) return 0;

          return Math.hypot(event.clientX - pointerStart.x, event.clientY - pointerStart.y);
        };

        const flushPendingColumnClick = () => {
          if (!pendingColumnClick || !context) return;

          const pendingEvent = pendingColumnClick;
          pendingColumnClick = null;

          if (isColumnPixel(pendingEvent)) {
            link.click();
          }
        };

        const prepareFinePointerHitCanvas = () => {
          if (isCoarsePointer()) return;

          if (image.complete) {
            buildHitCanvas();
          } else {
            image.addEventListener('load', buildHitCanvas, { once: true });
          }

          image.decode?.().then(buildHitCanvas).catch(() => {
            // The load event fallback above covers browsers that reject decode during navigation.
          });
        };

        const isImmediateColumnTap = (event) =>
          !context && isCoarsePointer() && isPointInsideImageRect(event);

        prepareFinePointerHitCanvas();

        stack.addEventListener('pointermove', (event) => {
          setColumnHitState(isColumnPixel(event));
        });

        stack.addEventListener('pointerdown', (event) => {
          const isHit = isImmediateColumnTap(event) || isColumnPixel(event);

          pointerStart = isHit
            ? {
                id: event.pointerId,
                x: event.clientX,
                y: event.clientY,
              }
            : null;
          setColumnHitState(isHit);
        });

        stack.addEventListener('pointerup', (event) => {
          if (!pointerStart || pointerStart.id !== event.pointerId) return;

          setColumnHitState(isImmediateColumnTap(event) || isColumnPixel(event));
        });

        stack.addEventListener('pointercancel', () => {
          pointerStart = null;
          clearColumnHitState();
        });

        stack.addEventListener('pointerleave', () => {
          pointerStart = null;
          scheduleGroupClear();
        });

        stack.addEventListener('click', (event) => {
          const movedPastClick = getPointerDistance(event) > clickMoveTolerance;

          if (!movedPastClick && (isImmediateColumnTap(event) || isColumnPixel(event))) {
            event.preventDefault();
            event.stopPropagation();
            link.click();
          } else if (!movedPastClick && !context && isPointInsideImageRect(event)) {
            pendingColumnClick = {
              clientX: event.clientX,
              clientY: event.clientY,
            };
          }

          pointerStart = null;
        });

        const setLinkHitState = () => {
          setGroupHitState(true);
          stack.style.cursor = '';
        };

        link.addEventListener('pointerenter', setLinkHitState);
        link.addEventListener('pointermove', setLinkHitState);
        link.addEventListener('pointerdown', setLinkHitState);
        link.addEventListener('mouseenter', setLinkHitState);
        link.addEventListener('mousemove', setLinkHitState);

        link.addEventListener('pointerleave', scheduleGroupClear);
        link.addEventListener('focus', () => setGroupHitState(true));
        link.addEventListener('blur', scheduleGroupClear);
      });
    };

    setupColumnFootprintHitboxes();

    if (window.__varelismHomeColumnFootprintHitboxesReady) return;

    window.__varelismHomeColumnFootprintHitboxesReady = true;
    document.addEventListener('astro:page-load', setupColumnFootprintHitboxes);
  })();
</script>

<style>
  :global(.site-shell > main) {
    display: grid;
    max-width: none;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: 0;
    place-items: center;
  }

  .triptych {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 6vw, 7rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    justify-items: center;
    margin: 0 auto;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: clamp(1.5rem, 4vh, 3rem) clamp(1.25rem, 6vw, 6rem);
    width: min(100%, 1280px);
  }

  .triptych-item {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.8vh, 1.25rem);
    min-width: 0;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    -webkit-touch-callout: none;
    user-select: none;
    width: 100%;
  }

  .triptych-link {
    color: inherit;
    display: block;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  h1 {
    color: currentColor;
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
    text-align: center;
    transition: color 180ms ease;
  }

  .column-stack {
    display: grid;
    max-width: 100%;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    width: clamp(6.25rem, 17vw, 13.25rem);
  }

  .column {
    display: block;
    grid-area: 1 / 1;
    height: auto;
    max-width: 100%;
    pointer-events: none;
    width: 100%;
  }

  .column-hover {
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .triptych-item.is-column-hit h1 {
    color: #691b17;
  }

  .triptych-item.is-column-hit .column-hover {
    opacity: 1;
  }

  .triptych-item:focus-within h1 {
    color: #691b17;
  }

  .triptych-item:focus-within .column-hover {
    opacity: 1;
  }

  .triptych-link:focus-visible h1 {
    color: #691b17;
  }

  .triptych-link:focus-visible {
    outline: 1px solid #691b17;
    outline-offset: 0.75rem;
  }

  .triptych-link:hover h1 {
    color: #691b17;
  }

  .triptych-link:hover + .column-stack .column-hover {
    opacity: 1;
  }

  .triptych-link:active h1 {
    color: #691b17;
  }

  .triptych-link:active + .column-stack .column-hover {
    opacity: 1;
  }

  @media (max-width: 720px) {
    .triptych {
      gap: clamp(1rem, 4vw, 2rem);
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .triptych-item {
      gap: 0.8rem;
    }

    h1 {
      font-size: clamp(0.95rem, 3.8vw, 1.25rem);
    }

    .column-stack {
      width: clamp(4.25rem, 26vw, 7rem);
    }
  }

  @media (max-width: 430px) {
    .triptych {
      gap: 0.75rem;
    }
  }
</style>
