---
import { getCollection } from 'astro:content';
import ArtworkArchive from '../../../components/ArtworkArchive.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPublicArtworks } from '../../../lib/artworks';

const artworks = getPublicArtworks(await getCollection('artworks'));
---

<BaseLayout title="Sebastian Varela: Lista de obras | Varelism" description="Sebastian Varela: Lista de obras.">
  <ArtworkArchive
    artworks={artworks}
    detailBasePath="/esp/artista/todo/"
    labels={{
      empty: 'Todavía no hay obras públicas.',
      grid: 'Mosaico',
      list: 'Índice',
      title: 'Sebastian Varela: Lista de obras',
    }}
  />
</BaseLayout>
