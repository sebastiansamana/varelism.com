---
import BaseLayout from '../layouts/BaseLayout.astro';
import MSAWorldMap from '../components/MSAWorldMap.jsx';
---

<BaseLayout title="MSA World | Sebastian Samana" description="Interactive world map tracing country origins to Manchester, UK.">
  <section class="tracing-page">
    <header class="tracing-header" aria-label="MSA World">
      <a class="tracing-brand" href="/">Sebastian Samana</a>
      <div class="tracing-title">
        <p>Tracing the City</p>
        <h1>MSA World</h1>
      </div>
      <p class="tracing-destination">Origins to Manchester, UK</p>
    </header>

    <MSAWorldMap client:load />
  </section>
</BaseLayout>

<style>
  :global(main) {
    max-width: none;
    padding: 0;
  }

  .tracing-page {
    background: #ffffff;
    color: #1b3642;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-height: 100vh;
    padding: clamp(1.25rem, 2.4vw, 2.75rem);
  }

  .tracing-header {
    align-items: end;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(10rem, 1fr) auto minmax(10rem, 1fr);
    padding-bottom: clamp(1.4rem, 2.6vw, 2.4rem);
  }

  .tracing-brand,
  .tracing-destination,
  .tracing-title p {
    font-size: clamp(0.78rem, 0.85vw, 0.92rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    line-height: 1.25;
    margin: 0;
    text-transform: uppercase;
  }

  .tracing-title {
    text-align: center;
  }

  .tracing-title h1 {
    font-size: clamp(2.4rem, 5.7vw, 6.6rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.95;
    margin: 0.14em 0 0;
  }

  .tracing-destination {
    justify-self: end;
    text-align: right;
  }

  :global(.msa-map) {
    min-height: min(68vh, 720px);
    position: relative;
    width: 100%;
  }

  :global(.msa-map__controls) {
    display: flex;
    gap: 0.35rem;
    justify-content: center;
    margin: 0 auto clamp(0.65rem, 1.1vw, 1rem);
  }

  :global(.msa-map__controls button) {
    appearance: none;
    background: transparent;
    border: 1px solid rgba(27, 54, 66, 0.2);
    color: rgba(27, 54, 66, 0.58);
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.48rem 0.68rem;
    text-transform: uppercase;
    transition: border-color 160ms ease, color 160ms ease;
  }

  :global(.msa-map__controls button.is-active) {
    border-color: #691b17;
    color: #691b17;
  }

  @media (hover: hover) and (pointer: fine) {
    :global(.msa-map__controls button:hover) {
      border-color: #691b17;
      color: #691b17;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    :global(.msa-map__controls button:active) {
      border-color: #691b17;
      color: #691b17;
    }
  }

  :global(.msa-map__svg) {
    display: block;
    height: auto;
    overflow: visible;
    width: 100%;
  }

  :global(.msa-map__countries path) {
    fill: #8d9ba1;
    opacity: 0.24;
    stroke: none;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  :global(.msa-map__arc) {
    fill: none;
    opacity: 0.42;
    pointer-events: none;
    stroke: #691b17;
    stroke-linecap: round;
    stroke-width: 0.72;
    transition: opacity 180ms ease, stroke-width 180ms ease;
  }

  :global(.msa-map__svg--network .msa-map__arc) {
    opacity: 0.52;
    stroke-width: 0.82;
  }

  :global(.msa-map__arc.is-active) {
    opacity: 0.96;
    stroke: #691b17;
    stroke-width: 1.55;
  }

  :global(.msa-map__arc-hit) {
    cursor: crosshair;
    fill: none;
    opacity: 0;
    stroke: transparent;
    stroke-linecap: round;
    stroke-width: 11;
  }

  :global(.msa-map__origin) {
    cursor: crosshair;
    fill: #691b17;
    opacity: 0.86;
    stroke: #ffffff;
    stroke-width: 1.1;
    transition: opacity 180ms ease, r 180ms ease;
  }

  :global(.msa-map__origin.is-active) {
    fill: #691b17;
    opacity: 1;
  }

  :global(.msa-map__destination circle:first-child) {
    fill: #691b17;
    fill-opacity: 0.07;
    stroke: #691b17;
    stroke-width: 1.25;
    vector-effect: non-scaling-stroke;
  }

  :global(.msa-map__destination circle:last-child) {
    fill: #691b17;
  }

  :global(.msa-map__tooltip) {
    background: #ffffff;
    border: 1px solid rgba(27, 54, 66, 0.2);
    color: #1b3642;
    font-size: 0.78rem;
    font-weight: 300;
    left: 0;
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0.42rem 0.52rem;
    pointer-events: none;
    position: absolute;
    text-transform: uppercase;
    top: 0;
    transform: translate(0.8rem, -1.9rem);
    white-space: nowrap;
    z-index: 2;
  }

  :global(.msa-map__status) {
    color: #691b17;
    font-size: 0.86rem;
    margin: 1rem 0 0;
    text-align: center;
  }

  @media (max-width: 760px) {
    .tracing-page {
      padding: 1rem;
    }

    .tracing-header {
      align-items: start;
      grid-template-columns: 1fr;
      padding-bottom: 1.5rem;
    }

    .tracing-title {
      text-align: left;
    }

    .tracing-destination {
      justify-self: start;
      text-align: left;
    }

    :global(.msa-map) {
      min-height: 56vh;
    }
  }
</style>
