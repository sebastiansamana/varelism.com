---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { title: 'Author', href: '/author/' },
  { title: 'Architect', href: '/architect/' },
  { title: 'Artist', href: '/artist/' },
];
---

<BaseLayout title="Varelism" description="Author, architect, and artist.">
  <section class="triptych" aria-label="Varelism sections">
    {sections.map((section) => (
      <a class="triptych-item" href={section.href}>
        <h1>{section.title}</h1>
        <span class="column-stack" aria-hidden="true">
          <img
            class="column column-base"
            src="/images/Home_Page_Column.png"
            alt=""
            loading="eager"
            decoding="async"
          />
          <img
            class="column column-hover"
            src="/images/Home_Page_Column_Cursor.png"
            alt=""
            loading="eager"
            decoding="async"
          />
        </span>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  @font-face {
    font-family: 'SF Pro Display Thin';
    font-style: normal;
    font-weight: 200;
    src: url('/fonts/SF-Pro-Display-Thin.otf') format('opentype');
    font-display: swap;
  }

  :global(main) {
    max-width: none;
    padding: 0;
  }

  .triptych {
    align-items: start;
    display: grid;
    gap: clamp(1.5rem, 6vw, 7rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    justify-items: center;
    margin: 0 auto;
    min-height: 100vh;
    padding: clamp(3rem, 7vh, 5.5rem) clamp(1.25rem, 6vw, 6rem) clamp(2rem, 5vh, 4rem);
    width: min(100%, 1280px);
  }

  .triptych-item {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 4vh, 3rem);
    min-width: 0;
    text-decoration: none;
    width: 100%;
  }

  h1 {
    color: currentColor;
    font-family: 'SF Pro Display Thin', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.55rem, 2.4vw, 2.45rem);
    font-weight: 200;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
    text-align: center;
    transition: color 180ms ease;
  }

  .column-stack {
    display: grid;
    max-width: 100%;
    position: relative;
    width: clamp(6.25rem, 17vw, 13.25rem);
  }

  .column {
    display: block;
    grid-area: 1 / 1;
    height: auto;
    max-width: 100%;
    width: 100%;
  }

  .column-hover {
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .triptych-item:hover,
  .triptych-item:focus-visible {
    color: #691b17;
  }

  .triptych-item:hover .column-hover,
  .triptych-item:focus-visible .column-hover {
    opacity: 1;
  }

  .triptych-item:focus-visible {
    outline: 1px solid #691b17;
    outline-offset: 0.75rem;
  }

  @media (max-width: 720px) {
    .triptych {
      gap: clamp(1rem, 4vw, 2rem);
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .triptych-item {
      gap: 1.25rem;
    }

    h1 {
      font-size: clamp(1.05rem, 4.2vw, 1.45rem);
    }

    .column-stack {
      width: clamp(4.25rem, 26vw, 7rem);
    }
  }

  @media (max-width: 430px) {
    .triptych {
      gap: 0.75rem;
    }
  }
</style>
