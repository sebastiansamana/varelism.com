---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { title: 'Author', href: '/author/' },
  { title: 'Architect', href: '/architect/' },
  { title: 'Artist', href: '/artist/' },
];
---

<BaseLayout title="Varelism" description="Author, architect, and artist.">
  <section class="triptych" aria-label="Varelism sections">
    {sections.map((section) => (
      <div class="triptych-item">
        <a class="triptych-link" href={section.href}>
          <h1>{section.title}</h1>
        </a>
        <span class="column-stack" aria-hidden="true">
          <img
            class="column column-base"
            src="/images/Home_Page_Column.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            decoding="async"
          />
          <img
            class="column column-hover"
            src="/images/Home_Page_Column_Cursor.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            decoding="async"
          />
        </span>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  :global(.site-shell > main) {
    display: grid;
    max-width: none;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: 0;
    place-items: center;
  }

  .triptych {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 6vw, 7rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    justify-items: center;
    margin: 0 auto;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: clamp(1.5rem, 4vh, 3rem) clamp(1.25rem, 6vw, 6rem);
    width: min(100%, 1280px);
  }

  .triptych-item {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.8vh, 1.25rem);
    min-width: 0;
    text-decoration: none;
    width: 100%;
  }

  .triptych-link {
    color: inherit;
    display: block;
    text-decoration: none;
  }

  h1 {
    color: currentColor;
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
    text-align: center;
    transition: color 180ms ease;
  }

  .column-stack {
    display: grid;
    max-width: 100%;
    position: relative;
    width: clamp(6.25rem, 17vw, 13.25rem);
  }

  .column {
    display: block;
    grid-area: 1 / 1;
    height: auto;
    max-width: 100%;
    pointer-events: none;
    width: 100%;
  }

  .column-hover {
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .triptych-link:focus-visible h1 {
    color: #691b17;
  }

  .triptych-link:focus-visible {
    outline: 1px solid #691b17;
    outline-offset: 0.75rem;
  }

  .triptych-link:hover h1 {
    color: #691b17;
  }

  .triptych-link:active h1 {
    color: #691b17;
  }

  @media (max-width: 720px) {
    .triptych {
      gap: clamp(1rem, 4vw, 2rem);
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .triptych-item {
      gap: 0.8rem;
    }

    h1 {
      font-size: clamp(0.95rem, 3.8vw, 1.25rem);
    }

    .column-stack {
      width: clamp(4.25rem, 26vw, 7rem);
    }
  }

  @media (max-width: 430px) {
    .triptych {
      gap: 0.75rem;
    }
  }
</style>
