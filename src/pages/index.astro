---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { title: 'Author', href: '/author/' },
  { title: 'Architect', href: '/architect/' },
  { title: 'Artist', href: '/artist/' },
];
---

<BaseLayout title="Varelism" description="Author, architect, and artist.">
  <section class="triptych" aria-label="Varelism sections">
    {sections.map((section) => (
      <a class="triptych-item" href={section.href}>
        <h1>{section.title}</h1>
        <span class="column-stack" aria-hidden="true">
          <img
            class="column column-base"
            src="/images/Home_Page_Column.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            decoding="async"
          />
          <img
            class="column column-hover"
            src="/images/Home_Page_Column_Cursor.png"
            alt=""
            width="720"
            height="1290"
            loading="eager"
            decoding="async"
          />
        </span>
      </a>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  const setupColumnHitboxes = () => {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      return;
    }

    document.querySelectorAll('.triptych-item').forEach((item) => {
      const column = item.querySelector('.column-base');
      if (!(column instanceof HTMLImageElement) || item.dataset.hitboxReady === 'true') {
        return;
      }

      item.dataset.hitboxReady = 'true';
      const canvas = document.createElement('canvas');
      const context = canvas.getContext('2d', { willReadFrequently: true });
      let isReady = false;

      const cacheColumnPixels = () => {
        if (!context || !column.naturalWidth || !column.naturalHeight) {
          return;
        }

        canvas.width = column.naturalWidth;
        canvas.height = column.naturalHeight;
        context.drawImage(column, 0, 0);
        isReady = true;
      };

      const clearHit = () => {
        item.classList.remove('is-column-hit');
      };

      const updateHit = (event) => {
        if (!isReady || !context) {
          clearHit();
          return;
        }

        const rect = column.getBoundingClientRect();
        const isInsideImage =
          event.clientX >= rect.left &&
          event.clientX <= rect.right &&
          event.clientY >= rect.top &&
          event.clientY <= rect.bottom;

        if (!isInsideImage) {
          clearHit();
          return;
        }

        const x = Math.min(
          canvas.width - 1,
          Math.floor(((event.clientX - rect.left) / rect.width) * canvas.width),
        );
        const y = Math.min(
          canvas.height - 1,
          Math.floor(((event.clientY - rect.top) / rect.height) * canvas.height),
        );
        const [red, green, blue, alpha] = context.getImageData(x, y, 1, 1).data;
        const isColumnPixel = alpha > 24 && !(red > 245 && green > 245 && blue > 245);

        item.classList.toggle('is-column-hit', isColumnPixel);
      };

      if (column.complete) {
        cacheColumnPixels();
      } else {
        column.addEventListener('load', cacheColumnPixels, { once: true });
      }

      item.addEventListener('pointermove', updateHit);
      item.addEventListener('pointerleave', clearHit);
    });
  };

  if (!window.varelismColumnHitboxesReady) {
    window.varelismColumnHitboxesReady = true;
    setupColumnHitboxes();
    document.addEventListener('astro:page-load', setupColumnHitboxes);
  }
</script>

<style>
  :global(.site-shell > main) {
    display: grid;
    max-width: none;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: 0;
    place-items: center;
  }

  .triptych {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 6vw, 7rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    justify-items: center;
    margin: 0 auto;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: clamp(1.5rem, 4vh, 3rem) clamp(1.25rem, 6vw, 6rem);
    width: min(100%, 1280px);
  }

  .triptych-item {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.8vh, 1.25rem);
    min-width: 0;
    text-decoration: none;
    width: 100%;
  }

  h1 {
    color: currentColor;
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
    text-align: center;
    transition: color 180ms ease;
  }

  .column-stack {
    display: grid;
    max-width: 100%;
    position: relative;
    width: clamp(6.25rem, 17vw, 13.25rem);
  }

  .column {
    display: block;
    grid-area: 1 / 1;
    height: auto;
    max-width: 100%;
    pointer-events: none;
    width: 100%;
  }

  .column-hover {
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .triptych-item:focus-visible {
    color: #691b17;
  }

  .triptych-item:focus-visible .column-hover {
    opacity: 1;
  }

  @media (hover: hover) and (pointer: fine) {
    .triptych-item.is-column-hit {
      color: #691b17;
    }

    .triptych-item.is-column-hit .column-hover {
      opacity: 1;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .triptych-item:active {
      color: #691b17;
    }

    .triptych-item:active .column-hover {
      opacity: 1;
    }
  }

  .triptych-item:focus-visible {
    outline: 1px solid #691b17;
    outline-offset: 0.75rem;
  }

  @media (max-width: 720px) {
    .triptych {
      gap: clamp(1rem, 4vw, 2rem);
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .triptych-item {
      gap: 0.8rem;
    }

    h1 {
      font-size: clamp(0.95rem, 3.8vw, 1.25rem);
    }

    .column-stack {
      width: clamp(4.25rem, 26vw, 7rem);
    }
  }

  @media (max-width: 430px) {
    .triptych {
      gap: 0.75rem;
    }
  }
</style>
