---
import HomePreloader from '../components/HomePreloader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Author | Varelism" description="Author.">
  <HomePreloader
    activePaths={['/author/', '/author']}
    completeEvent="varelism:author-preloader-complete"
    playOnce={false}
    sessionKey="varelism-author-preloader-seen"
    timingScale={0.25}
  />

  <section class="author-stage" data-author-stage aria-label="Author">
    <svg class="author-connector" data-author-connector aria-hidden="true" focusable="false">
      <path
        data-author-connector-path
        fill="none"
        stroke="#000000"
        stroke-linecap="butt"
        stroke-linejoin="round"
        stroke-width="0.8"
        vector-effect="non-scaling-stroke"
      ></path>
    </svg>
    <nav class="author-links" aria-label="Author sections">
      <a class="author-link" href="/books/" data-author-link="books">Books</a>
      <a class="author-link" href="/archives/" data-author-link="archives">Archives</a>
    </nav>
  </section>
</BaseLayout>

<script>
  (() => {
    const stateKey = '__varelismAuthorPage';
    const state = (window[stateKey] ||= {
      cleanup: null,
      listenersAttached: false,
    });
    const preloaderCompleteEvent = 'varelism:author-preloader-complete';

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
    const randomBetween = (min, max) => min + Math.random() * (max - min);
    const responsiveScale = (target, width = window.innerWidth) => clamp(target * (width / 720), target * 0.72, target);
    const getRectCenter = (rect) => ({
      x: rect.left + rect.width / 2,
      y: rect.top + rect.height / 2,
    });
    const normalizeVector = (vector, fallback = { x: 1, y: 0 }) => {
      const length = Math.hypot(vector.x, vector.y);

      if (length < 0.001) return fallback;

      return {
        x: vector.x / length,
        y: vector.y / length,
      };
    };
    const getPlacementRect = (placement) => ({
      bottom: placement.y + placement.height / 2,
      height: placement.height,
      left: placement.x - placement.width / 2,
      right: placement.x + placement.width / 2,
      top: placement.y - placement.height / 2,
      width: placement.width,
    });
    const getPaddedRect = (rect, padding) => ({
      bottom: rect.bottom + padding,
      height: rect.height + padding * 2,
      left: rect.left - padding,
      right: rect.right + padding,
      top: rect.top - padding,
      width: rect.width + padding * 2,
    });
    const getRectGap = (first, second) => {
      const xGap = Math.max(0, first.left > second.right ? first.left - second.right : second.left - first.right);
      const yGap = Math.max(0, first.top > second.bottom ? first.top - second.bottom : second.top - first.bottom);

      return Math.hypot(xGap, yGap);
    };
    const getPointRectDistance = (point, rect) => {
      const dx = Math.max(rect.left - point.x, 0, point.x - rect.right);
      const dy = Math.max(rect.top - point.y, 0, point.y - rect.bottom);

      return Math.hypot(dx, dy);
    };
    const toCanvasRect = (rect, canvasRect) => ({
      bottom: rect.bottom - canvasRect.top,
      height: rect.height,
      left: rect.left - canvasRect.left,
      right: rect.right - canvasRect.left,
      top: rect.top - canvasRect.top,
      width: rect.width,
    });
    let textMetricsContext = null;
    const getTextMetricsContext = () => {
      if (textMetricsContext) return textMetricsContext;

      textMetricsContext = document.createElement('canvas').getContext('2d');
      return textMetricsContext;
    };
    const getCanvasFont = (styles) =>
      [styles.fontStyle, styles.fontVariant, styles.fontWeight, styles.fontSize, styles.fontFamily]
        .filter(Boolean)
        .join(' ');
    const applyTextMetricsStyles = (context, styles) => {
      context.font = getCanvasFont(styles);
      context.textAlign = 'left';
      context.textBaseline = 'alphabetic';

      if ('direction' in context) context.direction = styles.direction;
      if ('fontKerning' in context) context.fontKerning = styles.fontKerning;
      if ('letterSpacing' in context) context.letterSpacing = styles.letterSpacing;
    };

    const createConnectorPath = (svg) => {
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('data-author-connector-path', '');
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', '#000000');
      path.setAttribute('stroke-linecap', 'butt');
      path.setAttribute('stroke-linejoin', 'round');
      path.setAttribute('stroke-width', '0.8');
      path.setAttribute('vector-effect', 'non-scaling-stroke');
      path.style.fill = 'none';
      path.style.opacity = '0';
      path.style.stroke = '#000000';
      path.style.strokeLinecap = 'butt';
      path.style.strokeLinejoin = 'round';
      path.style.strokeWidth = '0.8px';
      path.style.vectorEffect = 'non-scaling-stroke';
      svg.replaceChildren(path);

      return path;
    };

    const getTextGeometry = (link, canvasRect) => {
      const fallbackRect = toCanvasRect(link.getBoundingClientRect(), canvasRect);
      const context = getTextMetricsContext();
      const fallbackGeometry = {
        getSupportPoint: (anchor) => getCompassAnchorPoint(fallbackRect, anchor),
        rect: fallbackRect,
      };

      if (!context) return fallbackGeometry;

      const styles = window.getComputedStyle(link);
      const text = link.textContent?.trim() || '';

      applyTextMetricsStyles(context, styles);
      const metrics = context.measureText(text);
      const measuredWidth = Number.isFinite(metrics.width) && metrics.width > 0 ? metrics.width : fallbackRect.width;
      const leftBearing = Number.isFinite(metrics.actualBoundingBoxLeft) ? metrics.actualBoundingBoxLeft : 0;
      const rightBearing =
        Number.isFinite(metrics.actualBoundingBoxRight) && metrics.actualBoundingBoxRight > 0
          ? metrics.actualBoundingBoxRight
          : measuredWidth;
      const ascent =
        Number.isFinite(metrics.actualBoundingBoxAscent) && metrics.actualBoundingBoxAscent > 0
          ? metrics.actualBoundingBoxAscent
          : fallbackRect.height;
      const descent =
        Number.isFinite(metrics.actualBoundingBoxDescent) && metrics.actualBoundingBoxDescent > 0
          ? metrics.actualBoundingBoxDescent
          : 0;
      const widthOffset = (fallbackRect.width - measuredWidth) / 2;
      const inkHeight = Math.max(1, ascent + descent);
      const top = fallbackRect.top + (fallbackRect.height - inkHeight) / 2;
      const left = fallbackRect.left + widthOffset - leftBearing;
      const right = fallbackRect.left + widthOffset + rightBearing;
      const bottom = top + inkHeight;

      if (right <= left || bottom <= top) return fallbackGeometry;

      const rect = {
        bottom,
        height: bottom - top,
        left,
        right,
        top,
        width: right - left,
      };
      const padding = Math.ceil(Math.max(ascent, descent, 12) + 8);
      const bitmapWidth = Math.max(1, Math.ceil(measuredWidth + padding * 2));
      const bitmapHeight = Math.max(1, Math.ceil(inkHeight + padding * 2));

      context.canvas.width = bitmapWidth;
      context.canvas.height = bitmapHeight;
      applyTextMetricsStyles(context, styles);
      context.clearRect(0, 0, bitmapWidth, bitmapHeight);
      context.fillStyle = '#000000';
      context.fillText(text, padding, padding + ascent);

      const imageData = context.getImageData(0, 0, bitmapWidth, bitmapHeight).data;
      const originX = fallbackRect.left + widthOffset;
      const baselineY = top + ascent;
      const inkPixels = [];

      for (let y = 0; y < bitmapHeight; y += 1) {
        for (let x = 0; x < bitmapWidth; x += 1) {
          const alpha = imageData[(y * bitmapWidth + x) * 4 + 3];

          if (alpha <= 24) continue;

          inkPixels.push({
            x: originX + x + 0.5 - padding,
            y: baselineY + y + 0.5 - padding - ascent,
          });
        }
      }

      if (inkPixels.length === 0) return fallbackGeometry;

      return {
        getSupportPoint: (anchor) => {
          const center = getRectCenter(rect);

          if (anchor === 'E' || anchor === 'W') {
            const maxBand = Math.max(2, rect.height * 0.45);
            let candidates = [];

            for (let band = 1.5; band <= maxBand && candidates.length === 0; band += 1.5) {
              candidates = inkPixels.filter((point) => Math.abs(point.y - center.y) <= band);
            }

            if (candidates.length > 0) {
              const targetX =
                anchor === 'E'
                  ? Math.max(...candidates.map((point) => point.x))
                  : Math.min(...candidates.map((point) => point.x));
              const sidePoints = candidates.filter((point) => Math.abs(point.x - targetX) <= 0.75);
              const x =
                sidePoints.reduce((total, point) => total + point.x, 0) / Math.max(1, sidePoints.length);

              return {
                x,
                y: center.y,
              };
            }
          }

          if (anchor === 'N' || anchor === 'S') {
            const maxBand = Math.max(2, rect.width * 0.45);
            let candidates = [];

            for (let band = 1.5; band <= maxBand && candidates.length === 0; band += 1.5) {
              candidates = inkPixels.filter((point) => Math.abs(point.x - center.x) <= band);
            }

            if (candidates.length > 0) {
              const targetY =
                anchor === 'S'
                  ? Math.max(...candidates.map((point) => point.y))
                  : Math.min(...candidates.map((point) => point.y));
              const sidePoints = candidates.filter((point) => Math.abs(point.y - targetY) <= 0.75);
              const y =
                sidePoints.reduce((total, point) => total + point.y, 0) / Math.max(1, sidePoints.length);

              return {
                x: center.x,
                y,
              };
            }
          }

          const direction = getCompassAnchorDirection(anchor);
          let maxProjection = Number.NEGATIVE_INFINITY;

          inkPixels.forEach((point) => {
            maxProjection = Math.max(maxProjection, point.x * direction.x + point.y * direction.y);
          });

          const supportPoints = inkPixels.filter(
            (point) => maxProjection - (point.x * direction.x + point.y * direction.y) <= 0.75,
          );

          return supportPoints.reduce(
            (point, current) => ({
              x: point.x + current.x / supportPoints.length,
              y: point.y + current.y / supportPoints.length,
            }),
            { x: 0, y: 0 },
          );
        },
        rect,
      };
    };

    const calculateSafeMargins = (stage, links) => {
      const canvasRect = stage.getBoundingClientRect();
      const width = Math.max(stage.clientWidth, Math.round(canvasRect.width), 1);
      const height = Math.max(stage.clientHeight, Math.round(canvasRect.height), 1);
      const minDimension = Math.min(width, height);
      const textHeights = links.map((link) => link.getBoundingClientRect().height || 1);
      const fontSizes = links.map((link) => Number.parseFloat(window.getComputedStyle(link).fontSize) || 1);
      const typographyScale = Math.max(...textHeights, ...fontSizes, 1);
      const edgeInsetX = clamp(minDimension * 0.09, 26, 90);
      const edgeInsetY = clamp(minDimension * 0.1, 28, 84);
      const textPadding = clamp(typographyScale * 0.14, width <= 560 ? 3 : 4, width <= 560 ? 5 : 6);
      const TEXT_TO_LINE_GAP = responsiveScale(10, window.innerWidth);
      const safeRect = {
        bottom: height - edgeInsetY,
        left: edgeInsetX,
        right: width - edgeInsetX,
        top: edgeInsetY,
      };
      const viewportSplitX = clamp(window.innerWidth / 2 - canvasRect.left, safeRect.left, safeRect.right);

      return {
        canvasRect,
        edgeInsetX,
        edgeInsetY,
        height,
        minDimension,
        safeRect,
        textToLineGap: TEXT_TO_LINE_GAP,
        textPadding,
        viewportSplitX,
        width,
      };
    };

    const calculateRandomTextPositions = (sizes, margins) => {
      const { minDimension, safeRect, textPadding, viewportSplitX, width, height } = margins;
      const splitX = clamp(viewportSplitX, safeRect.left, safeRect.right);
      const booksBounds = {
        bottom: safeRect.bottom,
        left: safeRect.left,
        right: Math.min(safeRect.right, splitX),
        top: safeRect.top,
      };
      const archivesBounds = {
        bottom: safeRect.bottom,
        left: Math.max(safeRect.left, splitX),
        right: safeRect.right,
        top: safeRect.top,
      };
      const centerRange = (size, bounds) => {
        const minX = bounds.left + size.width / 2;
        const maxX = bounds.right - size.width / 2;
        const minY = bounds.top + size.height / 2;
        const maxY = bounds.bottom - size.height / 2;

        return {
          maxX: Math.max(minX, maxX),
          maxY: Math.max(minY, maxY),
          minX,
          minY,
        };
      };
      const createPlacement = (size, bounds) => {
        const range = centerRange(size, bounds);

        return {
          height: size.height,
          width: size.width,
          x: randomBetween(range.minX, range.maxX),
          y: randomBetween(range.minY, range.maxY),
        };
      };
      const minGap = Math.max(textPadding * 4.2, minDimension * 0.24);
      const minDistance = Math.max(minDimension * 0.63, (sizes[0].width + sizes[1].width) / 2 + textPadding * 6);
      const maxDistance = Math.hypot(width, height) * 0.88;

      for (let attempt = 0; attempt < 900; attempt += 1) {
        const books = createPlacement(sizes[0], booksBounds);
        const archives = createPlacement(sizes[1], archivesBounds);
        const booksRect = getPaddedRect(getPlacementRect(books), textPadding);
        const archivesRect = getPaddedRect(getPlacementRect(archives), textPadding);
        const gap = getRectGap(booksRect, archivesRect);
        const distance = Math.hypot(archives.x - books.x, archives.y - books.y);

        if (gap >= minGap && distance >= minDistance && distance <= maxDistance) {
          return [books, archives];
        }
      }

      const firstRange = centerRange(sizes[0], booksBounds);
      const secondRange = centerRange(sizes[1], archivesBounds);

      return [
        {
          height: sizes[0].height,
          width: sizes[0].width,
          x: firstRange.minX,
          y: randomBetween(firstRange.minY, firstRange.maxY),
        },
        {
          height: sizes[1].height,
          width: sizes[1].width,
          x: secondRange.maxX,
          y: randomBetween(secondRange.minY, secondRange.maxY),
        },
      ];
    };

    const getCompassAnchorPoint = (rect, anchor) => {
      const center = getRectCenter(rect);
      const anchors = {
        E: { x: rect.right, y: center.y },
        N: { x: center.x, y: rect.top },
        NE: { x: rect.right, y: rect.top },
        NW: { x: rect.left, y: rect.top },
        S: { x: center.x, y: rect.bottom },
        SE: { x: rect.right, y: rect.bottom },
        SW: { x: rect.left, y: rect.bottom },
        W: { x: rect.left, y: center.y },
      };

      return anchors[anchor] || center;
    };
    const getCompassAnchorDirection = (anchor) => {
      const directions = {
        E: { x: 1, y: 0 },
        N: { x: 0, y: -1 },
        NE: normalizeVector({ x: 1, y: -1 }),
        NW: normalizeVector({ x: -1, y: -1 }),
        S: { x: 0, y: 1 },
        SE: normalizeVector({ x: 1, y: 1 }),
        SW: normalizeVector({ x: -1, y: 1 }),
        W: { x: -1, y: 0 },
      };

      return directions[anchor] || { x: 1, y: 0 };
    };

    const getCompassAnchorPair = (booksRect, archivesRect) => {
      const booksCenter = getRectCenter(booksRect);
      const archivesCenter = getRectCenter(archivesRect);
      const deltaX = Math.max(1, archivesCenter.x - booksCenter.x);
      const deltaY = archivesCenter.y - booksCenter.y;
      const angle = (Math.atan2(deltaY, deltaX) * 180) / Math.PI;

      if (angle < -60) return { archives: 'SW', books: 'N' };
      if (angle < -22) return { archives: 'SW', books: 'NE' };
      if (angle <= 22) return { archives: 'W', books: 'E' };
      if (angle <= 60) return { archives: 'NW', books: 'SE' };

      return { archives: 'NW', books: 'S' };
    };

    const getClosestAnchorPoints = (booksGeometry, archivesGeometry, padding) => {
      const booksSafeRect = getPaddedRect(booksGeometry.rect, padding);
      const archivesSafeRect = getPaddedRect(archivesGeometry.rect, padding);
      const anchors = getCompassAnchorPair(booksSafeRect, archivesSafeRect);
      const booksDirection = getCompassAnchorDirection(anchors.books);
      const archivesDirection = getCompassAnchorDirection(anchors.archives);
      const booksReferencePoint = booksGeometry.getSupportPoint(anchors.books);
      const archivesReferencePoint = archivesGeometry.getSupportPoint(anchors.archives);

      return {
        archiveAnchor: anchors.archives,
        archivesDirection,
        archivesSafeRect,
        bookAnchor: anchors.books,
        booksDirection,
        booksSafeRect,
        endPoint: {
          x: archivesReferencePoint.x + archivesDirection.x * padding,
          y: archivesReferencePoint.y + archivesDirection.y * padding,
        },
        endTangent: {
          x: -archivesDirection.x,
          y: -archivesDirection.y,
        },
        startPoint: {
          x: booksReferencePoint.x + booksDirection.x * padding,
          y: booksReferencePoint.y + booksDirection.y * padding,
        },
        startTangent: booksDirection,
      };
    };

    const getCubicPoint = (start, controlOne, controlTwo, end, t) => {
      const inverseT = 1 - t;

      return {
        x:
          inverseT ** 3 * start.x +
          3 * inverseT ** 2 * t * controlOne.x +
          3 * inverseT * t ** 2 * controlTwo.x +
          t ** 3 * end.x,
        y:
          inverseT ** 3 * start.y +
          3 * inverseT ** 2 * t * controlOne.y +
          3 * inverseT * t ** 2 * controlTwo.y +
          t ** 3 * end.y,
      };
    };

    const generateVariableWaveParameters = (distance, minDimension) => ({
      amplitude: clamp(distance * randomBetween(0.032, 0.06), 7, minDimension * 0.131),
      amplitudeDrift: randomBetween(0.26, 0.58),
      amplitudePhase: randomBetween(-Math.PI, Math.PI),
      cycles: clamp(distance / (minDimension * randomBetween(0.48, 0.78)), 0.65, 2.45),
      centerAmplitudeBoost: randomBetween(0.75, 1.35),
      phase: randomBetween(-Math.PI, Math.PI),
      phaseDrift: randomBetween(0.4, 0.98),
      wavelengthDrift: randomBetween(0.43, 0.9),
      wavelengthPhase: randomBetween(-Math.PI, Math.PI),
    });

    const createSmoothPathFromPoints = (points, startTangent, endTangent, minDimension, options = {}) => {
      const samples = [points[0]];
      const cumulative = [0];
      let length = 0;
      let previousSample = points[0];
      let d = `M ${points[0].x.toFixed(2)} ${points[0].y.toFixed(2)}`;
      const hasLeadSegments = Boolean(options.hasLeadSegments) && points.length >= 4;

      for (let index = 0; index < points.length - 1; index += 1) {
        const previous = points[index - 1] || points[index];
        const current = points[index];
        const next = points[index + 1];
        const afterNext = points[index + 2] || next;
        const segmentLength = Math.hypot(next.x - current.x, next.y - current.y);
        const leadHandle = Math.max(0.1, segmentLength / 3);
        const tangentHandle = clamp(segmentLength * 0.38, 18, minDimension * 0.22);
        const startsStraightLead = hasLeadSegments && index === 0;
        const blendsFromLead = hasLeadSegments && index === 1;
        const blendsToLead = hasLeadSegments && index === points.length - 3;
        const endsStraightLead = hasLeadSegments && index === points.length - 2;
        let controlOne;
        let controlTwo;

        if (startsStraightLead) {
          controlOne = {
            x: current.x + startTangent.x * leadHandle,
            y: current.y + startTangent.y * leadHandle,
          };
        } else if (endsStraightLead) {
          controlOne = {
            x: current.x + endTangent.x * leadHandle,
            y: current.y + endTangent.y * leadHandle,
          };
        } else if (index === 0 || blendsFromLead) {
          controlOne = {
            x: current.x + startTangent.x * tangentHandle,
            y: current.y + startTangent.y * tangentHandle,
          };
        } else {
          controlOne = {
            x: current.x + (next.x - previous.x) / 6,
            y: current.y + (next.y - previous.y) / 6,
          };
        }

        if (startsStraightLead) {
          controlTwo = {
            x: next.x - startTangent.x * leadHandle,
            y: next.y - startTangent.y * leadHandle,
          };
        } else if (endsStraightLead) {
          controlTwo = {
            x: next.x - endTangent.x * leadHandle,
            y: next.y - endTangent.y * leadHandle,
          };
        } else if (index === points.length - 2 || blendsToLead) {
          controlTwo = {
            x: next.x - endTangent.x * tangentHandle,
            y: next.y - endTangent.y * tangentHandle,
          };
        } else {
          controlTwo = {
            x: next.x - (afterNext.x - current.x) / 6,
            y: next.y - (afterNext.y - current.y) / 6,
          };
        }

        for (let sample = 1; sample <= 12; sample += 1) {
          const point = getCubicPoint(current, controlOne, controlTwo, next, sample / 12);

          length += Math.hypot(point.x - previousSample.x, point.y - previousSample.y);
          samples.push(point);
          cumulative.push(length);
          previousSample = point;
        }

        d += ` C ${controlOne.x.toFixed(2)} ${controlOne.y.toFixed(2)}, ${controlTwo.x.toFixed(
          2,
        )} ${controlTwo.y.toFixed(2)}, ${next.x.toFixed(2)} ${next.y.toFixed(2)}`;
      }

      return {
        cumulative,
        d,
        length,
        samples,
      };
    };

    const getMinimumCurveDistance = (samples, rects) =>
      samples.slice(1, -1).reduce((minimum, point) => {
        const pointMinimum = rects.reduce(
          (rectMinimum, rect) => Math.min(rectMinimum, getPointRectDistance(point, rect)),
          Number.POSITIVE_INFINITY,
        );

        return Math.min(minimum, pointMinimum);
      }, Number.POSITIVE_INFINITY);

    const generateOrganicSingleStrokePath = ({ endPoint, endTangent, startPoint, startTangent }, margins, avoidRects) => {
      const deltaX = endPoint.x - startPoint.x;
      const deltaY = endPoint.y - startPoint.y;
      const distance = Math.max(1, Math.hypot(deltaX, deltaY));
      const direction = { x: deltaX / distance, y: deltaY / distance };
      const leadOutTangent = normalizeVector(startTangent || direction, direction);
      const leadInTangent = normalizeVector(endTangent || direction, direction);
      const leadLength = clamp(distance * 0.045, margins.textToLineGap * 1.4, margins.minDimension * 0.07);
      const organicStartPoint = {
        x: startPoint.x + leadOutTangent.x * leadLength,
        y: startPoint.y + leadOutTangent.y * leadLength,
      };
      const organicEndPoint = {
        x: endPoint.x - leadInTangent.x * leadLength,
        y: endPoint.y - leadInTangent.y * leadLength,
      };
      const organicDeltaX = organicEndPoint.x - organicStartPoint.x;
      const organicDeltaY = organicEndPoint.y - organicStartPoint.y;
      const organicDistance = Math.max(1, Math.hypot(organicDeltaX, organicDeltaY));
      const organicDirection = { x: organicDeltaX / organicDistance, y: organicDeltaY / organicDistance };
      const normal = { x: -organicDirection.y, y: organicDirection.x };
      const pointCount = Math.round(clamp(distance / 58, 7, 15));
      let bestCurve = null;
      let bestScore = Number.NEGATIVE_INFINITY;

      for (let attempt = 0; attempt < 18; attempt += 1) {
        const params = generateVariableWaveParameters(distance, margins.minDimension);
        const points = [];

        for (let index = 0; index <= pointCount; index += 1) {
          const t = index / pointCount;
          const taper = Math.sin(Math.PI * t) ** 2;
          const centerProfile = Math.sin(Math.PI * t) ** 1.35;
          const amplitude =
            params.amplitude *
            taper *
            (1 + params.centerAmplitudeBoost * centerProfile) *
            (1 + params.amplitudeDrift * Math.sin(Math.PI * 2 * t + params.amplitudePhase));
          const phase =
            params.phase +
            Math.PI * 2 * params.cycles * t +
            params.phaseDrift * centerProfile * Math.sin(Math.PI * 2 * t * 1.35 + params.wavelengthPhase);
          const wavelengthVariation =
            1 + params.wavelengthDrift * centerProfile * Math.sin(Math.PI * 2 * t * 0.72 + params.wavelengthPhase);
          const offset = amplitude * Math.sin(phase * wavelengthVariation);

          points.push({
            x: organicStartPoint.x + organicDeltaX * t + normal.x * offset,
            y: organicStartPoint.y + organicDeltaY * t + normal.y * offset,
          });
        }

        points[0] = organicStartPoint;
        points[points.length - 1] = organicEndPoint;
        points.unshift(startPoint);
        points.push(endPoint);

        const curve = createSmoothPathFromPoints(points, leadOutTangent, leadInTangent, margins.minDimension, {
          hasLeadSegments: true,
        });
        const clearance = getMinimumCurveDistance(curve.samples, avoidRects);
        const score = clearance - params.amplitude * 0.08 - Math.abs(params.cycles - 1.4) * 0.5;

        if (score > bestScore) {
          bestCurve = curve;
          bestScore = score;
        }
      }

      return (
        bestCurve ||
        createSmoothPathFromPoints(
          [startPoint, organicStartPoint, organicEndPoint, endPoint],
          leadOutTangent,
          leadInTangent,
          margins.minDimension,
          { hasLeadSegments: true },
        )
      );
    };

    const animateSingleStrokeConstantSpeed = ({ curve, path, timers }, callback) => {
      const duration = Math.round(clamp(curve.length * 5.2, 1600, 5600));
      let hasFinished = false;

      const finish = () => {
        if (hasFinished) return;

        hasFinished = true;
        callback();
      };

      path.style.strokeDasharray = `${curve.length} ${curve.length}`;
      path.style.strokeDashoffset = `${curve.length}`;
      path.style.transition = 'none';
      path.style.opacity = '1';
      path.getBoundingClientRect();
      path.style.transition = `stroke-dashoffset ${duration}ms linear`;
      path.style.strokeDashoffset = '0';

      path.addEventListener(
        'transitionend',
        (event) => {
          if (event.propertyName === 'stroke-dashoffset') finish();
        },
        { once: true },
      );
      timers.add(window.setTimeout(finish, duration + 140));

      return () => {
        path.style.transition = 'none';
      };
    };

    const initAuthorPage = () => {
      const stage = document.querySelector('[data-author-stage]');

      if (!(stage instanceof HTMLElement)) {
        state.cleanup?.();
        return;
      }

      if (stage.dataset.authorBooted === 'true') return;

      state.cleanup?.();
      stage.dataset.authorBooted = 'true';

      const links = Array.from(stage.querySelectorAll('[data-author-link]')).filter(
        (link) => link instanceof HTMLAnchorElement,
      );
      const pathSvg = stage.querySelector('[data-author-connector]');

      if (links.length < 2 || !(pathSvg instanceof SVGSVGElement)) return;

      const timers = new Set();
      let cleanupAnimation = () => {};
      let composition = null;
      let disposed = false;
      let hasPrepared = false;
      let hasStarted = false;
      let preloaderComplete = !document.querySelector('[data-home-preloader]');
      let resizeFrame = 0;
      const blankDelay = 240;
      const booksFadeDuration = 1040;
      const lineDelay = 180;

      const setTimer = (callback, delay) => {
        const timer = window.setTimeout(() => {
          timers.delete(timer);
          if (!disposed) callback();
        }, delay);

        timers.add(timer);
        return timer;
      };
      const clearTimers = () => {
        timers.forEach((timer) => window.clearTimeout(timer));
        timers.clear();
      };
      const resetStage = () => {
        cleanupAnimation();
        cleanupAnimation = () => {};
        clearTimers();
        stage.classList.remove('is-archives-visible');
        stage.classList.remove('is-books-visible');
        stage.classList.remove('is-line-drawing');
        stage.classList.remove('is-positioned');
        createConnectorPath(pathSvg);
      };

      const prepareComposition = () => {
        if (disposed) return;

        resetStage();
        const sizes = links.map((link) => {
          const rect = link.getBoundingClientRect();

          return {
            height: Math.ceil(rect.height),
            width: Math.ceil(rect.width),
          };
        });
        const margins = calculateSafeMargins(stage, links);
        const placements = calculateRandomTextPositions(sizes, margins);

        links.forEach((link, index) => {
          link.style.setProperty('--author-link-x', `${placements[index].x}px`);
          link.style.setProperty('--author-link-y', `${placements[index].y}px`);
        });
        stage.classList.add('is-positioned');

        const canvasRect = stage.getBoundingClientRect();
        const booksGeometry = getTextGeometry(links[0], canvasRect);
        const archivesGeometry = getTextGeometry(links[1], canvasRect);
        const anchorData = getClosestAnchorPoints(booksGeometry, archivesGeometry, margins.textToLineGap);
        const curve = generateOrganicSingleStrokePath(
          {
            endPoint: anchorData.endPoint,
            endTangent: anchorData.endTangent,
            startPoint: anchorData.startPoint,
            startTangent: anchorData.startTangent,
          },
          margins,
          [anchorData.booksSafeRect, anchorData.archivesSafeRect],
        );
        const path = createConnectorPath(pathSvg);

        pathSvg.setAttribute('height', `${margins.height}`);
        pathSvg.setAttribute('viewBox', `0 0 ${margins.width} ${margins.height}`);
        pathSvg.setAttribute('width', `${margins.width}`);
        path.setAttribute('d', curve.d);
        path.style.strokeDasharray = `${curve.length} ${curve.length}`;
        path.style.strokeDashoffset = `${curve.length}`;

        composition = {
          curve,
          path,
        };
        hasPrepared = true;
      };

      const tryStartSequence = () => {
        if (disposed || hasStarted || !hasPrepared || !preloaderComplete || !composition) return;

        hasStarted = true;

        setTimer(() => {
          stage.classList.add('is-books-visible');
        }, blankDelay);
        setTimer(() => {
          stage.classList.add('is-line-drawing');
          cleanupAnimation = animateSingleStrokeConstantSpeed(
            {
              curve: composition.curve,
              path: composition.path,
              timers,
            },
            () => {
              setTimer(() => {
                stage.classList.add('is-archives-visible');
              }, blankDelay);
            },
          );
        }, blankDelay + booksFadeDuration + lineDelay);
      };

      const prepareWhenFontsReady = () => {
        const fontsReady = document.fonts?.ready;

        if (fontsReady && typeof fontsReady.then === 'function') {
          fontsReady.then(() => {
            prepareComposition();
            tryStartSequence();
          }).catch(() => {
            prepareComposition();
            tryStartSequence();
          });
          return;
        }

        prepareComposition();
        tryStartSequence();
      };
      const onPreloaderComplete = () => {
        preloaderComplete = true;
        tryStartSequence();
      };
      const onResize = () => {
        window.cancelAnimationFrame(resizeFrame);
        resizeFrame = window.requestAnimationFrame(() => {
          if (disposed) return;

          const wasStarted = hasStarted;
          const shouldShowBooks = wasStarted || stage.classList.contains('is-books-visible');
          const shouldShowLine = stage.classList.contains('is-line-drawing');
          const shouldShowArchives = stage.classList.contains('is-archives-visible');

          hasPrepared = false;
          prepareComposition();

          if (!wasStarted) {
            tryStartSequence();
            return;
          }

          if (shouldShowBooks) stage.classList.add('is-books-visible');

          if (!composition) return;

          if (shouldShowLine || shouldShowArchives) {
            stage.classList.add('is-line-drawing');
            composition.path.style.transition = 'none';
            composition.path.style.opacity = '1';
            composition.path.style.strokeDasharray = `${composition.curve.length} ${composition.curve.length}`;
            composition.path.style.strokeDashoffset = '0';
          } else if (shouldShowBooks) {
            setTimer(() => {
              stage.classList.add('is-line-drawing');
              cleanupAnimation = animateSingleStrokeConstantSpeed(
                {
                  curve: composition.curve,
                  path: composition.path,
                  timers,
                },
                () => {
                  setTimer(() => {
                    stage.classList.add('is-archives-visible');
                  }, blankDelay);
                },
              );
            }, lineDelay);
          }

          if (shouldShowArchives) {
            stage.classList.add('is-archives-visible');
          } else if (shouldShowLine) {
            setTimer(() => {
              stage.classList.add('is-archives-visible');
            }, blankDelay);
          }
        });
      };

      window.addEventListener(preloaderCompleteEvent, onPreloaderComplete);
      window.addEventListener('resize', onResize);
      window.addEventListener('orientationchange', onResize);
      prepareWhenFontsReady();

      state.cleanup = () => {
        disposed = true;
        window.cancelAnimationFrame(resizeFrame);
        window.removeEventListener(preloaderCompleteEvent, onPreloaderComplete);
        window.removeEventListener('resize', onResize);
        window.removeEventListener('orientationchange', onResize);
        links.forEach((link) => {
          link.style.removeProperty('--author-link-x');
          link.style.removeProperty('--author-link-y');
        });
        resetStage();
        delete stage.dataset.authorBooted;
      };
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:before-swap', () => state.cleanup?.());
      document.addEventListener('astro:page-load', initAuthorPage);
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAuthorPage, { once: true });
    } else {
      initAuthorPage();
    }
  })();
</script>

<style>
  @font-face {
    font-family: 'SF Pro Display Ultralight';
    font-style: normal;
    font-weight: 300;
    src: url('/fonts/SF-Pro-Display-Ultralight.ttf') format('truetype');
    font-display: swap;
  }

  :global(.site-shell) {
    background: #ffffff;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  :global(.site-shell > main) {
    --author-footer-reserve: clamp(5.8rem, 11vh, 7.25rem);
    --author-main-top: clamp(6rem, 12vh, 8rem);

    max-width: none;
    min-height: calc(100vh - var(--author-footer-reserve));
    min-height: calc(100svh - var(--author-footer-reserve));
    min-height: calc(100dvh - var(--author-footer-reserve));
    padding: var(--author-main-top) clamp(1rem, 4vw, 3rem) 0;
    width: 100%;
  }

  .author-stage {
    background: #ffffff;
    display: block;
    height: calc(100vh - var(--author-main-top) - var(--author-footer-reserve));
    height: calc(100svh - var(--author-main-top) - var(--author-footer-reserve));
    height: calc(100dvh - var(--author-main-top) - var(--author-footer-reserve));
    isolation: isolate;
    min-height: 24rem;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .author-connector {
    display: block;
    height: 100%;
    inset: 0;
    overflow: visible;
    pointer-events: none;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  :global(.author-connector path) {
    fill: none;
    opacity: 0;
    stroke: #000000;
    stroke-linecap: butt;
    stroke-linejoin: round;
    stroke-width: 0.8;
    vector-effect: non-scaling-stroke;
  }

  .author-links {
    height: 100%;
    inset: 0;
    pointer-events: none;
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .author-link {
    color: #691b17;
    cursor: pointer;
    display: block;
    font-family: 'SF Pro Display Ultralight', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    left: var(--author-link-x, 50%);
    letter-spacing: 0;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    text-align: center;
    text-decoration: none;
    top: var(--author-link-y, 50%);
    transform: translate(-50%, -50%);
    transition: color 180ms ease, opacity 1020ms ease;
    white-space: nowrap;
  }

  .author-stage.is-positioned.is-books-visible [data-author-link='books'],
  .author-stage.is-positioned.is-archives-visible [data-author-link='archives'] {
    opacity: 1;
    pointer-events: auto;
  }

  .author-link:focus-visible {
    color: #000000;
    outline: 1px solid #691b17;
    outline-offset: 0.45rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .author-link:hover {
      color: #000000;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .author-link:active {
      color: #000000;
    }
  }

  @media (max-width: 560px) {
    :global(.site-shell > main) {
      --author-footer-reserve: 6.35rem;
      --author-main-top: 5rem;
      padding-left: 0.85rem;
      padding-right: 0.85rem;
    }

    .author-stage {
      min-height: 25rem;
    }

    .author-link {
      font-size: clamp(0.95rem, 3.8vw, 1.25rem);
    }
  }
</style>
