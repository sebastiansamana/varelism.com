---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Author | Varelism" description="Author.">
  <section class="author-stage" data-author-stage aria-label="Author">
    <svg class="author-root-line" data-author-root-line aria-hidden="true" focusable="false">
      <path data-author-root-path></path>
    </svg>
    <nav class="author-random-nav" aria-label="Author sections">
      <a class="author-random-link" href="/books/" data-author-random-link data-author-link="books">Books</a>
      <a class="author-random-link" href="/archives/" data-author-random-link data-author-link="archives">Archives</a>
    </nav>
  </section>
</BaseLayout>

<script>
  (() => {
    const stateKey = '__varelismAuthorCanvas';
    const state = (window[stateKey] ||= {
      cleanup: null,
      listenersAttached: false,
      restart: null,
    });

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
    const randomBetween = (min, max) => {
      if (max <= min) return min;
      return min + Math.random() * (max - min);
    };

    const getRectGap = (first, second) => {
      const xGap = Math.max(0, first.left > second.right ? first.left - second.right : second.left - first.right);
      const yGap = Math.max(0, first.top > second.bottom ? first.top - second.bottom : second.top - first.bottom);
      return Math.hypot(xGap, yGap);
    };

    const getRectCenter = (rect) => ({
      x: rect.left + rect.width / 2,
      y: rect.top + rect.height / 2,
    });

    const getPlacementRect = (placement) => ({
      bottom: placement.y + placement.height / 2,
      height: placement.height,
      left: placement.x - placement.width / 2,
      right: placement.x + placement.width / 2,
      top: placement.y - placement.height / 2,
      width: placement.width,
    });

    const getPaddedRect = (rect, padding) => ({
      bottom: rect.bottom + padding,
      height: rect.height + padding * 2,
      left: rect.left - padding,
      right: rect.right + padding,
      top: rect.top - padding,
      width: rect.width + padding * 2,
    });

    const getPointRectDistance = (point, rect) => {
      const dx = Math.max(rect.left - point.x, 0, point.x - rect.right);
      const dy = Math.max(rect.top - point.y, 0, point.y - rect.bottom);

      return Math.hypot(dx, dy);
    };

    const normalizeVector = (vector, fallback = { x: 1, y: 0 }) => {
      const length = Math.hypot(vector.x, vector.y);

      if (length < 0.001) return fallback;

      return {
        x: vector.x / length,
        y: vector.y / length,
      };
    };

    const getUnionRect = (rects) => {
      const left = Math.min(...rects.map((rect) => rect.left));
      const right = Math.max(...rects.map((rect) => rect.right));
      const top = Math.min(...rects.map((rect) => rect.top));
      const bottom = Math.max(...rects.map((rect) => rect.bottom));

      return {
        bottom,
        height: bottom - top,
        left,
        right,
        top,
        width: right - left,
      };
    };

    const getTextNodeCharacters = (node, textNodes = []) => {
      node.childNodes.forEach((child) => {
        if (child.nodeType === Node.TEXT_NODE) {
          textNodes.push(child);
          return;
        }

        getTextNodeCharacters(child, textNodes);
      });

      return textNodes;
    };

    const toStageRect = (rect, stageRect) => ({
      bottom: rect.bottom - stageRect.top,
      height: rect.height,
      left: rect.left - stageRect.left,
      right: rect.right - stageRect.left,
      top: rect.top - stageRect.top,
      width: rect.width,
    });

    const getMeasuredWordGeometry = (link, stageRect) => {
      const letterRects = [];

      getTextNodeCharacters(link).forEach((textNode) => {
        const text = textNode.textContent || '';

        for (let index = 0; index < text.length; index += 1) {
          if (!text[index] || /\s/.test(text[index])) continue;

          const range = document.createRange();
          range.setStart(textNode, index);
          range.setEnd(textNode, index + 1);

          const rect = range.getBoundingClientRect();
          range.detach?.();

          if (rect.width > 0 && rect.height > 0) {
            letterRects.push(toStageRect(rect, stageRect));
          }
        }
      });

      if (letterRects.length) {
        return {
          letterRects,
          wordRect: getUnionRect(letterRects),
        };
      }

      const wordRect = toStageRect(link.getBoundingClientRect(), stageRect);

      return {
        letterRects: [wordRect],
        wordRect,
      };
    };

    const getRayRectIntersection = (rect, direction) => {
      const center = getRectCenter(rect);
      const candidates = [];

      if (Math.abs(direction.x) > 0.001) {
        const edgeX = direction.x > 0 ? rect.right : rect.left;
        const t = (edgeX - center.x) / direction.x;
        const y = center.y + direction.y * t;

        if (t >= 0 && y >= rect.top - 0.5 && y <= rect.bottom + 0.5) {
          candidates.push({
            point: { x: edgeX, y: clamp(y, rect.top, rect.bottom) },
            t,
          });
        }
      }

      if (Math.abs(direction.y) > 0.001) {
        const edgeY = direction.y > 0 ? rect.bottom : rect.top;
        const t = (edgeY - center.y) / direction.y;
        const x = center.x + direction.x * t;

        if (t >= 0 && x >= rect.left - 0.5 && x <= rect.right + 0.5) {
          candidates.push({
            point: { x: clamp(x, rect.left, rect.right), y: edgeY },
            t,
          });
        }
      }

      candidates.sort((first, second) => first.t - second.t);

      return candidates[0]?.point || center;
    };

    const getWordAnchor = (wordGeometry, targetPoint, padding) => {
      const wordRect = wordGeometry.wordRect;
      const wordCenter = getRectCenter(wordRect);
      const normal = normalizeVector({
        x: targetPoint.x - wordCenter.x,
        y: targetPoint.y - wordCenter.y,
      });
      const reference = getRayRectIntersection(wordRect, normal);

      return {
        normal,
        point: {
          x: reference.x + normal.x * padding,
          y: reference.y + normal.y * padding,
        },
        reference,
      };
    };

    const getMinimumPathDistance = (points, rects) => {
      if (points.length <= 2) return 0;

      return points.slice(1, -1).reduce((minimum, point) => {
        const pointMinimum = rects.reduce(
          (rectMinimum, rect) => Math.min(rectMinimum, getPointRectDistance(point, rect)),
          Number.POSITIVE_INFINITY,
        );

        return Math.min(minimum, pointMinimum);
      }, Number.POSITIVE_INFINITY);
    };

    const getSinusoidalPath = (startAnchor, endAnchor, minDimension, avoidRects = []) => {
      const start = startAnchor.point;
      const end = endAnchor.point;
      const deltaX = end.x - start.x;
      const deltaY = end.y - start.y;
      const distance = Math.max(1, Math.hypot(deltaX, deltaY));
      const direction = {
        x: deltaX / distance,
        y: deltaY / distance,
      };
      const normal = {
        x: -direction.y,
        y: direction.x,
      };
      const sampleCount = Math.round(clamp(distance / 28, 18, 52));
      const handleLength = clamp(distance * 0.15, 24, minDimension * 0.18);
      let bestPoints = null;
      let bestScore = Number.NEGATIVE_INFINITY;

      for (let attempt = 0; attempt < 24; attempt += 1) {
        const amplitude = clamp(distance * randomBetween(0.018, 0.04), 4, minDimension * 0.05);
        const cycles = clamp(distance / (minDimension * randomBetween(0.58, 0.86)), 0.65, 1.55);
        const phase = randomBetween(-0.28, 0.28) * Math.PI;
        const normalPolarity = attempt % 2 === 0 ? 1 : -1;
        const points = [];

        for (let index = 0; index <= sampleCount; index += 1) {
          const t = index / sampleCount;
          const taper = Math.sin(Math.PI * t) ** 2;
          const primary = Math.sin(t * cycles * Math.PI * 2 + phase);
          const secondary = Math.sin(t * (cycles * 0.58 + 0.65) * Math.PI * 2 - phase * 0.45);
          const amplitudeDrift = 0.84 + 0.14 * Math.sin(Math.PI * 2 * t + phase * 0.3);
          const offset = taper * amplitude * normalPolarity * (primary * amplitudeDrift + secondary * 0.14);

          points.push({
            x: start.x + deltaX * t + normal.x * offset,
            y: start.y + deltaY * t + normal.y * offset,
          });
        }

        const minimumDistance = getMinimumPathDistance(points, avoidRects);
        const score = minimumDistance - amplitude * 0.08;

        if (score > bestScore) {
          bestPoints = points;
          bestScore = score;
        }
      }

      const points = bestPoints || [start, end];

      const approximateLength = points.slice(1).reduce((length, point, index) => {
        const previous = points[index];
        return length + Math.hypot(point.x - previous.x, point.y - previous.y);
      }, 0);
      let pathData = `M ${points[0].x.toFixed(2)} ${points[0].y.toFixed(2)}`;
      let cubicLength = 0;

      for (let index = 0; index < points.length - 1; index += 1) {
        const previous = points[index - 1] || points[index];
        const current = points[index];
        const next = points[index + 1];
        const afterNext = points[index + 2] || next;
        const controlOne =
          index === 0
            ? {
                x: current.x + startAnchor.normal.x * handleLength,
                y: current.y + startAnchor.normal.y * handleLength,
              }
            : {
                x: current.x + (next.x - previous.x) / 6,
                y: current.y + (next.y - previous.y) / 6,
              };
        const controlTwo =
          index === points.length - 2
            ? {
                x: next.x + endAnchor.normal.x * handleLength,
                y: next.y + endAnchor.normal.y * handleLength,
              }
            : {
                x: next.x - (afterNext.x - current.x) / 6,
                y: next.y - (afterNext.y - current.y) / 6,
              };

        let previousSample = current;
        for (let sample = 1; sample <= 12; sample += 1) {
          const t = sample / 12;
          const inverseT = 1 - t;
          const samplePoint = {
            x:
              inverseT ** 3 * current.x +
              3 * inverseT ** 2 * t * controlOne.x +
              3 * inverseT * t ** 2 * controlTwo.x +
              t ** 3 * next.x,
            y:
              inverseT ** 3 * current.y +
              3 * inverseT ** 2 * t * controlOne.y +
              3 * inverseT * t ** 2 * controlTwo.y +
              t ** 3 * next.y,
          };

          cubicLength += Math.hypot(samplePoint.x - previousSample.x, samplePoint.y - previousSample.y);
          previousSample = samplePoint;
        }

        pathData += ` C ${controlOne.x.toFixed(2)} ${controlOne.y.toFixed(2)}, ${controlTwo.x.toFixed(
          2,
        )} ${controlTwo.y.toFixed(2)}, ${next.x.toFixed(2)} ${next.y.toFixed(2)}`;
      }

      return {
        length: Math.max(approximateLength, cubicLength) * 1.01,
        pathData,
      };
    };

    const initAuthorRandomLinks = () => {
      const stage = document.querySelector('[data-author-stage]');

      if (!(stage instanceof HTMLElement)) {
        state.cleanup?.();
        return;
      }

      if (stage.dataset.authorRandomBooted === 'true') return;

      state.cleanup?.();
      stage.dataset.authorRandomBooted = 'true';
      stage.classList.remove('is-positioned');
      stage.classList.remove('is-books-visible');
      stage.classList.remove('is-line-drawing');
      stage.classList.remove('is-line-complete');
      stage.classList.remove('is-archives-visible');

      const links = Array.from(stage.querySelectorAll('[data-author-random-link]')).filter(
        (link) => link instanceof HTMLAnchorElement,
      );
      const rootLine = stage.querySelector('[data-author-root-line]');
      let rootPath = stage.querySelector('[data-author-root-path]');

      if (links.length < 2 || !(rootLine instanceof SVGSVGElement)) return;

      let resizeFrame = 0;
      let disposed = false;
      const timers = new Set();
      let lineCompletionCleanup = () => {};

      const clearTimers = () => {
        timers.forEach((timer) => window.clearTimeout(timer));
        timers.clear();
      };

      const setTimer = (callback, delay) => {
        const timer = window.setTimeout(() => {
          timers.delete(timer);
          if (!disposed) callback();
        }, delay);
        timers.add(timer);
      };

      const createRootPath = () => {
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('data-author-root-path', '');
        rootLine.replaceChildren(path);
        rootPath = path;

        return path;
      };

      const getLinkSizes = () =>
        links.map((link) => {
          const rect = link.getBoundingClientRect();
          return {
            height: Math.ceil(rect.height),
            width: Math.ceil(rect.width),
          };
        });

      const getSafeRect = (sizes) => {
        const stageRect = stage.getBoundingClientRect();
        const width = Math.max(stage.clientWidth, Math.round(stageRect.width), window.innerWidth || 0, 1);
        const height = Math.max(stage.clientHeight, Math.round(stageRect.height), window.innerHeight || 0, 1);
        const minDimension = Math.min(width, height);
        const widestLink = Math.max(...sizes.map((size) => size.width));
        const tallestLink = Math.max(...sizes.map((size) => size.height));
        const preferredInset = clamp(minDimension * 0.09, 28, 92);
        const maxInset = Math.max(8, Math.min((width - widestLink) / 2 - 1, (height - tallestLink) / 2 - 1));
        const inset = Math.min(preferredInset, maxInset);

        return {
          bottom: height - inset,
          height,
          inset,
          left: inset,
          minDimension,
          right: width - inset,
          top: inset,
          width,
        };
      };

      const getWordMarginPadding = (safeRect) => {
        if (safeRect.width <= 560) {
          return clamp(safeRect.minDimension * 0.04, 14, 22);
        }

        if (safeRect.width <= 900) {
          return clamp(safeRect.minDimension * 0.035, 18, 26);
        }

        return clamp(safeRect.minDimension * 0.03, 22, 32);
      };

      const getCenterRange = (safeRect, size) => {
        const minX = safeRect.left + size.width / 2;
        const maxX = safeRect.right - size.width / 2;
        const minY = safeRect.top + size.height / 2;
        const maxY = safeRect.bottom - size.height / 2;

        return {
          maxX: Math.max(minX, maxX),
          maxY: Math.max(minY, maxY),
          minX,
          minY,
        };
      };

      const makeCandidate = (safeRect, size) => {
        const range = getCenterRange(safeRect, size);

        return {
          height: size.height,
          width: size.width,
          x: randomBetween(range.minX, range.maxX),
          y: randomBetween(range.minY, range.maxY),
        };
      };

      const getFallbackPlacement = (safeRect, firstSize, secondSize) => {
        const makeCornerCandidates = (size) => {
          const range = getCenterRange(safeRect, size);

          return [
            { height: size.height, width: size.width, x: range.minX, y: range.minY },
            { height: size.height, width: size.width, x: range.maxX, y: range.minY },
            { height: size.height, width: size.width, x: range.minX, y: range.maxY },
            { height: size.height, width: size.width, x: range.maxX, y: range.maxY },
          ];
        };

        let bestPlacement = null;

        makeCornerCandidates(firstSize).forEach((first) => {
          makeCornerCandidates(secondSize).forEach((second) => {
            const gap = getRectGap(getPlacementRect(first), getPlacementRect(second));
            const centerDistance = Math.hypot(second.x - first.x, second.y - first.y);
            const score = gap + centerDistance * 0.35;

            if (!bestPlacement || score > bestPlacement.score) {
              bestPlacement = { first, score, second };
            }
          });
        });

        return bestPlacement ? [bestPlacement.first, bestPlacement.second] : null;
      };

      const getRandomPlacement = () => {
        const sizes = getLinkSizes();
        const safeRect = getSafeRect(sizes);
        const minEdgeGap = safeRect.minDimension * 0.2;
        const minCenterDistance = Math.max(
          safeRect.minDimension * 0.46,
          sizes[0].width / 2 + sizes[1].width / 2 + safeRect.minDimension * 0.22,
        );
        const attempts = 900;

        for (let attempt = 0; attempt < attempts; attempt += 1) {
          const first = makeCandidate(safeRect, sizes[0]);
          const second = makeCandidate(safeRect, sizes[1]);
          const gap = getRectGap(getPlacementRect(first), getPlacementRect(second));
          const centerDistance = Math.hypot(second.x - first.x, second.y - first.y);

          if (gap >= minEdgeGap && centerDistance >= minCenterDistance) {
            return [first, second];
          }
        }

        return getFallbackPlacement(safeRect, sizes[0], sizes[1]);
      };

      const prepareCurve = () => {
        const stageRect = stage.getBoundingClientRect();
        const safeRect = getSafeRect(getLinkSizes());
        const bookGeometry = getMeasuredWordGeometry(links[0], stageRect);
        const archiveGeometry = getMeasuredWordGeometry(links[1], stageRect);
        const wordMarginPadding = getWordMarginPadding(safeRect);
        const bookMarginRect = getPaddedRect(bookGeometry.wordRect, wordMarginPadding);
        const archiveMarginRect = getPaddedRect(archiveGeometry.wordRect, wordMarginPadding);
        const bookCenter = getRectCenter(bookGeometry.wordRect);
        const archiveCenter = getRectCenter(archiveGeometry.wordRect);
        const startAnchor = getWordAnchor(bookGeometry, archiveCenter, wordMarginPadding);
        const endAnchor = getWordAnchor(archiveGeometry, bookCenter, wordMarginPadding);

        const path = createRootPath();
        rootLine.setAttribute('viewBox', `0 0 ${safeRect.width} ${safeRect.height}`);
        rootLine.setAttribute('width', `${safeRect.width}`);
        rootLine.setAttribute('height', `${safeRect.height}`);
        const curve = getSinusoidalPath(startAnchor, endAnchor, safeRect.minDimension, [
          bookMarginRect,
          archiveMarginRect,
        ]);
        path.setAttribute('d', curve.pathData);
        path.style.transition = 'none';
        path.style.opacity = '0';
        path.style.strokeDasharray = '1';
        path.style.strokeDashoffset = '1';

        const pathLength = Math.max(1, path.getTotalLength?.() || curve.length);
        path.style.strokeDasharray = `${pathLength}`;
        path.style.strokeDashoffset = `${pathLength}`;

        return pathLength;
      };

      const resetStage = () => {
        clearTimers();
        lineCompletionCleanup();
        lineCompletionCleanup = () => {};
        stage.classList.remove('is-positioned');
        stage.classList.remove('is-books-visible');
        stage.classList.remove('is-line-drawing');
        stage.classList.remove('is-line-complete');
        stage.classList.remove('is-archives-visible');
        if (rootPath instanceof SVGPathElement) {
          rootPath.style.transition = 'none';
          rootPath.style.opacity = '0';
          rootPath.style.strokeDasharray = '1';
          rootPath.style.strokeDashoffset = '1';
        }
      };

      const positionAndPlay = () => {
        if (disposed) return;

        resetStage();
        const placements = getRandomPlacement();
        if (!placements) return;

        links.slice(0, 2).forEach((link, index) => {
          link.style.setProperty('--author-link-x', `${placements[index].x}px`);
          link.style.setProperty('--author-link-y', `${placements[index].y}px`);
        });

        const pathLength = prepareCurve();
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const booksDelay = prefersReducedMotion ? 68 : 468;
        const lineDelay = prefersReducedMotion ? 306 : 2040;
        const lineDuration = prefersReducedMotion
          ? 468
          : Math.round(clamp(pathLength * 3.06, 1785, 3230));
        const archiveDelay = prefersReducedMotion ? 38 : 156;

        stage.classList.add('is-positioned');

        setTimer(() => {
          stage.classList.add('is-books-visible');
        }, booksDelay);

        setTimer(() => {
          if (!(rootPath instanceof SVGPathElement)) return;

          const drawingPath = rootPath;
          let completedLine = false;
          const revealArchives = () => {
            if (completedLine || disposed) return;

            completedLine = true;
            lineCompletionCleanup();
            lineCompletionCleanup = () => {};
            stage.classList.add('is-line-complete');
            setTimer(() => {
              stage.classList.add('is-archives-visible');
            }, archiveDelay);
          };
          const onLineTransitionEnd = (event) => {
            if (event.target === drawingPath && event.propertyName === 'stroke-dashoffset') {
              revealArchives();
            }
          };

          drawingPath.addEventListener('transitionend', onLineTransitionEnd);
          lineCompletionCleanup = () => {
            drawingPath.removeEventListener('transitionend', onLineTransitionEnd);
          };

          stage.classList.add('is-line-drawing');
          drawingPath.style.opacity = '1';
          drawingPath.getBoundingClientRect();
          drawingPath.style.transition = `stroke-dashoffset ${lineDuration}ms cubic-bezier(0.5, 0, 0.16, 1)`;
          drawingPath.style.strokeDashoffset = '0';

          setTimer(revealArchives, lineDuration + 120);
        }, lineDelay);
      };

      const schedulePositionAndPlay = () => {
        window.cancelAnimationFrame(resizeFrame);
        resizeFrame = window.requestAnimationFrame(positionAndPlay);
      };

      const fontsReady = document.fonts?.ready;
      if (fontsReady && typeof fontsReady.then === 'function') {
        fontsReady.then(positionAndPlay).catch(positionAndPlay);
      } else {
        schedulePositionAndPlay();
      }

      window.addEventListener('resize', schedulePositionAndPlay);
      window.addEventListener('orientationchange', schedulePositionAndPlay);
      state.restart = positionAndPlay;
      state.cleanup = () => {
        disposed = true;
        clearTimers();
        window.cancelAnimationFrame(resizeFrame);
        window.removeEventListener('resize', schedulePositionAndPlay);
        window.removeEventListener('orientationchange', schedulePositionAndPlay);
        links.forEach((link) => {
          link.style.removeProperty('--author-link-x');
          link.style.removeProperty('--author-link-y');
        });
        resetStage();
        delete stage.dataset.authorRandomBooted;
        if (state.restart === positionAndPlay) state.restart = null;
      };
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:before-swap', () => state.cleanup?.());
      document.addEventListener('astro:page-load', initAuthorRandomLinks);
      window.addEventListener('pageshow', (event) => {
        if (event.persisted) state.restart?.();
      });
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAuthorRandomLinks, { once: true });
    } else {
      initAuthorRandomLinks();
    }
  })();
</script>

<style>
  @font-face {
    font-family: 'SF Pro Display Ultralight';
    font-style: normal;
    font-weight: 300;
    src: url('/fonts/SF-Pro-Display-Ultralight.ttf') format('truetype');
    font-display: swap;
  }

  :global(.site-shell) {
    background: #ffffff;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  :global(.site-shell > .site-header),
  :global(.site-shell > .site-footer) {
    display: none;
  }

  :global(.site-shell > main) {
    max-width: none;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    padding: 0;
    width: 100%;
  }

  .author-stage {
    background: #ffffff;
    display: block;
    height: 100vh;
    height: 100svh;
    height: 100dvh;
    isolation: isolate;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .author-root-line {
    display: block;
    height: 100%;
    inset: 0;
    overflow: visible;
    pointer-events: none;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  .author-root-line path {
    fill: none;
    opacity: 0;
    stroke: #691b17;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .author-random-nav {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .author-random-link {
    color: #000000;
    cursor: pointer;
    display: block;
    font-family: 'SF Pro Display Ultralight', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.35rem, 2.1vw, 2.15rem);
    font-weight: 300;
    left: var(--author-link-x, 50%);
    letter-spacing: 0;
