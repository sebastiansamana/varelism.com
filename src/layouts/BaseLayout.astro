---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Website under construction.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <script is:inline>
      (() => {
        const preloaderRoutes = [
          {
            paths: ['/', '/index.html'],
            playOnce: true,
            sessionKey: 'varelism-home-preloader-seen',
          },
          {
            paths: ['/artist/', '/artist'],
            playOnce: true,
            sessionKey: 'varelism-artist-preloader-seen',
          },
          {
            paths: ['/author/', '/author'],
            playOnce: false,
            sessionKey: 'varelism-author-preloader-seen',
          },
        ];
        const route = preloaderRoutes.find(({ paths }) => paths.includes(window.location.pathname));

        if (!route) return;

        let hasPlayed = false;

        try {
          hasPlayed = sessionStorage.getItem(route.sessionKey) === 'true';
        } catch {
          hasPlayed = false;
        }

        if (!route.playOnce || !hasPlayed) {
          document.documentElement.classList.add('home-preloader-active', 'home-preloader-booting');
        }
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="Site navigation">
        <a class="site-logo" href="/" aria-label="Varelism home">
          <span class="image-swap">
            <img class="image-swap__base" src="/images/Samana_Logo_Text.png" alt="Varelism" />
            <img class="image-swap__hover" src="/images/Samana_Logo_Text_Cursor.png" alt="" aria-hidden="true" />
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/contact/">contact</a>
          <a href="/about/">about</a>
          <a class="cart-link" href="/buy/" aria-label="buy">
            <span class="image-swap">
              <img class="image-swap__base" src="/images/Basket.png" alt="" aria-hidden="true" />
              <img class="image-swap__hover" src="/images/Basket_Cursor.png" alt="" aria-hidden="true" />
            </span>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <img src="/images/Triangular_Logo.png" alt="" aria-hidden="true" />
        <p>&copy; 2026 Varelism</p>
      </footer>
    </div>
  </body>
</html>
