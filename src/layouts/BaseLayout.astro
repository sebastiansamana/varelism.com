---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Website under construction.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <script is:inline>
      (() => {
        const preloaderVideoSrc = '/images/Logo_Animation_Preloader.mp4';
        const pendingPreloaderKey = '__varelismPendingPreloaderNavigation';
        const pendingHomeReturnKey = '__varelismPendingHomeReturn';
        const astroNavigateKey = '__varelismAstroNavigate';
        const preloaderCycleDurationMs = 3067;
        const handoffCycleFallbackMs = preloaderCycleDurationMs + 350;
        const handoffMediaFadeMs = 220;
        const handoffBlankHoldMs = 180;
        const homeReturnFadeMs = 260;
        const homeReturnRevealMs = 320;
        const preloaderRoutes = [
          {
            paths: ['/', '/index.html'],
            playOnce: true,
            sessionKey: 'varelism-home-preloader-seen',
          },
          {
            paths: ['/artist/', '/artist'],
            playOnce: true,
            sessionKey: 'varelism-artist-preloader-seen',
          },
          {
            paths: ['/author/', '/author'],
            playOnce: false,
            sessionKey: 'varelism-author-preloader-seen',
          },
        ];
        const standaloneHandoffRoutes = [
          {
            paths: ['/architect/', '/architect'],
          },
        ];
        const triptychHandoffPaths = [
          '/architect/',
          '/architect',
          '/artist/',
          '/artist',
          '/author/',
          '/author',
        ];
        const getPreloaderRoute = (pathname) =>
          preloaderRoutes.find(({ paths }) => paths.includes(pathname));
        const getStandaloneHandoffRoute = (pathname) =>
          standaloneHandoffRoutes.find(({ paths }) => paths.includes(pathname));
        const shouldForceTriptychPreloader = (pathname) => triptychHandoffPaths.includes(pathname);
        const hasRoutePlayed = (route) => {
          try {
            return sessionStorage.getItem(route.sessionKey) === 'true';
          } catch {
            return false;
          }
        };
        const markRoutePlayed = (route) => {
          if (!route?.sessionKey) return;

          try {
            sessionStorage.setItem(route.sessionKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        };
        const shouldPlayPreloader = (route, { force = false } = {}) =>
          Boolean(route && (force || !route.playOnce || !hasRoutePlayed(route)));
        const route = getPreloaderRoute(window.location.pathname);
        let skipNextHomePreloader = false;
        let activeTriptychNavigation = null;
        let activeHomeReturnNavigation = null;

        window.__varelismPreloaderCycleDurationMs = preloaderCycleDurationMs;

        const showPreloaderShell = () => {
          document.documentElement.classList.add('home-preloader-active', 'home-preloader-booting');
        };

        if (shouldPlayPreloader(route)) {
          showPreloaderShell();
        }

        const removeHandoffPreloader = () => {
          document.querySelectorAll('[data-home-preloader-handoff]').forEach((overlay) => {
            overlay.remove();
          });
        };

        const preparePassivePreloaderVideo = (video) => {
          video.controls = false;
          video.muted = true;
          video.defaultMuted = true;
          video.playsInline = true;
          video.preload = 'auto';
          video.disablePictureInPicture = true;
          video.setAttribute('controlsList', 'nodownload noplaybackrate noremoteplayback');
          video.setAttribute('aria-hidden', 'true');
          video.tabIndex = -1;
        };

        const restartHandoffVideo = (video) => {
          preparePassivePreloaderVideo(video);

          try {
            video.pause();
            video.currentTime = 0;
          } catch {
            // Metadata may not be ready yet; autoplay still starts from the beginning on fresh elements.
          }

          try {
            const playAttempt = video.play();

            if (playAttempt?.catch) {
              playAttempt.catch(() => {});
            }
          } catch {
            // If autoplay is rejected, keep the overlay clean and let navigation continue.
          }
        };

        const ensureHandoffPreloader = ({ restart = true } = {}) => {
          const existingOverlay = document.querySelector('[data-home-preloader-handoff]');

          if (existingOverlay instanceof HTMLElement) {
            const existingVideo = existingOverlay.querySelector('video');

            if (restart && existingVideo instanceof HTMLVideoElement) {
              restartHandoffVideo(existingVideo);
            }

            return {
              overlay: existingOverlay,
              video: existingVideo instanceof HTMLVideoElement ? existingVideo : null,
            };
          }

          const overlay = document.createElement('div');
          const video = document.createElement('video');
          const isCompact = window.matchMedia?.('(max-width: 720px)').matches;

          overlay.dataset.homePreloaderHandoff = 'true';
          overlay.setAttribute('aria-hidden', 'true');
          Object.assign(overlay.style, {
            alignItems: 'center',
            background: '#ffffff',
            display: 'flex',
            inset: '0',
            justifyContent: 'center',
            opacity: '1',
            pointerEvents: 'auto',
            position: 'fixed',
            visibility: 'visible',
            zIndex: '9999',
          });

          video.className = 'home-preloader__media';
          video.src = preloaderVideoSrc;
          video.autoplay = true;
          preparePassivePreloaderVideo(video);
          Object.assign(video.style, {
            background: 'transparent',
            display: 'block',
            height: 'auto',
            maxHeight: isCompact ? 'min(28vh, 13rem)' : 'min(34vh, 18rem)',
            maxWidth: isCompact ? 'min(62vw, 16rem)' : 'min(48vw, 22rem)',
            objectFit: 'contain',
            pointerEvents: 'none',
            transition: `opacity ${handoffMediaFadeMs}ms ease`,
            userSelect: 'none',
            width: isCompact ? 'min(62vw, 16rem)' : 'min(48vw, 22rem)',
          });

          overlay.append(video);
          document.body?.append(overlay);

          if (restart) restartHandoffVideo(video);

          return { overlay, video };
        };

        const isSamePath = (pathA, pathB) =>
          pathA === pathB ||
          `${pathA.replace(/\/$/, '')}/` === `${pathB.replace(/\/$/, '')}/`;

        const getPendingPreloaderNavigation = () => window[pendingPreloaderKey] || null;

        const getPendingHomeReturn = () => window[pendingHomeReturnKey] || null;

        const isPendingPreloaderPath = (pathname) => {
          const pendingNavigation = getPendingPreloaderNavigation();

          return Boolean(pendingNavigation?.pathname && isSamePath(pendingNavigation.pathname, pathname));
        };

        const restoreRoutePreloaderShell = () => {
          const pendingNavigation = getPendingPreloaderNavigation();

          if (!pendingNavigation?.keepBootingAfterSwap || !isPendingPreloaderPath(window.location.pathname)) {
            return;
          }

          showPreloaderShell();
        };

        const preparePreloaderNavigation = (url, { force = false, restartHandoff = true } = {}) => {
          const nextRoute = getPreloaderRoute(url.pathname);
          const forceTriptychPreloader = force && shouldForceTriptychPreloader(url.pathname);
          const shouldUseRoutePreloader = shouldPlayPreloader(nextRoute, {
            force: forceTriptychPreloader,
          });
          const standaloneHandoffRoute = getStandaloneHandoffRoute(url.pathname);
          const currentPendingNavigation = getPendingPreloaderNavigation();
          const shouldReuseHandoff = Boolean(
            currentPendingNavigation?.handoffStartedAt &&
              currentPendingNavigation.pathname &&
              isSamePath(currentPendingNavigation.pathname, url.pathname)
          );

          if (!shouldUseRoutePreloader && !standaloneHandoffRoute && !forceTriptychPreloader) {
            window[pendingPreloaderKey] = null;
            return null;
          }

          window[pendingPreloaderKey] = {
            forcePreloader: forceTriptychPreloader,
            handoffCycleComplete:
              shouldReuseHandoff && Boolean(currentPendingNavigation?.handoffCycleComplete),
            handoffCycleDurationMs: currentPendingNavigation?.handoffCycleDurationMs || preloaderCycleDurationMs,
            handoffStartedAt: shouldReuseHandoff
              ? currentPendingNavigation.handoffStartedAt
              : window.performance.now(),
            keepBootingAfterSwap: shouldUseRoutePreloader,
            pathname: url.pathname,
            suppressRoutePreloaderVideo:
              forceTriptychPreloader ||
              Boolean(standaloneHandoffRoute) ||
              (shouldReuseHandoff && Boolean(currentPendingNavigation?.suppressRoutePreloaderVideo)),
          };
          showPreloaderShell();

          return ensureHandoffPreloader({ restart: restartHandoff && !shouldReuseHandoff });
        };

        const continueTriptychNavigation = (url) => {
          const navigate = window[astroNavigateKey];

          if (typeof navigate === 'function') {
            navigate(url.href);
            return;
          }

          window.location.assign(url.href);
        };

        const cancelActiveTriptychNavigation = () => {
          if (activeTriptychNavigation) {
            activeTriptychNavigation.cancelled = true;
            activeTriptychNavigation = null;
          }
        };

        const syncHandoffVideoToPending = (video, pendingNavigation) => {
          if (!(video instanceof HTMLVideoElement) || !pendingNavigation?.handoffStartedAt) return;

          const elapsedSeconds = Math.max(0, (window.performance.now() - pendingNavigation.handoffStartedAt) / 1000);
          const maxSeekTime = Math.max(0, preloaderCycleDurationMs / 1000 - 0.05);
          const targetTime = Math.min(elapsedSeconds, maxSeekTime);

          preparePassivePreloaderVideo(video);
          video.style.opacity = '1';

          const seekAndPlay = () => {
            try {
              video.currentTime = targetTime;
            } catch {
              // If the browser rejects the seek, playback still stays passive and control-free.
            }

            try {
              const playAttempt = video.play();

              if (playAttempt?.catch) {
                playAttempt.catch(() => {});
              }
            } catch {
              // Autoplay failures should not expose native controls.
            }
          };

          if (video.readyState === 0) {
            video.addEventListener('loadedmetadata', seekAndPlay, { once: true });
            video.load();
            return;
          }

          seekAndPlay();
        };

        const restoreActiveHandoffOverlay = () => {
          const pendingNavigation = getPendingPreloaderNavigation();

          if (!pendingNavigation?.handoffStartedAt || pendingNavigation.handoffCycleComplete) return;

          const handoffPreloader = ensureHandoffPreloader({ restart: false });
          syncHandoffVideoToPending(handoffPreloader?.video, pendingNavigation);
        };

        const waitForHandoffCycle = (video) =>
          new Promise((resolve) => {
            if (!(video instanceof HTMLVideoElement)) {
              window.setTimeout(resolve, handoffCycleFallbackMs);
              return;
            }

            let timer = null;
            let didResolve = false;

            const cleanup = () => {
              if (timer) window.clearTimeout(timer);
              video.removeEventListener('ended', done);
              video.removeEventListener('error', done);
              video.removeEventListener('loadedmetadata', refreshFallback);
            };

            const done = () => {
              if (didResolve) return;
              didResolve = true;
              cleanup();
              resolve();
            };

            const refreshFallback = () => {
              if (timer) window.clearTimeout(timer);
              const duration = Number.isFinite(video.duration) && video.duration > 0
                ? Math.ceil(video.duration * 1000) + 180
                : handoffCycleFallbackMs;
              timer = window.setTimeout(done, duration);
            };

            preparePassivePreloaderVideo(video);

            if (video.ended) {
              done();
              return;
            }

            video.addEventListener('ended', done, { once: true });
            video.addEventListener('error', done, { once: true });
            video.addEventListener('loadedmetadata', refreshFallback, { once: true });
            refreshFallback();
          });

        const fadeHandoffToBlank = ({ video } = {}) =>
          new Promise((resolve) => {
            if (video instanceof HTMLVideoElement) {
              video.style.opacity = '0';
            }

            window.setTimeout(resolve, handoffMediaFadeMs + handoffBlankHoldMs);
          });

        const markHandoffCycleComplete = (url) => {
          const pendingNavigation = getPendingPreloaderNavigation();

          if (!pendingNavigation || !isSamePath(pendingNavigation.pathname || '', url.pathname)) return;

          window[pendingPreloaderKey] = {
            ...pendingNavigation,
            handoffCycleComplete: true,
            suppressRoutePreloaderVideo: true,
          };

          window.dispatchEvent(
            new CustomEvent('varelism:handoff-complete', {
              detail: {
                pathname: url.pathname,
              },
            })
          );
        };

        const ensureHomeReturnOverlay = () => {
          const existingOverlay = document.querySelector('[data-home-return-overlay]');

          if (existingOverlay instanceof HTMLElement) return existingOverlay;

          const overlay = document.createElement('div');
          overlay.dataset.homeReturnOverlay = 'true';
          overlay.setAttribute('aria-hidden', 'true');
          Object.assign(overlay.style, {
            background: '#ffffff',
            inset: '0',
            opacity: '0',
            pointerEvents: 'auto',
            position: 'fixed',
            transition: `opacity ${homeReturnFadeMs}ms ease`,
            visibility: 'visible',
            zIndex: '10000',
          });
          document.body?.append(overlay);

          return overlay;
        };

        const showHomeReturnOverlay = () => {
          const overlay = ensureHomeReturnOverlay();

          window.requestAnimationFrame(() => {
            overlay.style.opacity = '1';
          });

          return overlay;
        };

        const revealHomeFromWhite = () => {
          const pendingHomeReturn = getPendingHomeReturn();

          if (!pendingHomeReturn || !isSamePath(window.location.pathname, '/')) return;

          const overlay = ensureHomeReturnOverlay();
          overlay.style.opacity = '1';
          window[pendingHomeReturnKey] = null;
          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              overlay.style.transition = `opacity ${homeReturnRevealMs}ms ease`;
              overlay.style.opacity = '0';
              window.setTimeout(() => {
                overlay.remove();
              }, homeReturnRevealMs);
            });
          });
        };

        const startHomeReturnNavigation = (url) => {
          cancelActiveTriptychNavigation();
          skipNextHomePreloader = true;
          markRoutePlayed(getPreloaderRoute('/'));
          window[pendingPreloaderKey] = null;
          window[pendingHomeReturnKey] = {
            pathname: url.pathname,
          };
          removeHandoffPreloader();

          if (activeHomeReturnNavigation) {
            window.clearTimeout(activeHomeReturnNavigation);
            activeHomeReturnNavigation = null;
          }

          showHomeReturnOverlay();

          activeHomeReturnNavigation = window.setTimeout(() => {
            activeHomeReturnNavigation = null;
            continueTriptychNavigation(url);
          }, homeReturnFadeMs);
        };

        const startTriptychNavigation = (url) => {
          cancelActiveTriptychNavigation();

          const handoffPreloader = preparePreloaderNavigation(url, { force: true });
          const navigation = { cancelled: false };
          activeTriptychNavigation = navigation;

          waitForHandoffCycle(handoffPreloader?.video)
            .then(() => {
              if (navigation.cancelled) return;
              markHandoffCycleComplete(url);
              return fadeHandoffToBlank(ensureHandoffPreloader({ restart: false }));
            })
            .then(() => {
              if (navigation.cancelled) return;
              removeHandoffPreloader();
              if (activeTriptychNavigation === navigation) {
                activeTriptychNavigation = null;
              }
            });

          window.requestAnimationFrame(() => {
            if (navigation.cancelled || activeTriptychNavigation !== navigation) return;
            continueTriptychNavigation(url);
          });
        };

        const listenerKey = '__varelismPreloaderNavigationListeners';

        if (window[listenerKey]) return;

        window[listenerKey] = true;

        document.addEventListener('click', (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey ||
            !(event.target instanceof Element)
          ) {
            return;
          }

          const link = event.target.closest('a[href]');

          if (!(link instanceof HTMLAnchorElement) || (link.target && link.target !== '_self')) {
            return;
          }

          const url = new URL(link.href, window.location.href);

          if (url.origin !== window.location.origin) return;

          const isTriptychLink = Boolean(link.closest('.triptych-item'));

          if (link.closest('.site-logo') && (url.pathname === '/' || url.pathname === '/index.html')) {
            if (isSamePath(window.location.pathname, '/')) return;

            event.preventDefault();
            event.stopImmediatePropagation();
            startHomeReturnNavigation(url);
            return;
          }

          if (isTriptychLink && shouldForceTriptychPreloader(url.pathname)) {
            event.preventDefault();
            event.stopImmediatePropagation();
            startTriptychNavigation(url);
            return;
          }

          preparePreloaderNavigation(url, {
            force: isTriptychLink,
          });
        }, { capture: true });

        document.addEventListener('astro:before-preparation', (event) => {
          const url = event?.to ? new URL(event.to, window.location.href) : null;

          if (!url) return;

          if (skipNextHomePreloader && (url.pathname === '/' || url.pathname === '/index.html')) {
            skipNextHomePreloader = false;
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
            showHomeReturnOverlay();
            return;
          }

          preparePreloaderNavigation(url, {
            force: Boolean(isPendingPreloaderPath(url.pathname) && getPendingPreloaderNavigation()?.forcePreloader),
            restartHandoff: false,
          });
        });

        document.addEventListener('astro:after-swap', () => {
          restoreRoutePreloaderShell();
          restoreActiveHandoffOverlay();
          if (getPendingHomeReturn()) showHomeReturnOverlay();
        });

        document.addEventListener('astro:page-load', () => {
          const currentRoute = getPreloaderRoute(window.location.pathname);
          const standaloneHandoffRoute = getStandaloneHandoffRoute(window.location.pathname);
          const pendingNavigation = getPendingPreloaderNavigation();
          const shouldForceCurrentRoute = Boolean(
            pendingNavigation?.forcePreloader && isPendingPreloaderPath(window.location.pathname)
          );
          const shouldPreloadCurrentRoute = shouldPlayPreloader(currentRoute, {
            force: shouldForceCurrentRoute,
          });

          if (
            !shouldPreloadCurrentRoute &&
            !standaloneHandoffRoute &&
            !document.querySelector('[data-home-preloader]')
          ) {
            document.documentElement.classList.remove('home-preloader-active', 'home-preloader-booting');
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
          }

          revealHomeFromWhite();
        });
      })();
    </script>
    <script>
      import { navigate } from 'astro:transitions/client';

      window.__varelismAstroNavigate = navigate;
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="Site navigation">
        <a class="site-logo" href="/" aria-label="Varelism home">
          <span class="image-swap">
            <img
              class="image-swap__base"
              src="/images/Samana_Logo_Text.png"
              alt="Varelism"
              width="1095"
              height="398"
            />
            <img
              class="image-swap__hover"
              src="/images/Samana_Logo_Text_Cursor.png"
              alt=""
              width="1095"
              height="398"
              aria-hidden="true"
            />
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/contact/">contact</a>
          <a href="/about/">about</a>
          <a class="cart-link" href="/buy/" aria-label="buy">
            <span class="image-swap">
              <img
                class="image-swap__base"
                src="/images/Basket.png"
                alt=""
                width="370"
                height="368"
                aria-hidden="true"
              />
              <img
                class="image-swap__hover"
                src="/images/Basket_Cursor.png"
                alt=""
                width="370"
                height="368"
                aria-hidden="true"
              />
            </span>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <img src="/images/Triangular_Logo.png" alt="" aria-hidden="true" />
        <p>&copy; 2026 Varelism</p>
      </footer>
    </div>
  </body>
</html>
