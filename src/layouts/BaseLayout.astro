---
import { ViewTransitions } from 'astro:transitions';
import HomePreloader from '../components/HomePreloader.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Website under construction.' } = Astro.props;
const isHomeRoute = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const globalPreloaderPaths = [
  '/',
  '/index.html',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link
      rel="preload"
      as="font"
      href="/fonts/SF-Pro-Display-Light.woff2"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      href="/fonts/SF-Pro-Display-Ultralight.woff2"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      href="/fonts/SF-Pro-Display-Thin.woff2"
      type="font/woff2"
      crossorigin
    />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <script is:inline>
      (() => {
        const pendingPreloaderKey = '__varelismPendingPreloaderNavigation';
        const pendingHomeReturnKey = '__varelismPendingHomeReturn';
        const astroNavigateKey = '__varelismAstroNavigate';
        const forceAuthorReplayKey = '__varelismForceAuthorReplay';
        const forceArtistReplayKey = '__varelismForceArtistReplay';
        const authorReturnReplayKey = 'varelism-author-return-replay';
        const artistReturnReplayKey = 'varelism-artist-return-replay';
        const architectReturnReplayKey = 'varelism-architect-return-replay';
        const authorReturnBlankClass = 'author-return-blank-active';
        const artistReturnBlankClass = 'artist-return-blank-active';
        const architectReturnBlankClass = 'architect-return-blank-active';
        const navigationPreloaderClass = 'home-preloader-navigation-active';
        const initialHomePreloaderClass = 'home-preloader-initial-home-active';
        const initialHomeRevealClass = 'home-preloader-initial-home-revealing';
        const navigationScrollLockClass = 'home-preloader-scroll-locked';
        const navigationScrollLockKey = '__varelismNavigationPreloaderScrollLock';
        const architectSceneReadyFlag = '__varelismReady_varelism_architect_scene_ready';
        const homeReturnClass = 'home-return-active';
        const routeEnteringClass = 'varelism-route-entering';
        const routeEnterEvent = 'varelism:route-enter';
        const homeReturnFadeMs = 260;
        const homeReturnRevealMs = 320;
        const routeBlankHoldMs = 70;
        const authorReplayReturnPaths = [
          '/author/books/',
          '/author/books',
          '/author/everything/',
          '/author/everything',
        ];
        const artistReplayReturnPaths = [
          '/artist/exhibitions/',
          '/artist/exhibitions',
          '/artist/everything/',
          '/artist/everything',
        ];
        const architectReplayReturnPaths = [
          '/architect/projects/',
          '/architect/projects',
          '/architect/portfolios/',
          '/architect/portfolios',
        ];
        const isHomePath = (pathname) => pathname === '/' || pathname === '/index.html';
        const isArchitectScenePath = (pathname) => pathname === '/architect/' || pathname === '/architect';
        const clearArchitectSceneReadyFlag = (pathname = window.location.pathname) => {
          if (!isArchitectScenePath(pathname)) return;

          window.__varelismArchitectSceneReady = false;
          window[architectSceneReadyFlag] = false;
        };
        let lastPathname = window.location.pathname;
        let activeOutInNavigation = null;

        clearArchitectSceneReadyFlag();

        const scrollLock = (window[navigationScrollLockKey] ||= {
          cleanup: null,
          isLocked: false,
        });

        const lockNavigationPreloaderScroll = () => {
          scrollLock.cleanup?.();
          scrollLock.cleanup = null;
          scrollLock.isLocked = false;
          document.documentElement.classList.remove(navigationScrollLockClass);
        };

        const unlockNavigationPreloaderScroll = () => {
          scrollLock.cleanup?.();
          scrollLock.cleanup = null;
          scrollLock.isLocked = false;
          document.documentElement.classList.remove(navigationScrollLockClass);
        };

        window.__varelismLockNavigationPreloaderScroll = lockNavigationPreloaderScroll;
        window.__varelismUnlockNavigationPreloaderScroll = unlockNavigationPreloaderScroll;

        const activateNavigationPreloader = () => {
          document.documentElement.classList.add(navigationPreloaderClass);
          lockNavigationPreloaderScroll();
        };

        const deactivateNavigationPreloader = () => {
          document.documentElement.classList.remove(navigationPreloaderClass);
          unlockNavigationPreloaderScroll();
        };

        const clearNavigationPreloaderClassIfIdle = () => {
          if (
            document.querySelector(
              '[data-home-preloader-handoff], [data-home-preloader][data-navigation-preloader="true"]',
            )
          ) {
            return;
          }

          deactivateNavigationPreloader();
        };

        const showPreloaderShell = ({ navigation = false, initialHome = false } = {}) => {
          document.documentElement.classList.add('home-preloader-active', 'home-preloader-booting');
          document.documentElement.classList.remove(initialHomeRevealClass);
          document.documentElement.classList.toggle(initialHomePreloaderClass, Boolean(initialHome));
          if (navigation) {
            activateNavigationPreloader();
          }
        };

        const isInternalHomeReturn =
          isHomePath(window.location.pathname) &&
          Boolean(window[pendingHomeReturnKey] || document.documentElement.classList.contains(homeReturnClass));

        if (isHomePath(window.location.pathname) && !isInternalHomeReturn) {
          showPreloaderShell({ initialHome: isHomePath(window.location.pathname) });
        }

        const removeHandoffPreloader = () => {
          document.querySelectorAll('[data-home-preloader-handoff]').forEach((overlay) => {
            overlay.remove();
          });
          document.documentElement.classList.remove('home-preloader-handoff-active');
          clearNavigationPreloaderClassIfIdle();
        };

        const isSamePath = (pathA, pathB) =>
          pathA === pathB ||
          `${pathA.replace(/\/$/, '')}/` === `${pathB.replace(/\/$/, '')}/`;

        const isAuthorPath = (pathname) => isSamePath(pathname, '/author/');
        const isArchitectPath = (pathname) => isSamePath(pathname, '/architect/');
        const isArtistPath = (pathname) => isSamePath(pathname, '/artist/');
        const isPrimaryHomeReturn = (toPathname, fromPathname) =>
          isHomePath(toPathname) &&
          (isAuthorPath(fromPathname) || isArchitectPath(fromPathname) || isArtistPath(fromPathname));

        const markArchitectReturnReplay = () => {
          try {
            sessionStorage.setItem(architectReturnReplayKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        };

        const markAuthorReturnReplay = () => {
          try {
            sessionStorage.setItem(authorReturnReplayKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        };

        const markArtistReturnReplay = () => {
          try {
            sessionStorage.setItem(artistReturnReplayKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        };

        const hasAuthorReturnReplay = () => {
          try {
            return sessionStorage.getItem(authorReturnReplayKey) === 'true';
          } catch {
            return false;
          }
        };

        const hasArtistReturnReplay = () => {
          try {
            return sessionStorage.getItem(artistReturnReplayKey) === 'true';
          } catch {
            return false;
          }
        };

        const hasArchitectReturnReplay = () => {
          try {
            return sessionStorage.getItem(architectReturnReplayKey) === 'true';
          } catch {
            return false;
          }
        };

        const markAuthorReplayIfNeeded = (toPathname, fromPathname = lastPathname) => {
          if (
            isAuthorPath(toPathname) &&
            (hasAuthorReturnReplay() ||
              authorReplayReturnPaths.some((path) => isSamePath(fromPathname, path)))
          ) {
            window[forceAuthorReplayKey] = true;
            markAuthorReturnReplay();
            document.documentElement.classList.add(authorReturnBlankClass);
            return true;
          }

          return false;
        };

        const markArtistReplayIfNeeded = (toPathname, fromPathname = lastPathname) => {
          if (
            isArtistPath(toPathname) &&
            (hasArtistReturnReplay() ||
              artistReplayReturnPaths.some((path) => isSamePath(fromPathname, path)))
          ) {
            window[forceArtistReplayKey] = true;
            markArtistReturnReplay();
            document.documentElement.classList.add(artistReturnBlankClass);
            return true;
          }

          return false;
        };

        const markArchitectReplayIfNeeded = (toPathname, fromPathname = lastPathname) => {
          if (
            isArchitectPath(toPathname) &&
            (hasArchitectReturnReplay() ||
              architectReplayReturnPaths.some((path) => isSamePath(fromPathname, path)))
          ) {
            markArchitectReturnReplay();
            document.documentElement.classList.add(architectReturnBlankClass);
            return true;
          }

          return false;
        };

        const markAuthorReplayOnExit = (fromPathname, toPathname) => {
          if (
            isAuthorPath(fromPathname) &&
            authorReplayReturnPaths.some((path) => isSamePath(toPathname, path))
          ) {
            markAuthorReturnReplay();
          }
        };

        const markArtistReplayOnExit = (fromPathname, toPathname) => {
          if (
            isArtistPath(fromPathname) &&
            artistReplayReturnPaths.some((path) => isSamePath(toPathname, path))
          ) {
            markArtistReturnReplay();
          }
        };

        const markArchitectReplayOnExit = (fromPathname, toPathname) => {
          if (
            isArchitectPath(fromPathname) &&
            architectReplayReturnPaths.some((path) => isSamePath(toPathname, path))
          ) {
            markArchitectReturnReplay();
          }
        };

        const getPendingPreloaderNavigation = () => window[pendingPreloaderKey] || null;

        const getPendingHomeReturn = () => window[pendingHomeReturnKey] || null;

        const clearActiveOutInNavigation = () => {
          if (activeOutInNavigation?.timer) {
            window.clearTimeout(activeOutInNavigation.timer);
          }

          activeOutInNavigation = null;
        };

        const beginRouteContentTransition = (url) => {
          window[pendingPreloaderKey] = null;
          deactivateNavigationPreloader();
          removeHandoffPreloader();
          window[pendingHomeReturnKey] = {
            pathname: url.pathname,
          };
          showHomeReturnOverlay();
        };

        const hasPendingRouteContentTransition = (url) => {
          const pendingHomeReturn = getPendingHomeReturn();

          return Boolean(pendingHomeReturn?.pathname && isSamePath(pendingHomeReturn.pathname, url.pathname));
        };

        const continueOutInNavigation = (url, options = {}) => {
          const navigate = window[astroNavigateKey];

          if (typeof navigate === 'function') {
            navigate(url.href, options);
            return;
          }

          window.location.assign(url.href);
        };

        const startOutInNavigation = (url, options = {}) => {
          if (isSamePath(window.location.pathname, url.pathname) && window.location.search === url.search && !url.hash) {
            return false;
          }

          clearActiveOutInNavigation();
          beginRouteContentTransition(url);

          activeOutInNavigation = {
            pathname: url.pathname,
            timer: window.setTimeout(() => {
              const navigation = activeOutInNavigation;

              if (!navigation || !isSamePath(navigation.pathname, url.pathname)) return;

              activeOutInNavigation = null;
              continueOutInNavigation(url, options);
            }, homeReturnFadeMs + routeBlankHoldMs),
          };

          return true;
        };

        const clearPreloaderForReturnReplay = () => {
          window[pendingPreloaderKey] = null;
          document.documentElement.classList.remove(
            'home-preloader-active',
            'home-preloader-booting',
            initialHomePreloaderClass,
            initialHomeRevealClass,
          );
          deactivateNavigationPreloader();
          removeHandoffPreloader();
        };

        const ensureHomeReturnOverlay = () => {
          const existingOverlay = document.querySelector('[data-home-return-overlay]');

          document.documentElement.classList.add(homeReturnClass);

          if (existingOverlay instanceof HTMLElement) return existingOverlay;

          const overlay = document.createElement('div');
          overlay.dataset.homeReturnOverlay = 'true';
          overlay.setAttribute('aria-hidden', 'true');
          Object.assign(overlay.style, {
            background: '#ffffff',
            inset: '0',
            opacity: '0',
            pointerEvents: 'none',
            position: 'fixed',
            transition: `opacity ${homeReturnFadeMs}ms ease`,
            visibility: 'visible',
            zIndex: '10',
          });
          document.body?.append(overlay);

          return overlay;
        };

        const showHomeReturnOverlay = () => {
          const overlay = ensureHomeReturnOverlay();

          window.requestAnimationFrame(() => {
            overlay.style.opacity = '1';
          });

          return overlay;
        };

        const waitForRouteTransitionReady = (pathname) =>
          new Promise((resolve) => {
            if (!isArchitectPath(pathname) || window[architectSceneReadyFlag]) {
              resolve();
              return;
            }

            window.addEventListener('varelism:architect-scene-ready', resolve, { once: true });
          });

        const revealRouteFromWhite = () => {
          const pendingHomeReturn = getPendingHomeReturn();

          if (!pendingHomeReturn || !isSamePath(window.location.pathname, pendingHomeReturn.pathname)) return;

          const overlay = ensureHomeReturnOverlay();
          overlay.style.opacity = '1';

          waitForRouteTransitionReady(window.location.pathname).then(() => {
            const currentPendingHomeReturn = getPendingHomeReturn();
            if (
              !currentPendingHomeReturn ||
              !isSamePath(window.location.pathname, currentPendingHomeReturn.pathname)
            ) {
              return;
            }

            window[pendingHomeReturnKey] = null;
            window.requestAnimationFrame(() => {
              window.requestAnimationFrame(() => {
                document.documentElement.classList.remove(routeEnteringClass);
                window.dispatchEvent(
                  new CustomEvent(routeEnterEvent, {
                    detail: {
                      pathname: window.location.pathname,
                    },
                  }),
                );
                overlay.style.transition = `opacity ${homeReturnRevealMs}ms ease`;
                overlay.style.opacity = '0';
                window.setTimeout(() => {
                  overlay.remove();
                  document.documentElement.classList.remove(homeReturnClass);
                }, homeReturnRevealMs);
              });
            });
          });
        };

        const listenerKey = '__varelismPreloaderNavigationListeners';

        if (window[listenerKey]) return;

        window[listenerKey] = true;

        document.addEventListener('click', (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey ||
            !(event.target instanceof Element)
          ) {
            return;
          }

          const link = event.target.closest('a[href]');

          if (!(link instanceof HTMLAnchorElement) || (link.target && link.target !== '_self')) {
            return;
          }

          const url = new URL(link.href, window.location.href);

          if (url.origin !== window.location.origin) return;

          const isReturnReplayNavigation =
            markAuthorReplayIfNeeded(url.pathname, window.location.pathname) ||
            markArtistReplayIfNeeded(url.pathname, window.location.pathname) ||
            markArchitectReplayIfNeeded(url.pathname, window.location.pathname);

          markArchitectReplayOnExit(window.location.pathname, url.pathname);
          markArtistReplayOnExit(window.location.pathname, url.pathname);
          markAuthorReplayOnExit(window.location.pathname, url.pathname);

          if (isReturnReplayNavigation) {
            clearPreloaderForReturnReplay();
          }

          if (link.dataset.astroReload !== undefined || link.hasAttribute('download')) {
            return;
          }

          if (
            startOutInNavigation(url, {
              history: link.dataset.astroHistory === 'replace' ? 'replace' : 'auto',
              sourceElement: link,
            })
          ) {
            event.preventDefault();
            event.stopImmediatePropagation();
          }
        }, { capture: true });

        document.addEventListener('astro:before-preparation', (event) => {
          const url = event?.to ? new URL(event.to, window.location.href) : null;

          if (!url) return;

          const isReturnReplayNavigation =
            markAuthorReplayIfNeeded(url.pathname, window.location.pathname) ||
            markArtistReplayIfNeeded(url.pathname, window.location.pathname) ||
            markArchitectReplayIfNeeded(url.pathname, window.location.pathname);
          markArchitectReplayOnExit(window.location.pathname, url.pathname);
          markArtistReplayOnExit(window.location.pathname, url.pathname);
          markAuthorReplayOnExit(window.location.pathname, url.pathname);

          if (!hasPendingRouteContentTransition(url)) {
            beginRouteContentTransition(url);
          }

          if (isReturnReplayNavigation) {
            clearPreloaderForReturnReplay();
            return;
          }
        });

        document.addEventListener('astro:before-swap', (event) => {
          const pendingHomeReturn = getPendingHomeReturn();
          const nextDocument = event?.newDocument;

          if (pendingHomeReturn && nextDocument?.documentElement) {
            nextDocument.documentElement.classList.add(routeEnteringClass, homeReturnClass);
          }
        });

        document.addEventListener('astro:after-swap', () => {
          const isReturnReplayNavigation =
            markAuthorReplayIfNeeded(window.location.pathname) ||
            markArtistReplayIfNeeded(window.location.pathname) ||
            markArchitectReplayIfNeeded(window.location.pathname);
          if (isReturnReplayNavigation) {
            clearPreloaderForReturnReplay();
          }
          if (getPendingHomeReturn()) {
            document.documentElement.classList.add(routeEnteringClass, homeReturnClass);
            showHomeReturnOverlay();
          }
        });

        document.addEventListener('astro:page-load', () => {
          if (!document.querySelector('[data-home-preloader]')) {
            document.documentElement.classList.remove(
              'home-preloader-active',
              'home-preloader-booting',
              initialHomePreloaderClass,
              initialHomeRevealClass,
            );
            deactivateNavigationPreloader();
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
            clearNavigationPreloaderClassIfIdle();
          }

          revealRouteFromWhite();
          clearActiveOutInNavigation();
          lastPathname = window.location.pathname;
        });

        window.addEventListener('popstate', () => {
          beginRouteContentTransition(new URL(window.location.href));

          const isReturnReplayNavigation =
            markAuthorReplayIfNeeded(window.location.pathname) ||
            markArtistReplayIfNeeded(window.location.pathname) ||
            markArchitectReplayIfNeeded(window.location.pathname);
          if (isReturnReplayNavigation) {
            clearPreloaderForReturnReplay();
          }
        });
      })();
    </script>
    <script>
      import { navigate } from 'astro:transitions/client';

      window.__varelismAstroNavigate = navigate;
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header
        class="site-header"
        aria-label="Site navigation"
        data-astro-transition-persist="varelism-site-header"
      >
        <a class="site-logo" href="/" aria-label="Varelism home">
          <span class="image-swap">
            <img
              class="image-swap__base"
              src="/images/Samana_Logo_Text.png"
              alt="Varelism"
              width="1095"
              height="398"
            />
            <img
              class="image-swap__hover"
              src="/images/Samana_Logo_Text_Cursor.png"
              alt=""
              width="1095"
              height="398"
              aria-hidden="true"
            />
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/contact/">contact</a>
          <a href="/about/">about</a>
          <a class="cart-link" href="/buy/" aria-label="buy">
            <span class="image-swap">
              <img
                class="image-swap__base"
                src="/images/Basket.png"
                alt=""
                width="370"
                height="368"
                aria-hidden="true"
              />
              <img
                class="image-swap__hover"
                src="/images/Basket_Cursor.png"
                alt=""
                width="370"
                height="368"
                aria-hidden="true"
              />
            </span>
          </a>
        </nav>
      </header>
      <main>
        {
          isHomeRoute && (
            <HomePreloader
              activePaths={globalPreloaderPaths}
              playOnce={false}
              sessionKey="varelism-global-preloader-seen"
            />
          )
        }
        <slot />
      </main>
      <footer class="site-footer">
        <img src="/images/Triangular_Logo.png" alt="" aria-hidden="true" />
        <p>&copy; 2026 Varelism</p>
      </footer>
    </div>
  </body>
</html>
