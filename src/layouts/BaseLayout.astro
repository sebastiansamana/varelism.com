---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Website under construction.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <script is:inline>
      (() => {
        const preloaderImageSrc = '/images/Logo_Animation_Preloader.gif';
        const pendingPreloaderKey = '__varelismPendingPreloaderNavigation';
        const astroNavigateKey = '__varelismAstroNavigate';
        const triptychHandoffDelayMs = 950;
        const preloaderRoutes = [
          {
            paths: ['/', '/index.html'],
            playOnce: true,
            sessionKey: 'varelism-home-preloader-seen',
          },
          {
            paths: ['/artist/', '/artist'],
            playOnce: true,
            sessionKey: 'varelism-artist-preloader-seen',
          },
          {
            paths: ['/author/', '/author'],
            playOnce: false,
            sessionKey: 'varelism-author-preloader-seen',
          },
        ];
        const standaloneHandoffRoutes = [
          {
            paths: ['/architect/', '/architect'],
          },
        ];
        const triptychHandoffPaths = [
          '/architect/',
          '/architect',
          '/artist/',
          '/artist',
          '/author/',
          '/author',
        ];
        const getPreloaderRoute = (pathname) =>
          preloaderRoutes.find(({ paths }) => paths.includes(pathname));
        const getStandaloneHandoffRoute = (pathname) =>
          standaloneHandoffRoutes.find(({ paths }) => paths.includes(pathname));
        const shouldForceTriptychPreloader = (pathname) => triptychHandoffPaths.includes(pathname);
        const hasRoutePlayed = (route) => {
          try {
            return sessionStorage.getItem(route.sessionKey) === 'true';
          } catch {
            return false;
          }
        };
        const markRoutePlayed = (route) => {
          if (!route?.sessionKey) return;

          try {
            sessionStorage.setItem(route.sessionKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        };
        const shouldPlayPreloader = (route, { force = false } = {}) =>
          Boolean(route && (force || !route.playOnce || !hasRoutePlayed(route)));
        const route = getPreloaderRoute(window.location.pathname);
        let skipNextHomePreloader = false;
        let activeTriptychNavigation = null;
        let preloaderRunId = 0;

        const showPreloaderShell = () => {
          document.documentElement.classList.add('home-preloader-active', 'home-preloader-booting');
        };

        if (shouldPlayPreloader(route)) {
          showPreloaderShell();
        }

        const removeHandoffPreloader = () => {
          document.querySelectorAll('[data-home-preloader-handoff]').forEach((overlay) => {
            overlay.remove();
          });
        };

        const getRestartedPreloaderSrc = () => {
          const url = new URL(preloaderImageSrc, window.location.origin);
          preloaderRunId += 1;
          url.searchParams.set('run', `${Date.now()}-${preloaderRunId}`);

          return `${url.pathname}${url.search}`;
        };

        const ensureHandoffPreloader = () => {
          const existingOverlay = document.querySelector('[data-home-preloader-handoff]');

          if (existingOverlay instanceof HTMLElement) {
            const existingImage = existingOverlay.querySelector('img');

            if (existingImage instanceof HTMLImageElement) {
              existingImage.src = getRestartedPreloaderSrc();
            }

            return;
          }

          const overlay = document.createElement('div');
          const image = document.createElement('img');
          const isCompact = window.matchMedia?.('(max-width: 720px)').matches;

          overlay.dataset.homePreloaderHandoff = 'true';
          overlay.setAttribute('aria-hidden', 'true');
          Object.assign(overlay.style, {
            alignItems: 'center',
            background: '#ffffff',
            display: 'flex',
            inset: '0',
            justifyContent: 'center',
            opacity: '1',
            pointerEvents: 'auto',
            position: 'fixed',
            visibility: 'visible',
            zIndex: '9999',
          });

          image.alt = '';
          image.decoding = 'async';
          image.draggable = false;
          image.loading = 'eager';
          image.src = getRestartedPreloaderSrc();
          Object.assign(image.style, {
            display: 'block',
            height: 'auto',
            maxHeight: isCompact ? 'min(28vh, 13rem)' : 'min(34vh, 18rem)',
            maxWidth: isCompact ? 'min(62vw, 16rem)' : 'min(48vw, 22rem)',
            objectFit: 'contain',
            width: isCompact ? 'min(62vw, 16rem)' : 'min(48vw, 22rem)',
          });

          overlay.append(image);
          document.body?.append(overlay);
        };

        const isSamePath = (pathA, pathB) =>
          pathA === pathB ||
          `${pathA.replace(/\/$/, '')}/` === `${pathB.replace(/\/$/, '')}/`;

        const getPendingPreloaderNavigation = () => window[pendingPreloaderKey] || null;

        const isPendingPreloaderPath = (pathname) => {
          const pendingNavigation = getPendingPreloaderNavigation();

          return Boolean(pendingNavigation?.pathname && isSamePath(pendingNavigation.pathname, pathname));
        };

        const restoreRoutePreloaderShell = () => {
          const pendingNavigation = getPendingPreloaderNavigation();

          if (!pendingNavigation?.keepBootingAfterSwap || !isPendingPreloaderPath(window.location.pathname)) {
            return;
          }

          showPreloaderShell();
        };

        const preparePreloaderNavigation = (url, { force = false } = {}) => {
          const nextRoute = getPreloaderRoute(url.pathname);
          const forceTriptychPreloader = force && shouldForceTriptychPreloader(url.pathname);
          const shouldUseRoutePreloader = shouldPlayPreloader(nextRoute, {
            force: forceTriptychPreloader,
          });
          const standaloneHandoffRoute = getStandaloneHandoffRoute(url.pathname);

          if (!shouldUseRoutePreloader && !standaloneHandoffRoute && !forceTriptychPreloader) {
            window[pendingPreloaderKey] = null;
            return;
          }

          window[pendingPreloaderKey] = {
            forcePreloader: forceTriptychPreloader,
            keepBootingAfterSwap: shouldUseRoutePreloader,
            pathname: url.pathname,
          };
          showPreloaderShell();
          ensureHandoffPreloader();
        };

        const continueTriptychNavigation = (url) => {
          const navigate = window[astroNavigateKey];

          if (typeof navigate === 'function') {
            navigate(url.href);
            return;
          }

          window.location.assign(url.href);
        };

        const startTriptychNavigation = (url) => {
          if (activeTriptychNavigation) {
            window.clearTimeout(activeTriptychNavigation);
            activeTriptychNavigation = null;
          }

          preparePreloaderNavigation(url, { force: true });

          activeTriptychNavigation = window.setTimeout(() => {
            activeTriptychNavigation = null;
            continueTriptychNavigation(url);
          }, triptychHandoffDelayMs);
        };

        const listenerKey = '__varelismPreloaderNavigationListeners';

        if (window[listenerKey]) return;

        window[listenerKey] = true;

        document.addEventListener('click', (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey ||
            !(event.target instanceof Element)
          ) {
            return;
          }

          const link = event.target.closest('a[href]');

          if (!(link instanceof HTMLAnchorElement) || (link.target && link.target !== '_self')) {
            return;
          }

          const url = new URL(link.href, window.location.href);

          if (url.origin !== window.location.origin) return;

          const isTriptychLink = Boolean(link.closest('.triptych-item'));

          if (link.closest('.site-logo') && (url.pathname === '/' || url.pathname === '/index.html')) {
            skipNextHomePreloader = true;
            markRoutePlayed(getPreloaderRoute('/'));
            if (activeTriptychNavigation) {
              window.clearTimeout(activeTriptychNavigation);
              activeTriptychNavigation = null;
            }
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
            return;
          }

          if (isTriptychLink && shouldForceTriptychPreloader(url.pathname)) {
            event.preventDefault();
            event.stopImmediatePropagation();
            startTriptychNavigation(url);
            return;
          }

          preparePreloaderNavigation(url, {
            force: isTriptychLink,
          });
        }, { capture: true });

        document.addEventListener('astro:before-preparation', (event) => {
          const url = event?.to ? new URL(event.to, window.location.href) : null;

          if (!url) return;

          if (skipNextHomePreloader && (url.pathname === '/' || url.pathname === '/index.html')) {
            skipNextHomePreloader = false;
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
            return;
          }

          preparePreloaderNavigation(url, {
            force: Boolean(isPendingPreloaderPath(url.pathname) && getPendingPreloaderNavigation()?.forcePreloader),
          });
        });

        document.addEventListener('astro:after-swap', restoreRoutePreloaderShell);

        document.addEventListener('astro:page-load', () => {
          const currentRoute = getPreloaderRoute(window.location.pathname);
          const pendingNavigation = getPendingPreloaderNavigation();
          const shouldForceCurrentRoute = Boolean(
            pendingNavigation?.forcePreloader && isPendingPreloaderPath(window.location.pathname)
          );
          const shouldPreloadCurrentRoute = shouldPlayPreloader(currentRoute, {
            force: shouldForceCurrentRoute,
          });

          if (!shouldPreloadCurrentRoute && !document.querySelector('[data-home-preloader]')) {
            document.documentElement.classList.remove('home-preloader-active', 'home-preloader-booting');
            window[pendingPreloaderKey] = null;
            removeHandoffPreloader();
          }
        });
      })();
    </script>
    <script>
      import { navigate } from 'astro:transitions/client';

      window.__varelismAstroNavigate = navigate;
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="Site navigation">
        <a class="site-logo" href="/" aria-label="Varelism home">
          <span class="image-swap">
            <img class="image-swap__base" src="/images/Samana_Logo_Text.png" alt="Varelism" />
            <img class="image-swap__hover" src="/images/Samana_Logo_Text_Cursor.png" alt="" aria-hidden="true" />
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/contact/">contact</a>
          <a href="/about/">about</a>
          <a class="cart-link" href="/buy/" aria-label="buy">
            <span class="image-swap">
              <img class="image-swap__base" src="/images/Basket.png" alt="" aria-hidden="true" />
              <img class="image-swap__hover" src="/images/Basket_Cursor.png" alt="" aria-hidden="true" />
            </span>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <img src="/images/Triangular_Logo.png" alt="" aria-hidden="true" />
        <p>&copy; 2026 Varelism</p>
      </footer>
    </div>
  </body>
</html>
