---
interface Props {
  imageAlt: string;
  label: string;
  paragraphs: string[];
}

const { imageAlt, label, paragraphs } = Astro.props;
---

<section class="about-composition" aria-label={label} data-about-composition>
  <figure class="about-portrait">
    <img
      src="/images/about_me_v2.png"
      alt={imageAlt}
      width="1254"
      height="1254"
      loading="eager"
      decoding="async"
    />
  </figure>

  <div class="about-text">
    {
      paragraphs.map((paragraph) => (
        <p class:list={{ 'about-samana': paragraph === 'Samana.' }}>{paragraph}</p>
      ))
    }
  </div>
</section>

<script>
  (() => {
    const revealTextDelayMs = 750;
    const routeEnterEvent = 'varelism:route-enter';
    const routeEnteringClass = 'varelism-route-entering';

    const revealAbout = () => {
      const composition = document.querySelector('[data-about-composition]');

      if (!(composition instanceof HTMLElement) || composition.dataset.aboutRevealBooted === 'true') {
        return;
      }

      composition.dataset.aboutRevealBooted = 'true';

      const reveal = () => {
        composition.classList.add('is-portrait-visible');
        window.setTimeout(() => {
          composition.classList.add('is-text-visible');
        }, revealTextDelayMs);
      };

      if (document.documentElement.classList.contains(routeEnteringClass)) {
        window.addEventListener(routeEnterEvent, reveal, { once: true });
        return;
      }

      reveal();
    };

    revealAbout();

    if (window.__varelismAboutRevealReady) return;

    window.__varelismAboutRevealReady = true;
    document.addEventListener('astro:page-load', revealAbout);
  })();
</script>

<style>
  .about-composition {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    max-width: min(100%, 58rem);
    padding: clamp(2.2rem, 6vh, 4.8rem) 0 clamp(1.4rem, 4vh, 3rem);
  }

  .about-portrait {
    display: flex;
    flex-direction: column;
    margin: 0;
    opacity: 0;
    transition: opacity 450ms ease;
    width: clamp(9.0625rem, 13.75vw, 12.1875rem);
  }

  .about-portrait img {
    display: block;
    height: auto;
    max-width: 100%;
    object-fit: contain;
    width: 100%;
  }

  .about-text {
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      'Helvetica Neue', Arial, sans-serif;
    font-size: 1.08rem;
    font-weight: 200;
    letter-spacing: 0;
    line-height: 1.58;
    margin-top: calc(
      clamp(6rem, 12vh, 8rem) + clamp(2.2rem, 6vh, 4.8rem) -
        clamp(1.1rem, 2.4vw, 2.1rem) - clamp(1.1rem, 2.4vw, 2.1rem) -
        clamp(1.25rem, 2.125vw, 1.75rem)
    );
    max-width: min(100%, 51rem);
    opacity: 0;
    text-align: left;
    transition: opacity 450ms ease;
    width: 100%;
  }

  .about-composition.is-portrait-visible .about-portrait,
  .about-composition.is-text-visible .about-text {
    opacity: 1;
  }

  .about-text p {
    margin: 0 0 1.18rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  .about-samana {
    color: #691b17;
  }

  @media (max-width: 720px) {
    .about-composition {
      padding-top: clamp(1.6rem, 4vh, 2.5rem);
    }

    .about-portrait {
      width: clamp(7.8125rem, 31.25vw, 9.375rem);
    }

    .about-text {
      font-size: 0.98rem;
      line-height: 1.55;
      margin-top: calc(
        clamp(6rem, 12vh, 8rem) + clamp(1.6rem, 4vh, 2.5rem) -
          clamp(1.1rem, 2.4vw, 2.1rem) - clamp(1.1rem, 2.4vw, 2.1rem) -
          clamp(1.25rem, 2.125vw, 1.75rem)
      );
    }
  }

  @media (max-width: 560px) {
    .about-text {
      margin-top: calc(5rem + clamp(1.6rem, 4vh, 2.5rem) - 1rem - 1rem - 1.0625rem);
    }
  }
</style>
