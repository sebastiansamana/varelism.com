---
interface Props {
  caption: string;
  imageAlt: string;
  label: string;
  paragraphs: string[];
  signature: string;
}

const { caption, imageAlt, label, paragraphs, signature } = Astro.props;
---

<section class="about-composition" aria-label={label}>
  <figure class="about-portrait">
    <img
      src="/images/about_me.jpeg"
      alt={imageAlt}
      width="2862"
      height="3248"
      loading="eager"
      decoding="async"
    />
    <figcaption>{caption}</figcaption>
  </figure>

  <div class="about-text">
    {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    <p class="about-signature">{signature}</p>
  </div>
</section>

<style>
  .about-composition {
    align-items: center;
    color: #000000;
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    max-width: min(100%, 58rem);
    padding: clamp(2.2rem, 6vh, 4.8rem) 0 clamp(1.4rem, 4vh, 3rem);
  }

  .about-portrait {
    display: flex;
    flex-direction: column;
    margin: 0;
    width: clamp(7.25rem, 11vw, 9.75rem);
  }

  .about-portrait img {
    display: block;
    height: auto;
    max-width: 100%;
    object-fit: contain;
    width: 100%;
  }

  .about-portrait figcaption {
    color: #919191;
    font-family: inherit;
    font-size: 0.58rem;
    font-weight: 200;
    line-height: 1;
    margin-top: 0.35rem;
    text-align: right;
  }

  .about-text {
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      'Helvetica Neue', Arial, sans-serif;
    font-size: 1.08rem;
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1.58;
    margin-top: clamp(2.4rem, 5vh, 4rem);
    max-width: min(100%, 51rem);
    text-align: left;
    width: 100%;
  }

  .about-text p {
    margin: 0 0 1.18rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  .about-signature {
    padding-top: 0.15rem;
  }

  @media (max-width: 720px) {
    .about-composition {
      padding-top: clamp(1.6rem, 4vh, 2.5rem);
    }

    .about-portrait {
      width: clamp(6.25rem, 25vw, 7.5rem);
    }

    .about-text {
      font-size: 0.98rem;
      line-height: 1.55;
      margin-top: clamp(2rem, 4.5vh, 2.8rem);
    }
  }
</style>
