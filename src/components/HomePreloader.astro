---
interface Props {
  activePaths?: string[];
  completeEvent?: string;
  playOnce?: boolean;
  sessionKey?: string;
  timingScale?: number;
}

const videoSrc = '/videos/Logo_Animation_Preloader.mp4';
const {
  activePaths = ['/', '/index.html'],
  completeEvent = 'varelism:preloader-complete',
  playOnce = true,
  sessionKey = 'varelism-home-preloader-seen',
  timingScale = 1,
} = Astro.props;
---

<div
  class="home-preloader"
  data-home-preloader
  data-active-paths={activePaths.join('|')}
  data-complete-event={completeEvent}
  data-play-once={playOnce ? 'true' : 'false'}
  data-session-key={sessionKey}
  data-timing-scale={timingScale}
  aria-hidden="true"
>
  <video
    class="home-preloader__video"
    src={videoSrc}
    autoplay
    muted
    playsinline
    loop
    preload="auto"
  ></video>
</div>

<script is:inline>
  (() => {
    const stateKey = '__varelismHomePreloader';
    const state = (window[stateKey] ||= {
      listenersAttached: false,
    });

    const initOverlay = (overlay) => {
      if (!(overlay instanceof HTMLElement) || overlay.dataset.homePreloaderBooted === 'true') return;

      overlay.dataset.homePreloaderBooted = 'true';

      const sessionKey = overlay.dataset.sessionKey || 'varelism-home-preloader-seen';
      const completeEvent = overlay.dataset.completeEvent || 'varelism:preloader-complete';
      const activePaths = (overlay.dataset.activePaths || '/|/index.html').split('|').filter(Boolean);
      const playOnce = overlay.dataset.playOnce !== 'false';
      const timingScale = Math.max(0.1, Number.parseFloat(overlay.dataset.timingScale || '1') || 1);
      const videoVisibleMs = Math.round(3000 * timingScale);
      const videoFadeMs = Math.round(300 * timingScale);
      const whiteHoldMs = Math.round(300 * timingScale);
      const overlayFadeMs = Math.round(300 * timingScale);
      const fallbackMs = Math.round(10000 * timingScale);
      const isActivePath = activePaths.includes(window.location.pathname);
      let hasRemoved = false;
      const storage = {
        get() {
          try {
            return sessionStorage.getItem(sessionKey);
          } catch {
            return null;
          }
        },
        set() {
          try {
            sessionStorage.setItem(sessionKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        },
      };

      const removeOverlay = () => {
        if (hasRemoved) return;
        hasRemoved = true;
        overlay.remove();
        document.documentElement.classList.remove('home-preloader-active');
        window.dispatchEvent(new CustomEvent(completeEvent));
      };

      if (!isActivePath || (playOnce && storage.get() === 'true')) {
        removeOverlay();
        return;
      }

      if (playOnce) storage.set();
      document.documentElement.classList.add('home-preloader-active');
      overlay.classList.add('is-visible');

      let isPageReady = document.readyState === 'complete';
      let hasMetVideoDuration = false;
      let isHiding = false;

      const hideOverlay = () => {
        if (isHiding || !isPageReady || !hasMetVideoDuration) return;

        isHiding = true;
        overlay.classList.add('is-video-fading');
        window.setTimeout(() => {
          overlay.classList.add('is-overlay-fading');
          window.setTimeout(removeOverlay, overlayFadeMs);
        }, videoFadeMs + whiteHoldMs);
      };

      window.setTimeout(() => {
        hasMetVideoDuration = true;
        hideOverlay();
      }, videoVisibleMs);

      const fallbackTimer = window.setTimeout(() => {
        isPageReady = true;
        hasMetVideoDuration = true;
        hideOverlay();
      }, fallbackMs);

      if (document.readyState === 'complete') {
        hideOverlay();
      } else {
        window.addEventListener(
          'load',
          () => {
            isPageReady = true;
            window.clearTimeout(fallbackTimer);
            hideOverlay();
          },
          { once: true },
        );
      }
    };

    const initPreloaders = () => {
      document.querySelectorAll('[data-home-preloader]').forEach(initOverlay);
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:page-load', initPreloaders);
      document.addEventListener('astro:before-swap', () => {
        document.documentElement.classList.remove('home-preloader-active');
      });
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPreloaders, { once: true });
    } else {
      initPreloaders();
    }
  })();
</script>

<style>
  .home-preloader {
    align-items: center;
    background: #ffffff;
    display: flex;
    inset: 0;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 300ms ease, visibility 300ms ease;
    visibility: hidden;
    z-index: 9999;
  }

  .home-preloader.is-visible {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .home-preloader.is-overlay-fading {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .home-preloader__video {
    display: block;
    height: auto;
    max-height: min(34vh, 18rem);
    max-width: min(48vw, 22rem);
    object-fit: contain;
    opacity: 1;
    transition: opacity 300ms ease;
    width: min(48vw, 22rem);
  }

  .home-preloader.is-video-fading .home-preloader__video {
    opacity: 0;
  }

  :global(html.home-preloader-active),
  :global(html.home-preloader-active body) {
    overflow: hidden;
  }

  @media (max-width: 720px) {
    .home-preloader__video {
      max-height: min(28vh, 13rem);
      max-width: min(62vw, 16rem);
      width: min(62vw, 16rem);
    }
  }
</style>
