---
interface Props {
  activePaths?: string[];
  completeEvent?: string;
  imageFadeMs?: number;
  overlayFadeMs?: number;
  playOnce?: boolean;
  readyEvents?: string;
  sessionKey?: string;
  timingScale?: number;
  whiteHoldMs?: number;
}

const videoSrc = '/images/Logo_Animation_Preloader.mp4';
const fallbackSrc = '/images/Logo_Animation_Preloader.webp';
const {
  activePaths = ['/', '/index.html', '/architect/', '/architect', '/artist/', '/artist', '/author/', '/author'],
  completeEvent = 'varelism:preloader-complete',
  imageFadeMs,
  overlayFadeMs,
  playOnce = true,
  readyEvents = '',
  sessionKey = 'varelism-home-preloader-seen',
  timingScale = 1,
  whiteHoldMs,
} = Astro.props;
---

<div
  class="home-preloader"
  data-home-preloader
  data-active-paths={activePaths.join('|')}
  data-complete-event={completeEvent}
  data-image-fade-ms={imageFadeMs}
  data-overlay-fade-ms={overlayFadeMs}
  data-play-once={playOnce ? 'true' : 'false'}
  data-ready-events={readyEvents}
  data-session-key={sessionKey}
  data-timing-scale={timingScale}
  data-white-hold-ms={whiteHoldMs}
  aria-hidden="true"
>
  <video
    class="home-preloader__media"
    src={videoSrc}
    autoplay
    defaultMuted
    muted
    playsinline
    webkit-playsinline
    preload="auto"
    disablePictureInPicture
    controlsList="nodownload noplaybackrate noremoteplayback"
    aria-hidden="true"
    tabindex="-1"
  ></video>
  <img
    class="home-preloader__fallback"
    src={fallbackSrc}
    alt=""
    width="960"
    height="666"
    decoding="async"
    loading="eager"
    aria-hidden="true"
  />
</div>

<script is:inline>
  (() => {
    const stateKey = '__varelismHomePreloader';
    const pendingPreloaderKey = '__varelismPendingPreloaderNavigation';
    const activeHandoffKey = '__varelismActivePreloaderHandoff';
    const navigationPreloaderClass = 'home-preloader-navigation-active';
    const initialHomePreloaderClass = 'home-preloader-initial-home-active';
    const initialHomeRevealClass = 'home-preloader-initial-home-revealing';
    const state = (window[stateKey] ||= {
      cleanups: new Set(),
      listenersAttached: false,
    });
    state.cleanups ||= new Set();

    const clearPendingPreloaderNavigation = () => {
      window[pendingPreloaderKey] = null;
    };

    const shouldKeepBootingAfterSwap = () =>
      Boolean(window[pendingPreloaderKey]?.keepBootingAfterSwap);

    const shouldPreservePendingHandoffAfterSwap = () =>
      Boolean(
        window[activeHandoffKey]?.startedAt ||
          (window[pendingPreloaderKey]?.suppressRoutePreloaderVideo &&
            window[pendingPreloaderKey]?.handoffStartedAt)
      );

    const clearNavigationPreloaderClassIfIdle = () => {
      if (
        document.querySelector(
          '[data-home-preloader-handoff], [data-home-preloader][data-navigation-preloader="true"]'
        )
      ) {
        return;
      }

      document.documentElement.classList.remove(navigationPreloaderClass);
      window.__varelismUnlockNavigationPreloaderScroll?.();
    };

    const isSamePath = (pathA, pathB) =>
      pathA === pathB ||
      `${pathA.replace(/\/$/, '')}/` === `${pathB.replace(/\/$/, '')}/`;

    const getRouteCompleteEvents = (pathname) => {
      if (isSamePath(pathname, '/author/')) return ['varelism:author-preloader-complete'];
      if (isSamePath(pathname, '/artist/')) return ['varelism:artist-preloader-complete'];
      if (isSamePath(pathname, '/architect/')) return ['varelism:architect-preloader-complete'];
      return [];
    };

    const getDocumentScrollY = () =>
      Math.max(
        0,
        window.scrollY ||
          document.documentElement.scrollTop ||
          document.body?.scrollTop ||
          0
      );

    const getReadyFlagKey = (eventName) =>
      `__varelismReady_${eventName.replace(/[^a-zA-Z0-9_$]/g, '_')}`;

    const getRouteReadyEvent = (readyEvents, pathname) => {
      if (!readyEvents) return '';

      return readyEvents
        .split('|')
        .map((entry) => entry.trim())
        .filter(Boolean)
        .map((entry) => {
          const separatorIndex = entry.indexOf('=');
          if (separatorIndex < 0) return null;

          return {
            path: entry.slice(0, separatorIndex),
            eventName: entry.slice(separatorIndex + 1),
          };
        })
        .find((entry) => entry?.path && entry.eventName && isSamePath(entry.path, pathname))
        ?.eventName || '';
    };

    const waitForRouteReadyEvent = (eventName) => {
      if (!eventName) return Promise.resolve();

      const readyFlagKey = getReadyFlagKey(eventName);
      if (window[readyFlagKey]) return Promise.resolve();

      return new Promise((resolve) => {
        window.addEventListener(
          eventName,
          () => {
            window[readyFlagKey] = true;
            resolve();
          },
          { once: true }
        );
      });
    };

    const getPendingAnchorY = (activePaths) => {
      const pathname = window.location.pathname;
      const pendingNavigation = window[pendingPreloaderKey];
      const activeHandoff = window[activeHandoffKey];
      const candidates = [pendingNavigation, activeHandoff];

      for (const candidate of candidates) {
        if (
          candidate?.pathname &&
          activePaths.some((path) => isSamePath(path, candidate.pathname)) &&
          isSamePath(candidate.pathname, pathname)
        ) {
          const anchorY = Number.parseFloat(candidate.anchorY);
          if (Number.isFinite(anchorY)) return Math.max(0, anchorY);
        }
      }

      return null;
    };

    const anchorPreloaderToViewport = (overlay, activePaths) => {
      const storedAnchorY = Number.parseFloat(overlay.dataset.preloaderAnchorY || '');
      const pendingAnchorY = getPendingAnchorY(activePaths);
      const anchorY = Number.isFinite(storedAnchorY)
        ? storedAnchorY
        : pendingAnchorY ?? getDocumentScrollY();

      overlay.dataset.preloaderAnchorY = `${anchorY}`;
      overlay.style.setProperty('--home-preloader-anchor-y', `${anchorY}px`);
    };

    const preparePassivePreloaderVideo = (video) => {
      video.autoplay = true;
      video.controls = false;
      video.loop = false;
      video.muted = true;
      video.defaultMuted = true;
      video.playsInline = true;
      video.preload = 'auto';
      video.removeAttribute('controls');
      video.removeAttribute('loop');
      video.setAttribute('autoplay', '');
      video.setAttribute('muted', '');
      video.setAttribute('defaultMuted', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      video.setAttribute('preload', 'auto');
      try {
        video.disablePictureInPicture = true;
      } catch {
        // Some embedded browsers expose the attribute but reject assignment.
      }
      try {
        video.disableRemotePlayback = true;
      } catch {
        // Remote playback controls are best-effort only.
      }
      video.setAttribute('controlsList', 'nodownload noplaybackrate noremoteplayback');
      video.setAttribute('disablePictureInPicture', '');
      video.setAttribute('disableremoteplayback', '');
      video.setAttribute('x-webkit-airplay', 'deny');
      video.setAttribute('aria-hidden', 'true');
      video.tabIndex = -1;
    };

    const playPreloaderVideo = (video, { timeoutMs = 750 } = {}) =>
      new Promise((resolve) => {
        let hasResolved = false;
        let timeout = 0;

        const cleanup = () => {
          if (timeout) window.clearTimeout(timeout);
          video.removeEventListener('playing', onPlaying);
          video.removeEventListener('canplay', onReady);
          video.removeEventListener('canplaythrough', onReady);
          video.removeEventListener('error', onError);
        };

        const done = (didPlay) => {
          if (hasResolved) return;
          hasResolved = true;
          cleanup();
          resolve(didPlay);
        };

        const confirmPlayback = () => {
          if (!video.paused && !video.ended && video.readyState >= 2) {
            done(true);
          }
        };

        const tryPlay = () => {
          if (hasResolved) return;

          try {
            const playAttempt = video.play();

            if (playAttempt?.then) {
              playAttempt.then(confirmPlayback).catch(() => done(false));
              return;
            }

            window.requestAnimationFrame(confirmPlayback);
          } catch {
            done(false);
          }
        };

        function onPlaying() {
          confirmPlayback();
        }

        function onReady() {
          tryPlay();
        }

        function onError() {
          done(false);
        }

        preparePassivePreloaderVideo(video);
        try {
          const isAtEnd =
            Number.isFinite(video.duration) && video.duration > 0 && video.currentTime >= video.duration - 0.05;
          if (video.ended || isAtEnd) video.currentTime = 0;
        } catch {
          // If seeking is unavailable, play() or the fallback path will resolve the state.
        }
        video.addEventListener('playing', onPlaying);
        video.addEventListener('canplay', onReady);
        video.addEventListener('canplaythrough', onReady);
        video.addEventListener('error', onError, { once: true });
        timeout = window.setTimeout(() => done(false), timeoutMs);
        tryPlay();
      });

    const resetPreloaderMediaVisibility = (overlay) => {
      overlay.classList.remove(
        'is-video-visible',
        'is-fallback-visible',
        'is-image-fading',
        'is-overlay-fading'
      );
    };

    const showPreloaderVideo = (overlay) => {
      overlay.classList.remove('is-fallback-visible');
      overlay.classList.add('is-video-visible');
    };

    const showPreloaderFallback = (overlay) => {
      overlay.classList.remove('is-video-visible');
      overlay.classList.add('is-fallback-visible');
    };

    const pausePreloaderVideo = (video) => {
      preparePassivePreloaderVideo(video);

      try {
        video.pause();
      } catch {
        // Ignore media cleanup failures.
      }
    };

    const reviveEndedPreloaderVideo = (video) => {
      preparePassivePreloaderVideo(video);

      const isAtEnd =
        Number.isFinite(video.duration) && video.duration > 0 && video.currentTime >= video.duration - 0.05;

      if (!video.ended && !isAtEnd) return video;

      const freshVideo = video.cloneNode(true);

      if (!(freshVideo instanceof HTMLVideoElement)) return video;

      preparePassivePreloaderVideo(freshVideo);
      video.replaceWith(freshVideo);

      try {
        freshVideo.currentTime = 0;
        freshVideo.load();
      } catch {
        // Playback setup will fall back cleanly if the cloned media is not seekable yet.
      }

      return freshVideo;
    };

    const waitForWindowLoad = () => {
      if (document.readyState === 'complete') return Promise.resolve();

      return new Promise((resolve) => {
        window.addEventListener('load', resolve, { once: true });
      });
    };

    const waitForFonts = () => {
      if (!document.fonts?.ready) return Promise.resolve();

      return document.fonts.ready.catch(() => {});
    };

    const waitForImage = (image) => {
      if (!(image instanceof HTMLImageElement) || !image.src) return Promise.resolve();

      if (image.complete && image.naturalWidth > 0) {
        return image.decode ? image.decode().catch(() => {}) : Promise.resolve();
      }

      return new Promise((resolve) => {
        const done = () => {
          image.removeEventListener('load', done);
          image.removeEventListener('error', done);
          if (image.decode && image.naturalWidth > 0) {
            image.decode().catch(() => {}).then(resolve);
            return;
          }
          resolve();
        };

        image.addEventListener('load', done, { once: true });
        image.addEventListener('error', done, { once: true });
      });
    };

    const waitForPageImages = (overlay) => {
      const images = Array.from(document.images).filter(
        (image) =>
          !overlay.contains(image) &&
          !image.closest('[data-home-preloader]') &&
          !image.closest('[data-home-preloader-handoff]')
      );

      return Promise.all(images.map(waitForImage));
    };

    const waitForAnimationFrame = () =>
      new Promise((resolve) => {
        window.requestAnimationFrame(resolve);
      });

    const waitForStablePageFrame = async (overlay) => {
      await Promise.all([waitForWindowLoad(), waitForFonts(), waitForPageImages(overlay)]);
      await waitForAnimationFrame();
      await waitForAnimationFrame();
    };

    const isForcedByPendingNavigation = (activePaths) => {
      const pendingNavigation = window[pendingPreloaderKey];

      return Boolean(
        pendingNavigation?.forcePreloader &&
          activePaths.some((path) => isSamePath(path, pendingNavigation.pathname || window.location.pathname))
      );
    };

    const getPendingHandoffState = (activePaths) => {
      const visibleHandoff = document.querySelector('[data-home-preloader-handoff]');
      const visibleHandoffPath = visibleHandoff instanceof HTMLElement ? visibleHandoff.dataset.handoffPath : '';
      const activeHandoff = window[activeHandoffKey];
      const pendingNavigation = window[pendingPreloaderKey];
      const shouldHonorVisibleHandoff = Boolean(
        activeHandoff?.startedAt || pendingNavigation?.suppressRoutePreloaderVideo
      );

      if (
        visibleHandoff instanceof HTMLElement &&
        shouldHonorVisibleHandoff &&
        activePaths.some((path) => isSamePath(path, visibleHandoffPath || window.location.pathname))
      ) {
        return {
          cycleComplete: visibleHandoff.dataset.handoffReleased === 'true',
          pathname: visibleHandoffPath || window.location.pathname,
        };
      }

      if (visibleHandoff instanceof HTMLElement && !shouldHonorVisibleHandoff) {
        visibleHandoff.remove();
        document.documentElement.classList.remove('home-preloader-handoff-active');
        clearNavigationPreloaderClassIfIdle();
      }

      if (
        activeHandoff?.startedAt &&
        activePaths.some((path) => isSamePath(path, activeHandoff.pathname || window.location.pathname))
      ) {
        return {
          cycleComplete: Boolean(activeHandoff.cycleComplete),
          pathname: activeHandoff.pathname || window.location.pathname,
        };
      }

      if (
        !pendingNavigation?.suppressRoutePreloaderVideo ||
        !activePaths.some((path) => isSamePath(path, pendingNavigation.pathname || window.location.pathname))
      ) {
        return null;
      }

      return {
        cycleComplete: Boolean(pendingNavigation.handoffCycleComplete),
        pathname: pendingNavigation.pathname || window.location.pathname,
      };
    };

    const initOverlay = (overlay) => {
      if (!(overlay instanceof HTMLElement) || overlay.dataset.homePreloaderBooted === 'true') return;

      overlay.dataset.homePreloaderBooted = 'true';

      const sessionKey = overlay.dataset.sessionKey || 'varelism-home-preloader-seen';
      const completeEvent = overlay.dataset.completeEvent || 'varelism:preloader-complete';
      const activePaths = (overlay.dataset.activePaths || '/|/index.html').split('|').filter(Boolean);
      const routeReadyEvent = getRouteReadyEvent(overlay.dataset.readyEvents || '', window.location.pathname);
      const playOnce = overlay.dataset.playOnce !== 'false';
      const timingScale = Math.max(0.1, Number.parseFloat(overlay.dataset.timingScale || '1') || 1);
      const getDuration = (name, fallback) => {
        const parsed = Number.parseFloat(overlay.dataset[name] || '');

        return Number.isFinite(parsed) && parsed >= 0 ? Math.round(parsed) : Math.round(fallback);
      };
      const requestedImageFadeMs = getDuration('imageFadeMs', 300 * timingScale);
      const requestedWhiteHoldMs = getDuration('whiteHoldMs', 300 * timingScale);
      const requestedOverlayFadeMs = getDuration('overlayFadeMs', 300 * timingScale);
      const isActivePath = activePaths.some((path) => isSamePath(path, window.location.pathname));
      const forcePreloader = isForcedByPendingNavigation(activePaths);
      const handoffState = getPendingHandoffState(activePaths);
      const isSuppressedByReturnBlank = Boolean(
        (document.documentElement.classList.contains('author-return-blank-active') &&
          activePaths.some((path) => isSamePath(path, '/author/'))) ||
          (document.documentElement.classList.contains('architect-return-blank-active') &&
            activePaths.some((path) => isSamePath(path, '/architect/'))) ||
          (document.documentElement.classList.contains('home-return-active') &&
            activePaths.some((path) => isSamePath(path, '/')))
      );
      const isNavigationPreloader = Boolean(handoffState || window[pendingPreloaderKey]?.navigationPreloader);
      const imageFadeMs = isNavigationPreloader ? Math.min(requestedImageFadeMs, 90) : requestedImageFadeMs;
      const whiteHoldMs = isNavigationPreloader ? Math.min(requestedWhiteHoldMs, 24) : requestedWhiteHoldMs;
      const overlayFadeMs = isNavigationPreloader ? Math.min(requestedOverlayFadeMs, 180) : requestedOverlayFadeMs;
      let hasRemoved = false;
      let cleanupVideo = () => {};
      let cleanupHandoffCompletion = () => {};
      const timers = new Set();
      const fallbackCycleDurationMs = Math.ceil(window.__varelismPreloaderCycleDurationMs || 3067) + 180;
      overlay.style.setProperty('--home-preloader-image-fade-ms', `${imageFadeMs}ms`);
      overlay.style.setProperty('--home-preloader-overlay-fade-ms', `${overlayFadeMs}ms`);
      const storage = {
        get() {
          try {
            return sessionStorage.getItem(sessionKey);
          } catch {
            return null;
          }
        },
        set() {
          try {
            sessionStorage.setItem(sessionKey, 'true');
          } catch {
            // Storage can be unavailable in strict privacy contexts.
          }
        },
      };

      const setTimer = (callback, delay) => {
        const timer = window.setTimeout(() => {
          timers.delete(timer);
          callback();
        }, delay);

        timers.add(timer);
        return timer;
      };

      const cleanupOverlay = () => {
        cleanupVideo();
        cleanupHandoffCompletion();
        timers.forEach((timer) => window.clearTimeout(timer));
        timers.clear();

        state.cleanups.delete(cleanupOverlay);
      };

      state.cleanups.add(cleanupOverlay);

      const revealInitialHomeShell = () => {
        if (!document.documentElement.classList.contains(initialHomePreloaderClass)) return;

        document.documentElement.classList.add(initialHomeRevealClass);
        window.requestAnimationFrame(() => {
          document.documentElement.classList.remove(initialHomePreloaderClass);
          window.setTimeout(() => {
            document.documentElement.classList.remove(initialHomeRevealClass);
          }, 520);
        });
      };

      const removeOverlay = () => {
        if (hasRemoved) return;
        hasRemoved = true;
        cleanupOverlay();
        overlay.remove();
        document.documentElement.classList.remove(
          'home-preloader-active',
          'home-preloader-booting'
        );
        revealInitialHomeShell();
        delete overlay.dataset.navigationPreloader;
        clearNavigationPreloaderClassIfIdle();
        clearPendingPreloaderNavigation();
        new Set([completeEvent, ...getRouteCompleteEvents(window.location.pathname)]).forEach((eventName) => {
          window.dispatchEvent(new CustomEvent(eventName));
        });
      };

      if (
        isSuppressedByReturnBlank ||
        !isActivePath ||
        (playOnce && storage.get() === 'true' && !forcePreloader)
      ) {
        removeOverlay();
        return;
      }

      const video = overlay.querySelector('.home-preloader__media');
      const preloaderVideo = video instanceof HTMLVideoElement ? reviveEndedPreloaderVideo(video) : null;
      resetPreloaderMediaVisibility(overlay);

      if (handoffState && preloaderVideo) {
        preparePassivePreloaderVideo(preloaderVideo);

        try {
          preloaderVideo.pause();
          preloaderVideo.currentTime = 0;
        } catch {
          // Astro can insert the autoplaying video before this script takes over.
        }
      }

      if (playOnce) storage.set();
      anchorPreloaderToViewport(overlay, activePaths);
      document.documentElement.classList.add('home-preloader-active');
      if (isNavigationPreloader) {
        overlay.dataset.navigationPreloader = 'true';
        document.documentElement.classList.add(navigationPreloaderClass);
        window.__varelismLockNavigationPreloaderScroll?.();
      }
      overlay.classList.add('is-visible');
      document.documentElement.classList.remove('home-preloader-booting');

      let isPageReady = false;
      let hasMetMediaMoment = Boolean(handoffState?.cycleComplete);
      let isHiding = false;
      let isAwaitingVideoStart = false;
      let isFallbackActive = false;
      let hasStartedMediaCycle = false;
      let mediaCycleTimer = 0;

      const clearMediaCycleTimer = () => {
        if (!mediaCycleTimer) return;

        window.clearTimeout(mediaCycleTimer);
        timers.delete(mediaCycleTimer);
        mediaCycleTimer = 0;
      };

      const hideOverlay = () => {
        if (isHiding || !isPageReady || !hasMetMediaMoment) return;

        isHiding = true;
        overlay.classList.add('is-image-fading');
        setTimer(() => {
          overlay.classList.add('is-overlay-fading');
          setTimer(removeOverlay, overlayFadeMs);
        }, imageFadeMs + whiteHoldMs);
      };

      const markMediaMomentReached = () => {
        if (hasMetMediaMoment) return;
        clearMediaCycleTimer();
        hasMetMediaMoment = true;
        hideOverlay();
      };

      const getVideoCycleDurationMs = () => {
        if (!preloaderVideo || !Number.isFinite(preloaderVideo.duration) || preloaderVideo.duration <= 0) {
          return fallbackCycleDurationMs;
        }

        const remainingMs = Math.max(0, (preloaderVideo.duration - preloaderVideo.currentTime) * 1000);
        return Math.ceil(remainingMs) + 180;
      };

      const scheduleMediaCycleCompletion = (delay) => {
        clearMediaCycleTimer();
        mediaCycleTimer = setTimer(() => {
          mediaCycleTimer = 0;
          completeMediaCycleOrReplay();
        }, delay);
      };

      const startFallbackCycle = () => {
        if (hasRemoved || isHiding || hasMetMediaMoment) return;

        isFallbackActive = true;
        isAwaitingVideoStart = false;
        hasStartedMediaCycle = true;
        showPreloaderFallback(overlay);
        scheduleMediaCycleCompletion(fallbackCycleDurationMs);
      };

      const completeMediaCycleOrReplay = () => {
        if (hasRemoved || isHiding || hasMetMediaMoment) return;

        if (isPageReady) {
          markMediaMomentReached();
          return;
        }

        if (isFallbackActive || !preloaderVideo) {
          startFallbackCycle();
          return;
        }

        startVideoCycle({ restart: true });
      };

      const revealVideoOrFallback = () => {
        if (
          !preloaderVideo ||
          hasRemoved ||
          isHiding ||
          hasMetMediaMoment ||
          isAwaitingVideoStart
        ) {
          return;
        }

        isAwaitingVideoStart = true;
        playPreloaderVideo(preloaderVideo).then((didPlay) => {
          isAwaitingVideoStart = false;
          if (hasRemoved || isHiding) return;

          if (didPlay) {
            isFallbackActive = false;
            hasStartedMediaCycle = true;
            showPreloaderVideo(overlay);
            scheduleMediaCycleCompletion(getVideoCycleDurationMs());
            return;
          }

          startFallbackCycle();
        });
      };

      function startVideoCycle({ restart = false } = {}) {
        if (hasRemoved || isHiding || hasMetMediaMoment) return;

        clearMediaCycleTimer();

        if (!preloaderVideo) {
          startFallbackCycle();
          return;
        }

        if (!restart) {
          resetPreloaderMediaVisibility(overlay);
        }

        try {
          preloaderVideo.pause();
          preloaderVideo.currentTime = 0;
        } catch {
          // If seeking is blocked, play() still keeps the media passive and control-free.
        }

        revealVideoOrFallback();
      }

      if (preloaderVideo) {
        preparePassivePreloaderVideo(preloaderVideo);

        const onEnded = () => {
          if (hasRemoved || isHiding) return;

          completeMediaCycleOrReplay();
        };
        const onError = () => {
          if (handoffState && !hasMetMediaMoment) return;
          startFallbackCycle();
        };
        const onReady = () => {
          if (!hasStartedMediaCycle) revealVideoOrFallback();
        };
        const onMetadata = () => {
          if (hasStartedMediaCycle && !isFallbackActive && !hasMetMediaMoment) {
            scheduleMediaCycleCompletion(getVideoCycleDurationMs());
          }
        };

        preloaderVideo.addEventListener('ended', onEnded);
        preloaderVideo.addEventListener('error', onError, { once: true });
        preloaderVideo.addEventListener('loadedmetadata', onMetadata, { once: true });
        if (!handoffState) {
          preloaderVideo.addEventListener('loadeddata', onReady, { once: true });
          preloaderVideo.addEventListener('canplaythrough', onReady, { once: true });
        }

        cleanupVideo = () => {
          preloaderVideo.removeEventListener('ended', onEnded);
          preloaderVideo.removeEventListener('error', onError);
          preloaderVideo.removeEventListener('loadedmetadata', onMetadata);
          preloaderVideo.removeEventListener('loadeddata', onReady);
          preloaderVideo.removeEventListener('canplaythrough', onReady);

          try {
            pausePreloaderVideo(preloaderVideo);
          } catch {
            // Ignore media cleanup failures.
          }
        };

        if (!handoffState) {
          startVideoCycle();
        }
      } else {
        startFallbackCycle();
      }

      if (handoffState && !handoffState.cycleComplete) {
        const onHandoffComplete = (event) => {
          const pathname = event?.detail?.pathname;

          if (pathname && !activePaths.some((path) => isSamePath(path, pathname))) return;

          cleanupHandoffCompletion();
          markMediaMomentReached();
        };

        window.addEventListener('varelism:handoff-complete', onHandoffComplete);
        cleanupHandoffCompletion = () => {
          window.removeEventListener('varelism:handoff-complete', onHandoffComplete);
          cleanupHandoffCompletion = () => {};
        };
      }

      Promise.all([waitForStablePageFrame(overlay), waitForRouteReadyEvent(routeReadyEvent)]).then(() => {
        if (hasRemoved) return;
        isPageReady = true;
        if (hasStartedMediaCycle && preloaderVideo?.ended && !hasMetMediaMoment) {
          completeMediaCycleOrReplay();
        }
        hideOverlay();
      });
    };

    const initPreloaders = () => {
      document.querySelectorAll('[data-home-preloader]').forEach(initOverlay);
    };

    const initPreloadersAfterSwap = () => {
      initPreloaders();
      window.requestAnimationFrame(initPreloaders);
    };

    if (!state.listenersAttached) {
      document.addEventListener('astro:after-swap', initPreloadersAfterSwap);
      document.addEventListener('astro:page-load', initPreloaders);
      document.addEventListener('astro:before-swap', () => {
        state.cleanups.forEach((cleanup) => cleanup());
        state.cleanups.clear();
        if (!shouldKeepBootingAfterSwap()) {
          document.documentElement.classList.remove('home-preloader-active', 'home-preloader-booting');
          document.documentElement.classList.remove(initialHomePreloaderClass, initialHomeRevealClass);
          clearNavigationPreloaderClassIfIdle();
          if (!shouldPreservePendingHandoffAfterSwap()) {
            clearPendingPreloaderNavigation();
          }
        }
      });
      state.listenersAttached = true;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPreloaders, { once: true });
    } else {
      initPreloaders();
    }
  })();
</script>

